extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelControl — Examples"

block content
	.lane
		.container
			.page-header
				h1 PanelControl examples
				p.lead Vertical tablists, activation modes, and closable megamenus.

	+section("Vertical tablist (sidebar)")
		p A sidebar is just a tablist with #[code aria-orientation="vertical"] — arrows become Up / Down, everything else is identical. CSS lays the rail beside the panels. No tree, no extra ARIA.

		.card
			.demo
				.vc-layout
					nav.tabs.vc-rail(role="tablist" aria-orientation="vertical" data-panelcontrol)
						button(role="tab" aria-controls="vc-1" aria-selected="true") Profile
						button(role="tab" aria-controls="vc-2") Account
						button(role="tab" aria-controls="vc-3") Billing
					#vc(data-panelset)
						.panel-wrapper
							#vc-1.active(role="tabpanel" aria-label="Profile")
								h3 Profile
								p Focus the rail and use #[strong Up] / #[strong Down]. #[code Home] / #[code End] jump to the ends.
								br
								p Make the PanelSet #[strong closable] with #[code data-close-on-tab], then position it #[code absolute] so it #[strong floats over] the content instead of pushing it down — a dropdown megamenu. A button opens and switches panels; clicking the open one closes it. PanelControl wires the clicks and stamps #[code data-closeable] so the open button stays clickable; the chevrons flip with the open state.


							#vc-2(role="tabpanel" hidden aria-label="Account")
								h3 Account
								p Same keyboard model as a horizontal tablist, rotated.
							#vc-3(role="tabpanel" hidden aria-label="Billing")
								h3 Billing
								p For a flat sidebar like this, a vertical tablist is all you need.

			+codeblock('HTML')
				nav(role="tablist" aria-orientation="vertical" data-panelcontrol)
					button(role="tab" aria-controls="vc-1" aria-selected="true") Profile
					button(role="tab" aria-controls="vc-2") Account
					button(role="tab" aria-controls="vc-3") Billing
				+n
				#vc(data-panelset)
					.panel-wrapper
						#vc-1.active(role="tabpanel") …
						#vc-2(role="tabpanel" hidden) …
						#vc-3(role="tabpanel" hidden) …

	+section("Grouped sidebar — navigation, not tabs")
		p A categorized sidebar reads as one list, and that is the tell: it is #[strong navigation], not a tab strip. So this is a plain menu — every item is in the normal #[strong Tab] order, #[strong Enter] / #[strong Space] activates, and PanelControl just wires the clicks. The category labels are headings; they are not interactive.

		p #[strong Why not grouped tablists?] The tab pattern uses a roving #[code tabindex]: a tablist is a single Tab stop, and #[strong arrow keys] navigate #[em inside] it. Two tablists means two roving islands — #[strong Tab] would hop group-to-group while the arrow keys stay trapped within one group. That split fights the way a single list reads. Tabs suit a small, flat set (the vertical tablist above); a categorized sidebar is navigation. Reach for a #[strong tree] only when categories must collapse and expand.

		.card
			.demo
				.grp-layout
					nav.grp-rail(aria-label="Settings" data-panelcontrol)
						h4.grp-heading Account
						button(aria-controls="grp-profile") Profile
						button(aria-controls="grp-billing") Billing
						h4.grp-heading Workspace
						button(aria-controls="grp-members") Members
						button(aria-controls="grp-settings") Settings
					#grp(data-panelset)
						.panel-wrapper
							#grp-profile.active(role="tabpanel" aria-label="Profile")
								h3 Profile
								p One menu, one PanelSet. #[strong Tab] walks through every item in order — no roving, no arrow/Tab split.
							#grp-billing(role="tabpanel" hidden aria-label="Billing")
								h3 Billing
								p The headings group the items visually; they are plain labels, skipped by the keyboard.
							#grp-members(role="tabpanel" hidden aria-label="Members")
								h3 Members
								p PanelSet marks the active item; the rail styles it from that state.
							#grp-settings(role="tabpanel" hidden aria-label="Settings")
								h3 Settings
								p Need collapsible categories instead? That is a tree — planned, not this.

			+codeblock('HTML')
				// A menu: no role="tablist", so every button is a normal Tab stop.
				nav(aria-label="Settings" data-panelcontrol)
					h4 Account
					button(aria-controls="grp-profile") Profile
					button(aria-controls="grp-billing") Billing
					h4 Workspace
					button(aria-controls="grp-members") Members
					button(aria-controls="grp-settings") Settings
				+n
				#grp(data-panelset)
					.panel-wrapper
						#grp-profile.active(role="tabpanel") …
						#grp-billing(role="tabpanel" hidden) …
						#grp-members(role="tabpanel" hidden) …
						#grp-settings(role="tabpanel" hidden) …

	+section("Auto activation")
		p By default arrow keys move focus and you commit with #[strong Enter] / #[strong Space] / click (#[code activation: 'manual']). Set #[code data-activation="auto"] (or #[code init({ activation: 'auto' })]) to activate as you arrow across.

		.card
			.demo
				nav.tabs(role="tablist" data-panelcontrol data-activation="auto")
					button(role="tab" aria-controls="auto-1" aria-selected="true") One
					button(role="tab" aria-controls="auto-2") Two
					button(role="tab" aria-controls="auto-3") Three
				#gs-auto(data-panelset)
					.panel-wrapper
						#auto-1.active(role="tabpanel" aria-label="One")
							h3 One
							p Click a tab to focus it, then arrow right — the panel changes immediately, no Enter.
						#auto-2(role="tabpanel" hidden aria-label="Two")
							h3 Two
							p Focus stays on the tab strip the whole time.
						#auto-3(role="tabpanel" hidden aria-label="Three")
							h3 Three
							p Arrow back to step the other way.

			+codeblock('JS').
				PanelControl.init({ activation: 'auto' });
				// or per control, in markup:
				// <nav role="tablist" data-panelcontrol data-activation="auto">

	+section("Arrow protection (auto → manual)")
		p #[code auto] falls back to manual whenever activating-on-arrow would hurt: when the PanelSet uses #[code autoFocus] (focus would jump into the panel, out of the strip) or loads content asynchronously (every keystroke would fire a load). The #[code autoFocus] check covers the JS option, #[code data-auto-focus] on the set, and #[code data-auto-focus] on any individual tab.

		p This strip asks for #[code data-activation="auto"] too, but its PanelSet has #[code data-auto-focus="input"]. So PanelControl quietly keeps it #[strong manual]: #[strong Tab] into the strip and arrow across — the panel stays put. Press #[strong Enter] to switch, and watch focus drop into the field. That focus-stealing on every arrow is exactly what auto avoids here.

		.card
			.demo
				nav.tabs(role="tablist" data-panelcontrol data-activation="auto")
					button(role="tab" aria-controls="df-1" aria-selected="true") Account
					button(role="tab" aria-controls="df-2") Profile
					button(role="tab" aria-controls="df-3") Confirm
				#gs-downgrade(data-panelset data-auto-focus="input")
					.panel-wrapper
						#df-1.active(role="tabpanel" aria-label="Account")
							h3 Account
							label
								| Name
								input(type="text" placeholder="Your name")
						#df-2(role="tabpanel" hidden aria-label="Profile")
							h3 Profile
							label
								| Email
								input(type="email" placeholder="you@example.com")
						#df-3(role="tabpanel" hidden aria-label="Confirm")
							h3 Confirm
							p Nothing to focus here, so activating this one leaves focus on the tab.

	+section("Closable megamenu (absolute)")
		p Make the PanelSet #[strong closable] with #[code data-close-on-tab], then position it #[code absolute] so it #[strong floats over] the content instead of pushing it down — a dropdown megamenu. A button opens and switches panels; clicking the open one closes it. PanelControl wires the clicks and stamps #[code data-closeable] so the open button stays clickable; the chevrons flip with the open state.

		.card
			.demo
				nav.tabs(role="tablist" data-panelcontrol data-activation="auto")
					button(role="tab" aria-controls="mm-1")
						span Features
						+chevron(16, 'down')
					button(role="tab" aria-controls="mm-2")
						span Pricing
						+chevron(16, 'down')
					button(role="tab" aria-controls="mm-3")
						span Support
						+chevron(16, 'down')
				hr
				#mm(data-panelset data-closable data-close-on-tab data-panelset-align="end")
					.panel-wrapper
						#mm-1.active(role="tabpanel" aria-label="Products")
							+example-1
						#mm-2(role="tabpanel" hidden aria-label="Solutions")
							+example-2
						#mm-3(role="tabpanel" hidden aria-label="Resources")
							+example-3

			h4 Markup
			+codeblock('HTML')
				nav(role="tablist" data-panelcontrol)
					button(role="tab" aria-controls="mm-1") Products
					button(role="tab" aria-controls="mm-2") Solutions
					button(role="tab" aria-controls="mm-3") Resources
				+n
				#mm(data-panelset data-closable data-close-on-tab)
					.panel-wrapper
						#mm-1.active(role="tabpanel") …
						#mm-2(role="tabpanel" hidden) …

			h4 Positioning
			p The wrapping #[code .demo] is the positioning context; the closable set is taken out of flow so it overlays rather than pushes.
			+codeblock('CSS').
				.demo { position: relative; }

				#mm {
					position: absolute;
					left: 0;
					right: 0;
					z-index: 10;
				}


append styles
	style.
		#gs-auto,
		#gs-downgrade,
		#vc,
		#grp {
			border: 1px solid var(--border-default);
			border-radius: 8px;
		}
		#gs-auto .panel-wrapper [role="tabpanel"],
		#gs-downgrade .panel-wrapper [role="tabpanel"],
		#vc .panel-wrapper [role="tabpanel"],
		#grp .panel-wrapper [role="tabpanel"] {
			padding: 1.25rem;
		}
		/* Vertical tablist: rail beside the panels */
		.vc-layout {
			display: flex;
			gap: 1.5rem;
			//- align-items: flex-start;
		}
		.vc-rail {
			flex: 0 0 10rem;
			flex-direction: column;
			align-items: stretch;
		}
		.vc-rail button {
			text-align: left;
		}
		#vc {
			flex: 1;
			min-width: 0;
		}
		/* Grouped sidebar: a nav menu (no tablist) — items are normal Tab stops */
		.grp-layout {
			display: flex;
			gap: 1.5rem;
			align-items: flex-start;
		}
		.grp-rail {
			flex: 0 0 10rem;
		}
		.grp-rail button {
			display: block;
			width: 100%;
			text-align: left;
			padding: 0.35rem 0.75rem;
			border: 0;
			border-left: 3px solid transparent;
			background: none;
			color: inherit;
			font: inherit;
			cursor: pointer;
		}
		.grp-rail button[aria-selected="true"] {
			border-left-color: currentColor;
			font-weight: 600;
		}
		.grp-heading {
			margin: 1rem 0 0.25rem;
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
			opacity: 0.6;
		}
		.grp-heading:first-child {
			margin-top: 0;
		}
		#grp {
			flex: 1;
			min-width: 0;
		}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			PanelControl.init();
	else
		script(type="module").
			import { PanelSet, PanelControl } from 'panelset';
			PanelSet.init({ debug: true });
			PanelControl.init({ debug: true });
