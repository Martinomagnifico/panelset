extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelFlow | Examples | Finalize"

block content
	.lane
		.container
			.page-header
				h1 Finalize
				p.lead A tabbed flow whose last step finishes with an action, not a dead-end Next.

	+section("Finish as an action")
		p A wizard's last step usually is not "go to the next panel" — there is no next panel. It is #[strong finish]: submit, calculate, navigate away. So on the last step PanelFlow turns the forward control into a #[strong Finish] action: it stays #[strong enabled] once the step is valid (instead of dimming at the end), relabels itself, and its click fires a #[code pf:finish] event. What finishing #[em does] is yours — here it just shows an alert.

	+section("Live demo")
		.card
			.demo
				nav.tabs#pfin-tabs(role="tablist" data-panelcontrol data-panelflow aria-label="Steps")
					button(role="tab" aria-controls="pfin-1" aria-selected="true") Account
					button(role="tab" aria-controls="pfin-2") Profile
					button(role="tab" aria-controls="pfin-3") Confirm

				#pfin.tab-content(data-panelset data-ps-levels data-auto-focus="heading")
					.panel-wrapper
						.active#pfin-1(role="tabpanel" aria-label="Account")
							h3 Step 1. Account
							label.wizard-check
								input(type="checkbox" required)
								span I agree to create an account
						#pfin-2(role="tabpanel" hidden aria-label="Profile")
							h3 Step 2. Profile
							label.wizard-check
								input(type="checkbox" required)
								span I confirm my profile details are correct
						#pfin-3(role="tabpanel" hidden aria-label="Confirm")
							h3 Step 3. Confirm
							label.wizard-check
								input(type="checkbox" required)
								span I accept the terms and conditions

				.wizard-nav
					button.secondary(data-ps-prev="#pfin" data-ps-disabled-hint="pfin-prev-hint") Previous
					button(data-ps-next="#pfin" data-pf-finish="Finish" data-pf-disabled-hint="pfin-incomplete") Next
				span#pfin-prev-hint(hidden) You're on the first step.
				span#pfin-incomplete(hidden) Complete this step before continuing.

			p #[strong Try it]: step through with #[strong Next]. On #[strong Confirm] the button becomes #[strong Finish] and stays enabled once the box is ticked — pressing it fires the finish action (an alert here), instead of being a dimmed Next with nowhere to go.

			h4 Markup
			+codeblock('HTML')
				nav.tabs(role="tablist" data-panelcontrol data-panelflow aria-label="Steps")
					button(role="tab" aria-controls="pfin-1" aria-selected="true") Account
					button(role="tab" aria-controls="pfin-2") Profile
					button(role="tab" aria-controls="pfin-3") Confirm
				+n
				#pfin(data-panelset data-ps-levels data-auto-focus="heading")
					.panel-wrapper
						#pfin-1.active(role="tabpanel") …
						#pfin-2(role="tabpanel" hidden) …
						#pfin-3(role="tabpanel" hidden) …
				+n
				.wizard-nav
					button(data-ps-prev="#pfin" data-ps-disabled-hint="pfin-prev-hint") Previous
					button(data-ps-next="#pfin" data-pf-finish="Finish" data-pf-disabled-hint="pfin-incomplete") Next
				span#pfin-prev-hint(hidden) You're on the first step.
				span#pfin-incomplete(hidden) Complete this step before continuing.

			h4 JavaScript
			+codeblock('JS').
				import { PanelSet, PanelControl } from 'panelset';
				import { PanelFlow } from 'panelflow'; // preview

				PanelSet.init();
				PanelControl.init();
				PanelFlow.init();

				// What finishing DOES is the app's. PanelFlow fires pf:finish on the
				// last step; here we just acknowledge it.
				document.querySelector('#pfin')
					.addEventListener('pf:finish', () => alert('Submitted! Your finalize action would run here.'));

	+section("What PanelFlow did")
		p The #[code data-ps-next] button is a forward verb everywhere but the end. On the last step PanelFlow stops dimming it (so it stays usable), swaps its label to its #[code data-pf-finish] text, and intercepts the click — turning a no-op "next" into a #[code pf:finish] event. The flow still gates and locks the earlier steps; only the terminal control changes character, from #[strong navigation] to #[strong action].


append styles
	style.
		#pfin {
			--ps-panel-in-transform-from: translateX(40px);
			--ps-panel-out-transform-to:  translateX(-40px);
			--ps-panel-in-delay: 0s;
		}
		.wizard-nav {
			display: flex;
			justify-content: space-between;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.wizard-check {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.tabs [role="tab"][aria-disabled="true"],
		.wizard-nav [aria-disabled="true"] {
			opacity: 0.4;
			cursor: not-allowed;
		}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script(src=`${basePath}assets/scripts/panelflow.js` vite-ignore)
		script.
			PanelSet.init();
			PanelControl.init();
			PanelFlow.init();
			document.querySelector('#pfin').addEventListener('pf:finish', () => alert('Submitted! Your finalize action would run here.'));
	else
		script(src="/src/assets/scripts/panelflow.js")
		script(type="module").
			import { PanelSet, PanelControl } from 'panelset';
			PanelSet.init({ debug: true });
			PanelControl.init({ debug: true });
			PanelFlow.init();
			document.querySelector('#pfin').addEventListener('pf:finish', () => alert('Submitted! Your finalize action would run here.'));
