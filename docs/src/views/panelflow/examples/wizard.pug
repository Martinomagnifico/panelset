extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelFlow | Examples | Wizard"

block content
	.lane
		.container
			.page-header
				h1 Wizard
				p.lead The PanelControl wizard's gated flow — with the per-page script replaced by one PanelFlow.init().

	+section("Live demo")
		p The same three-step gated wizard as the #[a(href="/panelcontrol/examples/wizard.html") PanelControl version]: a required checkbox gates each step, later steps lock, and #[strong Next] stays disabled until the current step is valid. Here #[strong all] of that is PanelFlow — the page adds #[code data-panelflow] to the strip and calls #[code PanelFlow.init()]. There is no per-page flow script.

		.card
			.demo
				nav.tabs#pfwiz-tabs(role="tablist" data-panelcontrol data-panelflow aria-label="Steps")
					button(role="tab" aria-controls="pfwiz-step-1" aria-selected="true") Account
					button(role="tab" aria-controls="pfwiz-step-2") Profile
					button(role="tab" aria-controls="pfwiz-step-3") Confirm

				#pfwiz.tab-content(data-panelset data-ps-levels data-auto-focus="heading")
					.panel-wrapper
						.active#pfwiz-step-1(role="tabpanel" aria-label="Account")
							h3 Step 1. Account
							label.wizard-check
								input(type="checkbox" required)
								span I agree to create an account
						#pfwiz-step-2(role="tabpanel" hidden aria-label="Profile")
							h3 Step 2. Profile
							label.wizard-check
								input(type="checkbox" required)
								span I confirm my profile details are correct
						#pfwiz-step-3(role="tabpanel" hidden aria-label="Confirm")
							h3 Step 3. Confirm
							label.wizard-check
								input(type="checkbox" required)
								span I accept the terms and conditions

				.wizard-nav
					button.secondary(data-ps-prev="#pfwiz" data-ps-disabled-hint="pfwiz-prev-hint") Previous
					button(data-ps-next="#pfwiz" data-pf-disabled-hint="pfwiz-incomplete") Next
				span#pfwiz-prev-hint(hidden) You're on the first step.
				span#pfwiz-incomplete(hidden) Complete this step before continuing.

			p #[strong Try it]: with the current step unticked, #[strong Next] is disabled (focus it to hear why) and the later tabs stay locked. Tick the box and #[strong Next] enables and the next tab unlocks.

			h4 Markup
			+codeblock('HTML')
				nav.tabs(role="tablist" data-panelcontrol data-panelflow aria-label="Steps")
					button(role="tab" aria-controls="pfwiz-step-1" aria-selected="true") Account
					button(role="tab" aria-controls="pfwiz-step-2") Profile
					button(role="tab" aria-controls="pfwiz-step-3") Confirm
				+n
				#pfwiz(data-panelset data-ps-levels data-auto-focus="heading")
					.panel-wrapper
						#pfwiz-step-1.active(role="tabpanel")
							label
								input(type="checkbox" required)
								span I agree to create an account
						#pfwiz-step-2(role="tabpanel" hidden) …
						#pfwiz-step-3(role="tabpanel" hidden) …
				+n
				.wizard-nav
					button(data-ps-prev="#pfwiz" data-ps-disabled-hint="pfwiz-prev-hint") Previous
					button(data-ps-next="#pfwiz" data-pf-disabled-hint="pfwiz-incomplete") Next
				span#pfwiz-prev-hint(hidden) You're on the first step.
				span#pfwiz-incomplete(hidden) Complete this step before continuing.

			h4 JavaScript
			+codeblock('JS').
				import { PanelSet, PanelControl } from 'panelset';
				import { PanelFlow } from 'panelflow'; // preview

				PanelSet.init();
				PanelControl.init();
				PanelFlow.init();

	+section("What PanelFlow did")
		p Next to the #[a(href="/panelcontrol/examples/wizard.html") hand-wired PanelControl wizard], the whole per-page flow script is gone. PanelFlow took over the forward gate, the step locking through #[code setTabState], and disabling Next until the step is valid — announcing your #[code data-pf-disabled-hint] message (#[code #pfwiz-incomplete]) while it is blocked. The markup gained #[code data-panelflow] and the hint messages. As PanelFlow grows, schema-driven validation, branching, and persistence will land here too.


append styles
	style.
		#pfwiz {
			--ps-panel-in-transform-from: translateX(40px);
			--ps-panel-out-transform-to:  translateX(-40px);
			--ps-panel-in-delay: 0s;
		}
		.wizard-nav {
			display: flex;
			justify-content: space-between;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.wizard-check {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.tabs [role="tab"][aria-disabled="true"],
		.wizard-nav [aria-disabled="true"] {
			opacity: 0.4;
			cursor: not-allowed;
		}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script(src=`${basePath}assets/scripts/panelflow.js` vite-ignore)
		script.
			PanelSet.init();
			PanelControl.init();
			PanelFlow.init();
	else
		script(src="/src/assets/scripts/panelflow.js")
		script(type="module").
			import { PanelSet, PanelControl } from 'panelset';
			PanelSet.init({ debug: true });
			PanelControl.init({ debug: true });
			PanelFlow.init();
