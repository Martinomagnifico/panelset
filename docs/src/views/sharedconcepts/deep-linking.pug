extends /views/templates/layouts/_base

append variables
	- pagetitle = "Deep linking"

block content
	.lane
		.container
			.page-header
				h1 Deep linking
				p.lead Link directly to any panel state via a single #[code ?panel=] URL param. Works for both Panel and PanelSet.

	.lane
		.container
			+anchor How it works

			p Both components read the #[code ?panel=] query param on every page load. The value is a comma-separated list of panel IDs.

			+codeblock('HTML').
				<!-- Open or activate a single panel -->
				<a href="?panel=pricing">Link to Pricing</a>

				<!-- Open or activate multiple panels at once -->
				<a href="?panel=pricing,sidebar">Pricing tab open, sidebar open</a>

			p Because HTML IDs are globally unique, a panel ID unambiguously identifies one element, whether it is a standalone #[code [data-panel]] collapse or a #[code [role="tabpanel"]] inside a PanelSet.

			p The full priority chain on load is:

			ol
				li #[strong URL param] (#[code ?panel=]): explicit incoming link, always wins
				li #[strong localStorage]: restores the last visited state when no URL param is present
				li #[strong HTML default]: first panel, or whichever has #[code class="active"]

			p URL params are always read on load. Writing state back — updating the URL and localStorage when the user navigates — requires #[code persist: true]. See #[a(href="/sharedconcepts/persisting.html") Persisting state].

	.lane
		.container
			+anchor PanelSet

			p When a #[code ?panel=] value matches one of a PanelSet's panels, that panel is made active on load.

			+codeblock('HTML').
				<nav role="tablist">
				  <button role="tab" aria-controls="features">Features</button>
				  <button role="tab" aria-controls="pricing">Pricing</button>
				</nav>

				<!-- ?panel=pricing activates the Pricing tab -->
				<div id="main-tabs" data-panelset data-panel-persist>
				  <div class="panel-wrapper">
				    <div class="active" role="tabpanel" id="features">...</div>
				    <div role="tabpanel" id="pricing" hidden>...</div>
				  </div>
				</div>

			p When #[code persist] is enabled and the user switches tabs, the URL is updated: the previous panel ID is removed from the list and the new active panel ID is added.

			p The PanelSet element must have an #[code id] for #[code persist] to work.

	.lane
		.container
			+anchor Panel

			p When a #[code ?panel=] value includes a panel's own ID, that panel is opened on load.

			+codeblock('HTML').
				<!-- ?panel=sidebar opens this panel on load -->
				<div id="sidebar" data-panel data-panel-persist class="is-closed">
				  <div class="panel-wrapper">...</div>
				</div>

			p For accordion groups, set #[code data-panel-persist] on the #[code [data-panel-group]] element, to avoid having to add it to each panel individually.

			+codeblock('HTML').
				<!-- data-panel-persist on the group covers all direct panels -->
				<div data-panel-group data-panel-persist>
				  <div>
				    <button aria-controls="faq-1" aria-expanded="false">Question 1</button>
				    <div id="faq-1" data-panel class="is-closed">
				      <div class="panel-wrapper">Answer 1</div>
				    </div>
				  </div>
				  <div>
				    <button aria-controls="faq-2" aria-expanded="false">Question 2</button>
				    <div id="faq-2" data-panel class="is-closed">
				      <div class="panel-wrapper">Answer 2</div>
				    </div>
				  </div>
				</div>

			p When a panel closes, its ID is removed from #[code ?panel=]. When it opens, the ID is added. Multiple open panels accumulate naturally: #[code ?panel=faq-1,faq-2].

	.lane
		.container
			+anchor Mixed components

			p Because the param is a flat list of IDs, PanelSet panels and standalone panels can coexist in the same URL without any special syntax.

			+codeblock('HTML').
				<!-- Activate the Pricing tab and open the sidebar in one link -->
				<a href="?panel=pricing,sidebar">View pricing with sidebar open</a>



append scripts
	if isProd
		script(src="/lib/panelset.js" vite-ignore)
	else
		script(type="module").
			import { Panel, PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init({ debug: true });
