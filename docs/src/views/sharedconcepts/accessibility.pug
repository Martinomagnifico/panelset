extends /views/templates/layouts/_base

append variables
	- pagetitle = "Accessibility"


block content
	.lane
		.container
			.page-header
				h1=pagetitle
				p.lead Both Panel and PanelSet are accessible... up to a point.

	+section("Overview")
		p The library handles ARIA attributes automatically. Autofocus is built in, but will need to be configured. Furthermore, you will still need to provide the correct markup and keyboard navigation.

	+section("Panel - accessibility", "Panel")
		p #[code Panel] manages #[code aria-expanded] on all trigger elements (#[code [aria-controls]]) automatically. It also uses the #[code inert] attribute on closed panels to remove them from the tab order and accessibility tree without affecting layout.

		.indented
			h3 Trigger markup

			+codeblock('HTML')
				// aria-expanded is set automatically by Panel
				button(aria-controls="my-panel", aria-expanded="false") Toggle

		.indented
			h3 Panel markup
			p Use #[code role="dialog"] for modal-like sidebars, #[code role="region"] for inline panels.

			+codeblock('HTML')
				#my-panel(data-panel data-panel-axis="horizontal")
					.panel-wrapper(role="dialog" aria-label="Settings")
						button(data-panel-close aria-label="Close Settings") ✕
						// content

		.indented
			h3 Focus management
			p Use #[code autoFocus] to move focus into the panel on open, and #[code returnFocus] to return it to the trigger on close.
			+codeblock('JS').
				new Panel('#my-panel', {
					autoFocus: 'first',   // focus first focusable element on open
					returnFocus: true     // return focus to trigger on close
				});

	+section("PanelSet - accessibility", "PanelSet")
		p PanelSet manages #[code aria-selected] automatically on all #[code [aria-controls]] trigger elements. It is set immediately when a tab switch is committed, before the animation ends. The #[code inert] attribute is applied to the closed container and to panels that are not yet visible during a transition.

		.indented
			h3 What PanelSet does automatically

			.card
				table.table
					thead
						tr
							th When
							th PanelSet automatically
					tbody
						tr
							td On initialisation
							td Sets #[code aria-selected] on all #[code [aria-controls]] triggers to match the active panel
						tr
							td Tab is switched
							td Updates #[code aria-selected] immediately when the new tab is committed (before the animation ends)
						tr
							td Closable panelset is closed
							td Adds #[code inert] to the container, removing it and its contents from the tab order entirely


			h3 What you still need to provide

			ul
				li Keyboard navigation (arrow keys, Home, End) if using a proper #[code role="tablist"] pattern
				li #[code aria-labelledby] or #[code aria-label] on each panel
				li Initial #[code aria-selected] state in HTML (overridden on init, but correct for no-JS fallback)

	+section("PanelSet - required markup", "Required markup")
		.card.api
			h3 Panel elements
			p Every panel must have #[code role="tabpanel"] and a unique #[code id].

			+codeblock('HTML')
				div(data-panelset)
					div(role="tabpanel" id="panel-1" aria-labelledby="tab-1") <!-- Content -->
					div(role="tabpanel" id="panel-2" aria-labelledby="tab-2") <!-- Content -->


		.card.api
			h3 Tab buttons
			p For proper tab interfaces, wrap buttons in a #[code role="tablist"] with #[code role="tab"] and #[code aria-controls].

			+codeblock('HTML')
				nav(role="tablist" aria-label="Settings sections")
					button(role="tab" id="tab-1" aria-controls="panel-1" aria-selected="true") Overview
					button(role="tab" id="tab-2" aria-controls="panel-2" aria-selected="false") Security


	+section("PanelSet - focus management", "Focus management")
		p Switch panels with your #[strong keyboard] to see #[code autoFocus] in action. Tab to a button, press Enter, and watch where focus lands.


		.card
			+anchor('h3', 'a11y-heading')(title="autoFocus: 'heading'")
			p Focus moves to the first heading in the incoming panel. Headings must have #[code tabindex="-1"] to be programmatically focusable.

			.demo
				.demo-controls
					button(aria-controls="a11y-h-panel-1") Panel 1
					button(aria-controls="a11y-h-panel-2") Panel 2
					button(aria-controls="a11y-h-panel-3") Panel 3
				div#a11y-heading-demo(data-panelset)
					.panel-wrapper
						div.active(role="tabpanel" id="a11y-h-panel-1" aria-labelledby="a11y-h-tab-1")
							h3(tabindex="-1") Key Features
							p Switch to this panel with keyboard to see focus land on this heading. Here is #[a(href="#a11y-heading") A focusable link in this panel].

						div(role="tabpanel" id="a11y-h-panel-2" hidden aria-labelledby="a11y-h-tab-2")
							h3(tabindex="-1") Pricing Plans
							p Switch to this panel with keyboard to see focus land on this heading.
							button(type="button") A button in this panel
						div(role="tabpanel" id="a11y-h-panel-3" hidden aria-labelledby="a11y-h-tab-3")
							h3(tabindex="-1") Support Options
							p Switch to this panel with keyboard to see focus land on this heading.
							input(type="text" placeholder="An input in this panel")


		.card
			+anchor('h3', 'a11y-first')(title="autoFocus: 'first'")
			p Focus moves to the first focusable element. Kind of ideal for wizard steps where you want the user in the form immediately.

			.demo
				.demo-controls
					button(aria-controls="a11y-f-panel-1") Step 1
					button(aria-controls="a11y-f-panel-2") Step 2
					button(aria-controls="a11y-f-panel-3") Step 3
				div#a11y-first-demo(data-panelset)
					.panel-wrapper
						
						div.active(role="tabpanel" id="a11y-f-panel-1" aria-label="Step 1: Your name")
							h3 Step 1. Your name
							p Focus will land on the input below when you arrive here via keyboard.
							label
								| Name:
								input(type="text" placeholder="Enter your name")
						
						div(role="tabpanel" id="a11y-f-panel-2" hidden aria-label="Step 2: Your email")
							h3 Step 2. Your email
							p Focus will land on the input below when you arrive here via keyboard.
							label
								| Email:
								input(type="email" placeholder="Enter your email")
						
						div(role="tabpanel" id="a11y-f-panel-3" hidden aria-label="Step 3: Confirm")
							h3 Step 3. Confirm
							p Focus will land on the submit button when you arrive here via keyboard.
							p Review your details and submit when ready.

				.demo-controls(style="justify-content: space-between")
					button#a11y-wizard-back.btn.chevron.back(disabled)
						+chevron(24, 'left')
						| Back
					button#a11y-wizard-next.btn.chevron
						| Next
						+chevron()

		+anchor('h3', 'a11y-input')(title="autoFocus: 'input'")
		p Focus moves to the first #[code input], #[code select], or #[code textarea] in the incoming panel. 
		.callout 
			+warning()
			p #[strong Note]: this moves the focus for ALL users, not just keyboard.

		.card
			.demo
				.demo-controls
					button(aria-controls="a11y-i-panel-1") Welcome
					button(aria-controls="a11y-i-panel-2") Sign in

				div#a11y-input-demo(data-panelset)
					.panel-wrapper
						div.active(role="tabpanel" id="a11y-i-panel-1" aria-label="Welcome")
							h3 Welcome
							p We have an other panel for you.

						div(role="tabpanel" id="a11y-i-panel-2" hidden aria-label="Sign in")
							h3 Sign in
							p Please fill in your email to sign in.
							label
								| Email:
								input(type="email" placeholder="you@example.com")

	+section("autoFocus options")
		p Both #[code Panel] and #[code PanelSet] support the same #[code autoFocus] values.

		.card.api
			table.table
				thead
					tr
						th Value
						th What it focuses
						th Best for
				tbody
					tr
						td #[code 'heading']
						td First #[code h1–h6] in panel (needs #[code tabindex="-1"])
						td Standard tabs with headings
					tr
						td #[code 'first']
						td First focusable element (button, link, input)
						td Wizard steps, forms
					tr
						td #[code true]
						td The panel element itself
						td Panels with #[code aria-label]
					tr
						td #[code 'input']
						td First form field (input, select, textarea)
						td Forms, bypasses keyboard-only check
					tr
						td #[code false]
						td Nothing (no focus movement)
						td Page load, mouse-only interfaces

		.card.api
			h3 Keyboard vs. mouse detection

			p When you pass the #[code event] to #[code show()], PanelSet only moves focus on keyboard activation (Enter/Space). Mouse clicks skip the focus movement, preventing unwanted scroll.

			+codeblock('JS').
				button.addEventListener('click', (event) => {
					panelSet.show('panel-2', {
						event,              // pass the event
						autoFocus: 'heading'
					});
					// keyboard: focuses heading
					// mouse click: no focus movement
				});

			.callout
				+warning()
				p #[strong Best practice:] Always pass #[code event] to #[code show()]. Without it, #[code autoFocus] fires on every activation including mouse clicks, which can cause unwanted scrolling on mobile.

	+section("Labeling panels")
		p Every panel needs an accessible name so screen readers can announce what content is being shown.

		.card.api
			h3 aria-labelledby (recommended for tabs)
			p Links the panel to its tab button. The button’s text becomes the panel’s accessible name, which is announced when the panel is shown.

			+codeblock('HTML')
				button(role="tab" id="tab-overview" aria-controls="panel-overview") Overview
				+n
				div(role="tabpanel" id="panel-overview" aria-labelledby="tab-overview")
					// Content



		.card.api
			h3 aria-label (for panels without tabs)
			p Use for wizard steps, sub-panels, or any panel without a corresponding tab.

			+codeblock('HTML')
				div(role="tabpanel" id="step-2" aria-label="Step 2: Contact Information")
					// Content



append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}assets/scripts/example-accessibility.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			new PanelSet('#a11y-heading-demo', { autoFocus: 'heading' });
			new PanelSet('#a11y-first-demo', { autoFocus: 'first' });
			new PanelSet('#a11y-input-demo', { autoFocus: 'input' });
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module" src="/src/assets/scripts/example-accessibility.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			new PanelSet('#a11y-heading-demo', { autoFocus: 'heading' });
			new PanelSet('#a11y-first-demo', { autoFocus: 'first' });
			new PanelSet('#a11y-input-demo', { autoFocus: 'input' });
