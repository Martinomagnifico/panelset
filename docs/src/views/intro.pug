extends /views/templates/layouts/_base

append variables
	- pagetitle = "Intro"

block content
	.lane
		.container
			.page-header
				h1 PanelSet
				p.lead One panel or many. CSS animates.

	+section("What is it?")
		p It is a transition helper for panels that you want to show or hide.
		
		p The package exports three classes. Two main classes: #[strong Panel] and #[strong PanelSet] and a class #[strong PanelControl]. Both main classes animate a size between values using an #[a(href=url('/how-it-works.html#lmau')) LMAU]* cycle: 
		
		ul
			li Panel animates height or width
			li PanelSet animates height of a whole set of panels, showing one at a time
			li PanelControl is an addition to PanelSet that handles navigation for tabs

		p The two main classes use the same animation core and share most config options. Animation is CSS-only: JS measures and sets pixel values, then hands off to the browser. For async content, pass a promise to #[code onBeforeOpen()] to hold the open until it resolves. A spinner kicks in if loading takes longer than #[code loadingDelay]ms. Both also handle focus management.

		p * LMAU: Lock-Measure-Animate-Unlock #[span.small (I should trademark the term)].

		hr

		.grid-2
			.card
				+anchor(title="Panel")
				p A single element that can be #[strong opened and closed]. Use it for sidebars, show-more blocks, accordions, or any element that expands and collapses.
				p Triggers are any element with #[code aria-controls] pointing to the panel’s ID. Or a #[code button] with #[code data-panel-trigger] if it is a sibling of a panel, which sets up the #[code id] and ARIA for you.
				p You can add a close button that uses #[code data-panel-close].



			.card
				+anchor(title="PanelSet")
				p A container that #[strong switches between] some panels. Use it for tabs, wizards, or multi-step interfaces. Only one panel is (fully) visible at a time. Height transitions as well.
				p Triggers are any element with #[code aria-controls] pointing to an internal panel’s ID. 
				p It can also be opened and closed as a whole, just like a regular Panel.

				.card
					p Add #[strong PanelControl] for activation, keyboard navigation, roving tabindex, and state reflection.

		br
		.grid-2.gap-v-1
			div
				h3 Panel example
				.demo
					button(aria-controls="intro-panel") Toggle panel

					#intro-panel.is-open(data-panel)
						.panel-wrapper
							h3= example1Title
							+example-1-content

				a.btn.bottom.chevron.solid.block(href=url('/panel/index.html'))
					| Panel docs
					+chevron()



			div
				h3 PanelSet example
				.demo
					+exampletabset('intro-ps')
					+examplepanelset('intro-ps')

				a.btn.bottom.chevron.solid.block(href=url('/panelset/index.html'))
					| PanelSet docs
					+chevron()

			div.start-2
				a.btn.bottom.chevron.solid.block(href=url('/panelcontrol/index.html'))
					| PanelControl docs
					+chevron()



	+section("Features")
		.grid-3
			.card
				h3 CSS-driven animation
				p JS measures and sets a pixel value. After that, the browser animates. No JS animation loop.

			.card
				h3 Async content
				p Pass a promise to #[code onBeforeOpen()] and the panel waits. A spinner appears if loading takes longer than #[code loadingDelay] ms.

			.card
				h3 Interrupt-safe
				p Click again mid-animation and it reverses from exactly where it is. No jumping.

			.card
				h3 Accessible
				p #[code aria-expanded], #[code aria-controls], #[code aria-selected] (or #[code aria-current]) and #[code inert] are managed for you. Opt into #[code autoFocus] and #[code returnFocus] for focus handling.

			.card
				h3 Persist &amp; deep-link
				p #[code persist: true] saves the active panel to #[code localStorage] so it survives reloads. #[code deepLink: true] reflects it in the #[code ?panel=] URL for shareable links. And a #[code ?panel=] link is always honoured on load.

			.card
				h3 Reduced motion
				p Respects #[code prefers-reduced-motion]. Users who prefer less motion get instant state changes instead.


	+section("Setup")
		+installWizard('Panel, PanelSet and PanelControl', 'Panel, PanelSet, PanelControl')


	hr
	section.no-hr
		.container
			+anchor(title="Support this project")
			p PanelSet is free. If it saved you time, a coffee goes a long way.

			a.btn.solid.chevron.mobileblock(href="https://ko-fi.com/martinomagnifico" target="_blank" rel="noopener")
				+coffee()
				| Support my work on Ko-fi
				+chevron()




append styles
	style.
		.grid-2 > .start-2 { grid-column: 2; }
		@container (max-width: 600px) {
			.grid-2 > .start-2 { grid-column: auto; }
		}


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			new Panel('#intro-panel');
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init({ debug: true });
