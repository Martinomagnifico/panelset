extends /views/templates/layouts/_base

append variables
	- pagetitle = "Intro"

block content
	.lane
		.container
			.page-header
				h1 PanelSet
				p.lead One panel or many. CSS does the animating.

	+section("What is it?")
		p This package exports two classes: #[strong Panel] and #[strong PanelSet]. Both animate a dimension (height or width) between sizes using an #[a(href="/how-it-works.html#lmau") LMAU]* cycle.

		p Both classes use the same animation core and share most config options. Animation is CSS-only: JS measures and sets pixel values, then hands off to the browser. For async content, pass a promise to #[code onBeforeOpen()] to hold the open until it resolves. A spinner kicks in if loading takes longer than #[code loadingDelay]ms. Both also handle focus management.


		p * LMAU: Lock-Measure-Animate-Unlock #[span.small (I should trademark the term)].

		hr

		.grid-2
			.card
				+anchor(title="Panel")
				p A single element that can be #[strong opened and closed]. Use it for sidebars, show-more blocks, accordions, or any element that expands and collapses.
				p Triggers are any element with #[code aria-controls] pointing to the panel's ID. 
				p You can add a close button that uses #[code data-panel-close].



			.card
				+anchor(title="PanelSet")
				p A container that #[strong switches between] some panels. Use it for tabs, wizards, or multi-step interfaces. Only one panel is (fully) visible at a time. Height transitions as well.
				p Triggers are any element with #[code aria-controls] pointing to an internal panel's ID. 
				p It can also be opened and closed as a whole, just like a regular Panel.


			div
				h3 Panel example
				.demo
					button(aria-controls="intro-panel") Toggle panel

					#intro-panel.is-open(data-panel data-panel-axis="vertical")
						.panel-wrapper
							h3= example1Title
							+example-1-content

				a.btn.bottom.chevron.solid.block(href="/panel/getting-started.html")
					| Panel docs
					+chevron()



			div
				h3 PanelSet example
				.demo
					+exampletabset('intro-ps')
					+examplepanelset('intro-ps')

				a.btn.bottom.chevron.solid.block(href="/panelset/getting-started.html")
					| PanelSet docs
					+chevron()


	+section("Features")
		.grid-3
			.card
				h4 CSS-driven animation
				p JS measures and sets a pixel value. After that, the browser animates. No JS animation loop.

			.card
				h4 Async content
				p Pass a promise to #[code onBeforeOpen()] and the panel waits. A spinner appears if loading takes longer than #[code loadingDelay] ms.

			.card
				h4 Interrupt-safe
				p Click again mid-animation and it reverses from exactly where it is. No jumping.

			.card
				h4 Accessible
				p #[code aria-expanded], #[code aria-controls], #[code aria-selected], #[code inert]. These are all handled. Add keyboard navigation, #[code autoFocus] and #[code returnFocus] as needed.

			.card
				h4 Persist &amp; deep-link
				p Add #[code persist: true] and the active panel survives reloads. State goes into #[code localStorage] and the #[code ?panel=] URL parameter.

			.card
				h4 Reduced motion
				p Respects #[code prefers-reduced-motion]. Users who prefer less motion get instant state changes instead.


	+section("Installation")
		h3 Using NPM and imports

		.code-block
			.code-header Terminal
			pre
				code npm install panelset

		+codeblock('JS').
			import { Panel, PanelSet } from 'panelset';
			import 'panelset/style.css';

		h3 Using the normal JS and CSS files
		p Download the latest CSS and JS files from the #[a(href="https://github.com/your-repo/panelset") GitHub repository]. Import it like this:

		+codeblock('HTML')
			link(rel="stylesheet" href="path/to/panelset.css")
			script(src="path/to/panelset.js")
	.container
		.demo
			.popout-wrapper
				button(aria-controls="test-popout-panel") Toggle dropdown
				div(data-panel, id="test-popout-panel")
					.panel-wrapper
						p There is some dropdown content here. We give it a maximum width.

	hr
	section.no-hr
		.container
			+anchor(title="Support this project")
			p PanelSet is free. If it saved you time, a coffee goes a long way.

			a.btn.solid.chevron(href="https://ko-fi.com/martinomagnifico" target="_blank" rel="noopener")
				+coffee()
				| Support my work on Ko-fi
				+chevron()


append styles
	style.

		.popout-wrapper {
			position: relative;
			width: max-content;
		}

		#test-popout-panel .panel-wrapper {
			padding: 1rem;
			flex-shrink: 0;
			width: 220px;
		}

		#test-popout-panel {

			--ps-open-timing:    cubic-bezier(0.34, 1.56, 0.64, 1);
			--ps-close-timing:   cubic-bezier(0.36, 0, 0.66, -0.56);

			--ps-open-transition-extra: box-shadow var(--ps-open-speed) var(--ps-open-timing), width var(--ps-open-speed) var(--ps-open-timing), opacity var(--ps-open-speed) var(--ps-open-timing);
			--ps-close-transition-extra: box-shadow var(--ps-close-speed) var(--ps-close-timing), width var(--ps-close-speed) var(--ps-close-timing), opacity var(--ps-close-speed) var(--ps-close-timing);

			width: 100%;
			right: 0;
			position: absolute;
			border-radius: 8px;
			background: white;
			z-index: 10;
			box-shadow: inset 0 0 0 0px var(--special-normal), 0 0 0 var(--special-shadow-dark);
			opacity: 0.5;
			display: flex;
			justify-content: flex-end;
			align-items: flex-start;



		}

		#test-popout-panel.is-opening,
		#test-popout-panel.is-open {
			box-shadow: inset 0 0 0 2px var(--special-normal), 0 8px 20px var(--special-shadow-dark);
			width: 220px;
			opacity: 1;
		}
		



append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			new Panel('#intro-panel');
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init({ debug: true });
			//-new Panel('#intro-panel', { debug: true });
