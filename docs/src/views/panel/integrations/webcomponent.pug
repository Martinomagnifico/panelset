extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel: Web Component"

block content
	.lane
		.container
			.page-header
				h1 Web Component
				p.lead Use Panel as a native HTML element.

	+section("Getting started")
		p #[code &lt;ps-panel&gt;] is a custom element that wraps Panel. Everything works the same: events, async content, grouped accordions, #[code persist], all of it. The only differences are how you register it and how you write attributes.

		.title-text
			h3 IIFE (no build step)
			p Include the bundled script. #[code register()] is called automatically with the default #[code ps] prefix. No extra setup needed.

		+codeblock('HTML')
			script(src="panelset.js")
			+n
			// <ps-panel> is ready immediately after the script loads
			ps-panel(id="my-panel" panel-axis="vertical")
				.panel-wrapper ...


		.title-text
			h3 Module: import and done
			p Just import this path and both elements are registered. Nothing to call.

		+codeblock('JS').
			import 'panelset/register';
			// <ps-panel> and <ps-panelset> are now registered

		.title-text
			h3 Module: explicit call
			p Call #[code register()] yourself when you need control over timing or the prefix.

		+codeblock('JS').
			import { register } from 'panelset';
			register(); // registers <ps-panel> and <ps-panelset>

	+section("Basic example")
		p A show-more panel using #[code &lt;ps-panel&gt;] with plain attributes. The attribute names match the data attributes but without the #[code data-] prefix: #[code data-panel-axis] becomes #[code panel-axis].

		.card
			.demo
				button(aria-controls="wc-panel-demo" aria-expanded="false") Show more
				ps-panel#wc-panel-demo
					.panel-wrapper
						p Additional content that was hidden. The panel animates to its natural height, exactly as with #[code data-panel].


			+codeblock('HTML')
				button(aria-controls="wc-panel-demo" aria-expanded="false") Show more
				+n
				ps-panel#wc-panel-demo
					.panel-wrapper
						p Hidden content.

			p Panel auto-wires the trigger via #[code aria-controls], so no click handler is needed.

		p It can even be simplified further: the #[code aria-expanded] attribute is optional, because Panel will add it on its own. The same goes for the panel-wrapper. Panel adds it. And if we add #[code data-panel-trigger] to the button, we can skip the id too (when a trigger and its panel sit next to each other in the markup, see #[a(href="/panel/configuration.html#implicit-wiring") implicit wiring]). This is all optional, but it’s nice that the web component can handle it for you.

		.card
			.demo
				button(data-panel-trigger) Show more
				ps-panel
					p Additional content that was hidden. The panel animates to its natural height, exactly as with #[code data-panel].


			+codeblock('HTML')
				button(data-panel-trigger) Show more
				+n
				ps-panel
					p Hidden content.





	+section("Trigger wiring")
		p Panel auto-binds all #[code [aria-controls]&thinsp;] triggers on init. If you need to reach the Panel instance from your own JavaScript, use #[code closest('ps-panel')] instead of #[code closest('&#91;data-panel&#93;')].

		+codeblock('JS').
			// Accessing the Panel instance from custom JS:
			document.addEventListener('click', event => {
				const el = event.target.closest('ps-panel');
				if (!el?.panel) return;
				el.panel.toggle(event);
			});


	+section("Custom prefix")
		p Pass a string to #[code register()] to use a custom element name prefix. The default is #[code ps].

		+codeblock('JS').
			import { register } from 'panelset';

			register();         // <ps-panel>, <ps-panelset>
			register('solar'); // <solar-panel>, <solar-panelset>

		p It is safe to call #[code register()] multiple times. It skips any name that is already defined.

append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
	else
		script(type="module").
			import { register } from 'panelset';
			register();
