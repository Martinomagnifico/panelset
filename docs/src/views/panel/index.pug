extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel | Getting started"

mixin installWizard(cls)
	- const named = `{ ${cls} }`
	- const init = `${cls}.init();`
	- const cdnBase = 'https://cdn.jsdelivr.net/npm/panelset/dist'
	- const ghReleases = 'https://github.com/Martinomagnifico/panelset/releases'
	- const pfx = `iw-${cls.toLowerCase()}`

	.card.no-padding.install-wizard.border
		nav(role="tablist").tabs
			button(role="tab" aria-controls=`${pfx}-download`) Download
			button(role="tab" aria-controls=`${pfx}-npm`) npm
			button(role="tab" aria-controls=`${pfx}-cdn`) CDN


		.card-content(data-panelset)
			.panel-wrapper

				div(role="tabpanel" id=`${pfx}-download` class="active")
					.column.gap-1
						h3 Install with downloaded files
						p Download the files from the #[a(href=ghReleases) releases page].
						p How do you intend to use it?
						.demo-controls
							button.is-active(data-choice="type" aria-pressed="true") Module
							button(data-choice="type" aria-pressed="false") Script tag
						.install-option
							p Get #[code panelset.esm.js] and #[code panelset.css], then:
							+codeblock('HTML').
								<link rel="stylesheet" href="./panelset.css">
								<script type="module">
									import #{named} from './panelset.esm.js';
									#{init}
								</script>
						.install-option(hidden)
							p Get #[code panelset.js] and #[code panelset.css], then:
							+codeblock('HTML').
								<link rel="stylesheet" href="./panelset.css">
								<script src="./panelset.js"></script>
								<script>#{init}</script>



				div(role="tabpanel" id=`${pfx}-npm` hidden)
					.column.gap-1
						h3 Install with npm
						+codeblock('bash', 'Terminal').
							npm install panelset
						p How do you intend to use it?
						.demo-controls
							button.is-active(data-choice="type" aria-pressed="true") Module
							button(data-choice="type" aria-pressed="false") Script tag
						.install-option
							+codeblock('JS').
								import #{named} from 'panelset';
								import 'panelset/style.css';
								#{init}

						.install-option(hidden)
							p Copy #[code node_modules/panelset/dist/panelset.js] and #[code panelset.css] to your project, then:
							+codeblock('HTML').
								<link rel="stylesheet" href="./panelset.css">
								<script src="./panelset.js"></script>
								<script>#{init}</script>

				div(role="tabpanel" id=`${pfx}-cdn` hidden)
					.column.gap-1
						h3 Install with a CDN
						p Link to the files on a CDN like #[a(href=ghReleases) jsDelivr]. Use the #[code .esm.js] version for native module support, or #[code .js] for a classic script tag.
							br
							small Note: the module version is recommended for better tree-shaking and performance.

						+codeblock('HTML').
							<link rel="stylesheet" href="#{cdnBase}/panelset.css">
						//

						p How do you intend to use it?
						.demo-controls
							button.is-active(data-choice="type" aria-pressed="true") Module
							button(data-choice="type" aria-pressed="false") Script tag
						.install-option
							+codeblock('HTML').
								<link rel="stylesheet" href="#{cdnBase}/panelset.css">
								<script type="module">
									import #{named} from '#{cdnBase}/panelset.esm.js';
									#{init}
								</script>
						.install-option(hidden)
							+codeblock('HTML').
								<link rel="stylesheet" href="#{cdnBase}/panelset.css">
								<script src="#{cdnBase}/panelset.js"></script>
								<script>#{init}</script>


block content
	.lane
		.container
			.page-header
				h1 Panel
				p.lead A single element that opens and closes with a smooth transition.

	+section("What Panel does")
		p #[code Panel] controls one element: it can be opened, closed, or toggled. The element animates its #[strong height] (vertical axis) or #[strong width] (horizontal axis) between 0 and its natural size.

		p Typical uses: show-more blocks, accordions, sidebars, drawers.

		.callout
			+warning()
			p #[strong Not the same as PanelSet.] #[code Panel] opens and closes a single element. #[code PanelSet] switches between several. See the #[a(href="/intro.html") Intro] for the distinction.


	+section("Setup")
		+installWizard('Panel')

	+section("Installation")
		.code-block
			.code-header Terminal
			pre
				code npm install panelset

		+codeblock('JS').
			import { Panel } from 'panelset';
			import 'panelset/style.css';

	+section("Markup")
		p Add #[code data-panel] to your element and give it an #[code id]. Panels start closed by default (no class required). Wrap the content in #[code .panel-wrapper].

		.card
			.demo
				button(aria-controls="markup-example") Toggle panel
				#markup-example(data-panel)
					.panel-wrapper
						h3= example1Title
						+example-1-content

			+codeblock('HTML')
				// Trigger: any element with aria-controls pointing to the panel id
				button(aria-controls="markup-example") Toggle
				+n
				// Panel element
				#markup-example(data-panel)
					.panel-wrapper
						p Panel content goes here.





		p #[code aria-expanded] is managed automatically. Panel sets it to #[code true] or #[code false] on every open and close.

	+section("Starting state")
		p A Panel is closed by default. To start it #[strong open], add the #[code is-open] class to the panel element in your markup. That’s all. Panel reads it on init, removes #[code inert], and syncs the trigger’s #[code aria-expanded] to match. No animation runs for the initial state.
		.card
			.demo
				button(aria-controls="starting-example") Toggle panel
				#starting-example.is-open(data-panel)
					.panel-wrapper
						h3= example1Title
						+example-1-content

			+codeblock('HTML')
				button(aria-controls="starting-example") Toggle
				+n
				#starting-example.is-open(data-panel)
					.panel-wrapper
						p Visible on load.


		p If you use #[code persist] or #[code deepLink], a stored open/closed state takes precedence over the markup on return visits.

	+section("Initializing")
		p Use the static #[code init()] method to initialize all matching elements at once, or create instances directly.

		+codeblock('JS').
			// Initialize all [data-panel] elements
			Panel.init();

			// With options
			Panel.init({ debug: true });

			// Custom selector
			Panel.init('[data-panel]', { transitions: false });

			// Single instance
			const panel = new Panel('#my-panel', { axis: 'vertical' });

			// Single instance by element reference
			const el = document.getElementById('my-panel');
			const panel = new Panel(el, { autoFocus: 'first' });

	+section("Triggers and close buttons", "Triggers")
		p Any element with #[code aria-controls="&lt;panel id here&gt;"] auto-binds a click handler on init. No extra JS needed. Add #[code data-panel-close] inside the panel for a close button.

		+codeblock('HTML')
			button(aria-controls="my-panel" aria-expanded="false") Open
			+n
			#my-panel(data-panel)
				.panel-wrapper(role="dialog" aria-label="Options")
					button(data-panel-close) Close
					p Sidebar content.

		p When a trigger and panel are adjacent siblings, you can skip the #[code id] / #[code aria-controls] pair entirely. Use #[code data-panel-trigger] on the button and Panel will generate and set up the ID automatically.

		+codeblock('HTML')
			button(data-panel-trigger) Toggle
			+n
			div(data-panel)
				.panel-wrapper Content


	+section("Public API", "API")
		+codeblock('JS').
			const panel = new Panel('#my-panel');

			panel.open();    // open
			panel.close();   // close
			panel.toggle();  // toggle open/closed

			panel.isOpen;    // boolean (true if open or opening)

	+section("Async content")
		p Attach a handler to delay opening until content is ready. If loading takes longer than #[code loadingDelay]ms, a spinner appears.

		+codeblock('JS').
			const panel = new Panel('#my-panel');

			panel.onBeforeOpen(async (el, signal) => {
				const res = await fetch('/api/content', { signal });
				el.querySelector('.panel-wrapper').innerHTML = await res.text();
			}, { once: true }); // load once, cache forever


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			Panel.init('[data-panel]');
			PanelSet.init('.install-wizard [data-panelset]');
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { Panel, PanelSet } from 'panelset';
			//- Panel.init('[data-panel]', { debug: true });
			//- PanelSet.init('.install-wizard [data-panelset]');
			Panel.init();
			PanelSet.init();



	script.
		document.querySelectorAll('.install-wizard').forEach(function(wizard) {
			wizard.querySelectorAll('[data-choice]').forEach(function(btn) {
				btn.addEventListener('click', function() {
					var tab = btn.closest('[role="tabpanel"]');
					var btns = tab.querySelectorAll('[data-choice]');
					var opts = tab.querySelectorAll('.install-option');
					var idx = Array.from(btns).indexOf(btn);

					btns.forEach(function(b, i) {
						b.classList.toggle('is-active', i === idx);
						b.setAttribute('aria-pressed', i === idx ? 'true' : 'false');
					});
					opts.forEach(function(opt, i) {
						opt.hidden = i !== idx;
					});
				});
			});
		});
