extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel | Transitions"

block content
	.lane
		.container
			.page-header
				h1 Panel transitions
				p.lead Panel uses only CSS transitions.




	+section("Transitionable elements")

		p A Panel has two transitionable parts: the #[strong container] that animates its size open and closed, and the inner #[strong wrapper] that holds your content and fades (or transforms) in.


		svg.img-transitions(xmlns='http://www.w3.org/2000/svg' width='340' height='340' fill='none' viewbox='0 0 340 340')
			rect.sw-2.wrap(width='180' height='160' x='80' y='141' stroke-dasharray='8 8' rx='8')

			rect.sw-3.cont(stroke-dasharray='8 8' x='65' y='126' width='210' height='190' rx='16')
			rect.sw-4.cont(x='65' y='126' width='210' height='138' rx='16')

			path.sw-2.anim-indicator(d='M41 264v52M49 272l-8-8-8 8M33 308l8 8 8-8')

			path.sw-3.indicator(d='M65 217H31V26')
			circle.indicator(cx='65' cy='217' r='6')
			path.sw-3.indicator(d='M170 217h146V109')
			circle.indicator(cx='170' cy='217' r='6')
			path.sw-3.indicator(d='M170 141V52')
			circle.indicator(cx='170' cy='141' r='6')

			text: tspan(x='0' y='15.892') 1. Container (data-panel)
			text: tspan(x='80.359' y='43.892') 2. Wrapper (.panel-wrapper)
			text: tspan(x='261.672' y='98.892') Content



	+section("1. Container")

		p The container is the #[code [data-panel]] box. It animates between #[code 0] and the content’s natural size: height by default, or width on the horizontal axis..

		.column.gap-1(data-panel-group data-panel-close-siblings data-panel-persist)

			+collapse('h3', "Transitioning opening &amp; closing")

				p These control the container’s size animation as the panel opens and closes.

				dl.bg-surface-tint-contrast
					dt #[code --ps-open-speed]
					dd Size transition duration when opening. Default: #[code 0.25s].

					dt #[code --ps-open-timing]
					dd Easing when opening. Default: #[code ease-in-out].

					dt #[code --ps-close-speed]
					dd Size transition duration when closing. Default: #[code 0.25s].

					dt #[code --ps-close-timing]
					dd Easing when closing. Default: #[code ease-in-out].

				h4 Demo
				p Both speeds are set to 1 second, so you can see the two halves separately: the container grows while the content fades in, and the content fades out while the container collapses.

				.demo
					button(aria-controls="panel-slow-demo" aria-expanded="false") Toggle panel
					div#panel-slow-demo(data-panel)
						.panel-wrapper
							h3= example1Title
							+example-1-content

				+codeblock('CSS').
					#my-panel {
						--ps-open-speed:   0.25s;
						--ps-open-timing:  ease-in-out;
						--ps-close-speed:  0.25s;
						--ps-close-timing: ease-in-out;
					}

			+collapse('h3', "Transitioning extra transitions")

				p Use #[code --ps-open-transition-extra] and #[code --ps-close-transition-extra] to animate extra CSS properties alongside the size, say a border or a shadow. The value is tacked onto the transition shorthand as-is, so write it in the same shape: #[code property duration timing-function].

				p A common use is #[code box-shadow], including an #[code inset] box-shadow as a border, because it has no effect on layout, it never interferes with the size measurement.

				dl.bg-surface-tint-contrast
					dt #[code --ps-open-transition-extra]
					dd Extra #[code transition] shorthand values appended when opening. Unset by default.

					dt #[code --ps-close-transition-extra]
					dd Same, applied when closing.

				h4 Demo
				.demo
					button(aria-controls="panel-extra-demo" aria-expanded="false") Toggle panel
					div#panel-extra-demo(data-panel)
						.panel-wrapper
							h3= example1Title
							+example-1-content

				+codeblock('CSS').
					#my-panel {
						--ps-open-transition-extra:  box-shadow var(--ps-open-speed) ease-in;
						--ps-close-transition-extra: box-shadow var(--ps-close-speed) ease-out;
						box-shadow: inset 0 0 0 6px yellow, 0 0 0 rgba(0,0,0,0.2);
					}

					#my-panel.is-open,
					#my-panel.is-opening {
						box-shadow: inset 0 0 0 6px green, 0 0 1rem rgba(0,0,0,0.2);
					}


	+section("2. Wrapper")

		p The wrapper is the #[code .panel-wrapper] that holds your content. It fades in as the container opens (and out as it closes), and can slide in on top of that.

		.column.gap-1(data-panel-group data-panel-close-siblings data-panel-persist)

			+collapse('h3', "The fade")

				p By default the wrapper fades from #[code 0] to full opacity as the panel opens. Set #[code --ps-closed-opacity] to #[code 1] to keep the content fully visible while the container grows and shrinks, so only the size animates and there is no fade.

				dl.bg-surface-tint-contrast
					dt #[code --ps-closed-opacity]
					dd Opacity of #[code .panel-wrapper] when closed or closing. Default: #[code 0] (fades out). Set to #[code 1] to disable the inner fade.

				h4 Demo
				p This panel keeps its content at full opacity. Only the container height animates, with no fade-in.

				.demo
					button(aria-controls="panel-nofade-demo" aria-expanded="false") Toggle panel
					div#panel-nofade-demo(data-panel)
						.panel-wrapper
							h3= example1Title
							+example-1-content

				+codeblock('CSS').
					#my-panel {
						--ps-closed-opacity: 1;
					}

			+collapse('h3', "The transform")

				p Set #[code --ps-wrapper-transform-from] to move the wrapper as it appears. It animates from that transform to #[code none] on open, and back on close, sharing the #[code --ps-open-] / #[code --ps-close-] timing. The default #[code none] is a plain fade. It is also the lever for keeping animated SVG icons smooth on iPhone (see the note below).

				p The open and close transitions can have their own delays, both #[code 0s] by default. Use #[code --ps-wrapper-open-delay] to hold the content back until the box has grown a little, and #[code --ps-wrapper-close-delay] to let it linger before everything collapses.

				dl.bg-surface-tint-contrast
					dt #[code --ps-wrapper-transform-from]
					dd Transform the wrapper reveals from, settling at #[code none]; reverses on close. Any transform. Default: #[code none].

						.callout 
							+warning
							p #[strong On iOS]: if a trigger has an SVG icon that animates (like a rotating chevron), then the open and close can stutter. That’s not nice. The offending browser (maybe a ‘standard browser’) tries to redraw the SVG on every frame of the rotation, and that competes with the height animation. Giving the wrapper a transform fixes it: even an almost invisible #[code --ps-wrapper-transform-from: translateY(-0.5px);] lets the panel composite on the GPU and stay smooth. The layer is only GPU-promoted while it animates. (It is exactly what the accordion and card examples here do.)



					dt #[code --ps-wrapper-open-delay]
					dd Delay before the wrapper reveals when opening. Default: #[code 0s]. (Legacy alias: #[code --ps-wrapper-delay].)

					dt #[code --ps-wrapper-close-delay]
					dd Delay before the wrapper starts leaving when closing. Default: #[code 0s].



				h4 Demo
				.demo
					button(aria-controls="panel-wrapper-demo" aria-expanded="false") Toggle panel
					div#panel-wrapper-demo(data-panel)
						.panel-wrapper
							h3= example1Title
							+example-1-content

				+codeblock('CSS').
					#my-panel {
						--ps-wrapper-transform-from: translateY(-1rem);
						--ps-wrapper-open-delay: 0.1s;
					}


	+section("Disabling transitions", "Disabling")
		p Pass #[code transitions: false] (or #[code data-panel-transitions="false"]) to skip the animation entirely. Useful for the first paint on page load.

		+codeblock('JavaScript').
			new Panel('#my-panel', { transitions: false });

		p anel also honours #[code prefers-reduced-motion] on its own: when a user has asked for reduced motion, the CSS drops every transition.


append styles
	style.
		#panel-slow-demo {
			--ps-open-speed:  1s;
			--ps-close-speed: 1s;
		}
		#panel-nofade-demo {
			--ps-closed-opacity: 1;
		}
		#panel-extra-demo {
			--ps-open-transition-extra:  box-shadow var(--ps-open-speed) ease-in;
			--ps-close-transition-extra: box-shadow var(--ps-close-speed) ease-out;

			background: var(--demo-btn-bg);
			border-radius: 0.5rem;
			box-shadow: inset 0 0 0 6px yellow, 0 0 0 rgba(0, 0, 0, 0.2);
		}
		#panel-extra-demo.is-open,
		#panel-extra-demo.is-opening {
			box-shadow: inset 0 0 0 6px green, 0 0 1rem rgba(0, 0, 0, 0.2);
		}
		#panel-wrapper-demo {
			--ps-open-speed:  0.5s;
			--ps-close-speed: 0.5s;
			--ps-wrapper-transform-from: translateY(-1rem);
			--ps-wrapper-open-delay: 0.1s;
		}
		#panel-extra-demo > .panel-wrapper {
			padding: var(--standard-padding);
		}


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			Panel.init('[data-panel]');
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { Panel } from 'panelset';
			Panel.init('[data-panel]', { debug: true });
