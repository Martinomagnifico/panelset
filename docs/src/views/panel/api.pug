extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel | API"

block content
	.lane
		.container
			.page-header
				h1 Panel API
				p.lead Constructor, instance methods, properties, and static methods.

	+section("Constructor")
		.indented
			h3.code new Panel(elementOrSelector: HTMLElement | string, options?: PanelConfig)
			hr
			p Creates a new Panel instance.
			h4 Parameters:
			dl
				dt.code elementOrSelector
				dd A CSS selector string or HTMLElement reference to the #[code [data-panel]] element.
				dt.code options (optional)
				dd A configuration object. See #[a(href="/panel/configuration.html") Panel - Configuration] for all options.

			+codeblock('JavaScript').
				const panel = new Panel('#my-panel');
				const panel = new Panel('#my-panel', { axis: 'horizontal' });
				const panel = new Panel(document.getElementById('my-panel'));

	+section("Instance methods")
		.indented
			h3.code panel.open(event?): Promise&lt;void&gt;
			hr
			p Opens the panel. Nothing happens if it is already open.
			h4 Parameters:
			dl
				dt.code event (optional)
				dd The triggering event. When passed, #[code autoFocus] only fires on keyboard events. Mouse clicks are ignored, preventing unwanted scroll.
			h4 Returns:
			p A promise that resolves when the opening transition completes.

		.indented
			h3.code panel.close(): void
			hr
			p Closes the panel. Nothing happens if it is already closed.

		.indented
			h3.code panel.toggle(event?): void
			hr
			p Opens the panel if closed, closes it if open. Reverses a mid-animation close if called while closing.
			h4 Parameters:
			dl
				dt.code event (optional)
				dd The triggering event. Used for keyboard detection.

		.indented
			h3.code panel.onBeforeOpen(handler, options?): void
			hr
			p Registers a handler for async content loading before the panel opens. The handler runs before every open unless #[code once: true] is set.
			h4 Parameters:
			dl
				dt.code handler
				dd #[code (el: HTMLElement, signal: AbortSignal) => Promise&lt;void&gt; | void]: Return a promise to delay opening.
				dt.code options (optional)
				dd #[code { once?: boolean }]: If #[code true], the handler is skipped after the first successful load (#[code dataset.loaded === 'true']).

			+codeblock('JavaScript').
				panel.onBeforeOpen(async (el, signal) => {
					const html = await fetch('/api/content', { signal }).then(r => r.text());
					el.querySelector('.panel-wrapper').innerHTML = html;
				}, { once: true });

			p You can also define the handler as a named function. This keeps it clean and lets you share the same function across multiple panels.

			+codeblock('JavaScript').
				async function loadContent(el, signal) {
					const html = await fetch('/api/content', { signal }).then(r => r.text());
					el.querySelector('.panel-wrapper').innerHTML = html;
				}

				panel.onBeforeOpen(loadContent, { once: true });

		.indented
			// TODO, DOES THIS EXIST?
			h3.code panel.destroy(): void
			hr
			p Tears down the instance: aborts any in-progress animation, removes all event listeners, resets the element to closed state, and clears the #[code element.panel] reference so the element can be re-initialised.

	+section("Instance properties")
		.indented
			h3.code panel.isOpen: boolean
			hr
			p #[strong Read-only.] #[code true] if the panel is open or mid-open-animation.

		.indented
			h3.code panel.element: HTMLElement
			hr
			p #[strong Read-only.] The #[code [data-panel]] DOM element.

		.indented
			h3.code panel.config: PanelConfig
			hr
			p #[strong Read-only.] The merged configuration object (1. data attributes, 2. constructor options, 3. defaults ).

	+section("Static methods")
		.indented
			h3.code Panel.init(selectorOrOptions?, options?): Panel[]
			hr
			p Auto-initialises all panels matching the selector. Also connects #[code [data-panel-trigger]] / #[code [data-panel]] implicit pairs.
			h4 Parameters:
			dl
				dt.code selectorOrOptions (optional)
				dd CSS selector string, or a config object (uses #[code '[data-panel]'] selector).
				dt.code options (optional)
				dd Config object, only used when the first argument is a selector string.
			h4 Returns:
			p An array of created Panel instances.

			+codeblock('JavaScript').
				Panel.init();
				Panel.init({ debug: true });
				Panel.init('[data-panel]', { axis: 'vertical' });

		.indented
			h3.code Panel.defaults: PanelConfig
			hr
			p #[strong Static property.] Default configuration applied to all new instances. Modify to change defaults globally.

			+codeblock('JavaScript').
				Panel.defaults.axis = 'vertical';
				Panel.defaults.debug = true;

	+section("TypeScript types")
		+codeblock('JavaScript').
			import {
				Panel,
				type PanelConfig,
				type PanelBeforeOpenEventDetail,
				type PanelEventDetail,
				type AsyncOpenHandler,
			} from 'panelset';

			const panel = new Panel('#my-panel');

			panel.element.addEventListener('panel:opened', e => {
				const event = e as CustomEvent<PanelEventDetail>;
				console.log(event.detail.trigger);
			});

			const config: PanelConfig = {
				axis: 'horizontal',
				transitions: true,
				autoFocus: 'first',
				returnFocus: true,
				persist: true,
			};

			const panel = new Panel('#my-panel', config);


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
	else
		script(type="module").
			import { Panel } from 'panelset';
			Panel.init({ debug: true });
