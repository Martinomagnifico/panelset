extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel | API"

block content
	.lane
		.container
			.page-header
				h1 Panel API
				p.lead Everything you can call on a Panel.

	+section("Constructor")
		.indented
			h3.code new Panel(elementOrSelector: HTMLElement | string, options?: PanelConfig)
			hr
			p Builds a Panel on a single element, from a selector or an element reference. Reach for this when you want a handle on one panel. To wire up many at once, #[code Panel.init()] (further down) is less typing.

			h4 Parameters:
			dl
				dt.code elementOrSelector
				dd A CSS selector string or HTMLElement reference to the #[code [data-panel]] element.
				dt.code options (optional)
				dd A configuration object. See #[a(href=url('/panel/configuration.html')) Panel - Configuration] for all options.

			+codeblock('JavaScript').
				const panel = new Panel('#my-panel');
				const panel = new Panel('#my-panel', { axis: 'horizontal' });
				const panel = new Panel(document.getElementById('my-panel'));

	+section("Instance methods")
		.indented
			h3.code panel.open(event?): Promise&lt;void&gt;
			hr
			p OOpen the panel. Nothing happens if it is already open.
			h4 Parameters:
			dl
				dt.code event (optional)
				dd The triggering event. When passed, #[code autoFocus] only fires on keyboard events. Mouse clicks are ignored, preventing unwanted scroll.
			h4 Returns:
			p A promise that resolves once the opening transition has finished.

		.indented
			h3.code panel.close(): void
			hr
			p Close the panel. Nothing happens if it is already closed.

		.indented
			h3.code panel.toggle(event?): void
			hr
			p Open the panel if it is closed, close it if it is open. If you catch it mid-close, toggle reverses and opens it again.
			h4 Parameters:
			dl
				dt.code event (optional)
				dd The triggering event. Used for keyboard detection.

		.indented
			h3.code panel.onBeforeOpen(handler, options?): void
			hr
			p Register a handler that runs just before the panel opens, which is where content loading goes. Return a promise from it and the open waits for that promise to settle. It runs before every open unless you pass #[code once: true].

			h4 Parameters:
			dl
				dt.code handler
				dd #[code (el: HTMLElement, signal: AbortSignal) => Promise&lt;void&gt; | void]: Return a promise to delay opening.
				dt.code options (optional)
				dd #[code { once?: boolean }]: If #[code true], the handler is skipped after the first successful load (#[code dataset.loaded === 'true']).

			+codeblock('JavaScript').
				panel.onBeforeOpen(async (el, signal) => {
					const html = await fetch('/api/content', { signal }).then(r => r.text());
					el.querySelector('.panel-wrapper').innerHTML = html;
				}, { once: true });

			p You can pass a named function instead of an inline one. It keeps the call site tidy, and it lets you reuse the same loader across several panels.

			+codeblock('JavaScript').
				async function loadContent(el, signal) {
					const html = await fetch('/api/content', { signal }).then(r => r.text());
					el.querySelector('.panel-wrapper').innerHTML = html;
				}

				panel.onBeforeOpen(loadContent, { once: true });

		.indented
			h3.code panel.destroy(): void
			hr
			p Destroy it. It aborts any animation in progress, removes its event listeners, resets the element to its closed state, and clears the #[code element.panel] reference so the element can be initialised again.

	+section("Instance properties")
		.indented
			h3.code panel.isOpen: boolean
			hr
			p #[strong Read-only.] #[code true] while the panel is open, or part-way through opening.

		.indented
			h3.code panel.element: HTMLElement
			hr
			p #[strong Read-only.] The #[code [data-panel]] element itself.

		.indented
			h3.code panel.config: PanelConfig
			hr
			p #[strong Read-only.] The merged configuration. Precedence runs least specific to most: defaults first, then constructor options, then data attributes.

	+section("Static methods")
		.indented
			h3.code Panel.init(selectorOrOptions?, options?): Panel[]
			hr
			p Find every panel matching the selector and initialise the lot in one call. It also connects implicit #[code [data-panel-trigger]] / #[code [data-panel]] pairs that sit next to each other.

			h4 Parameters:
			dl
				dt.code selectorOrOptions (optional)
				dd CSS selector string, or a config object (uses #[code '[data-panel]'] selector).
				dt.code options (optional)
				dd Config object, only used when the first argument is a selector string.
			h4 Returns:
			p An array of the Panel instances it created.

			+codeblock('JavaScript').
				Panel.init();
				Panel.init({ debug: true });
				Panel.init('[data-panel]', { axis: 'vertical' });

		.indented
			h3.code Panel.defaults: PanelConfig
			hr
			p #[strong Static property.] The default config handed to every new instance. Change it here to move the defaults for the whole page at once.

			+codeblock('JavaScript').
				Panel.defaults.axis = 'vertical';
				Panel.defaults.debug = true;

	+section("TypeScript types")
		+codeblock('JavaScript').
			import {
				Panel,
				type PanelConfig,
				type PanelBeforeOpenEventDetail,
				type PanelEventDetail,
				type AsyncOpenHandler,
			} from 'panelset';

			const panel = new Panel('#my-panel');

			panel.element.addEventListener('panel:opened', e => {
				const event = e as CustomEvent<PanelEventDetail>;
				console.log(event.detail.trigger);
			});

			const config: PanelConfig = {
				axis: 'horizontal',
				transitions: true,
				autoFocus: 'first',
				returnFocus: true,
				persist: true,
			};

			const panel = new Panel('#my-panel', config);


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
	else
		script(type="module").
			import { Panel } from 'panelset';
			Panel.init({ debug: true });
