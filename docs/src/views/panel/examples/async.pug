extends /views/templates/layouts/_base

append variables
	- pagetitle = "Panel | Examples | Async panel"

block content
	.lane
		.container
			.page-header
				h1 Async panels
				p.lead Load panel content with promises, fetch, or heavy computation


	+section("Live demo")


		.card
			.demo
				button(aria-controls="async-panel-recipe" aria-expanded="false") Load recipe
				div#async-panel-recipe( data-panel data-panel-loading-delay="200")
					.panel-wrapper
						// content injected by JS

			+codeblock('JS').
				const panel = new Panel('#async-panel-recipe');

				panel.onBeforeOpen((el, signal) => {
					return slowFetch('https://dummyjson.com/recipes/1', { signal })
						.then(r => r.json())
						.then(data => {
							el.querySelector('.panel-wrapper').innerHTML = renderRecipe(data);
						});
				}, { once: true });

			p The panel below fetches a random recipe from a public API when opened. A simulated delay makes the spinner visible. With #[code { once: true }] the content is cached, so reopening the panel skips the fetch.


	+section("The onBeforeOpen() callback")

		.title-text
			p Use #[code onBeforeOpen()] to add async loading:

		+codeblock('JS').
			const panel = new Panel('#my-panel');

			panel.onBeforeOpen((el, signal) => {
				// Return a promise to delay opening
				return fetch(`/api/content`, { signal })
					.then(response => response.text())
					.then(html => {
						el.querySelector('.panel-wrapper').innerHTML = html;
					});
			}, { once: true }); // Load once, cache forever

		.card.api
			h3 Parameters
			dl
				dt el
				dd The panel #[code HTMLElement] being opened

				dt signal
				dd #[code AbortSignal] for cancelling the operation if the user closes the panel

				dt options.once
				dd #[code true] loads once and caches; #[code false] always reloads. Default: #[code false]


	+section("Using the event directly")
		p For more control, listen to #[code panel:beforeopen] on the element:

		+codeblock('JS').
			document.querySelector('#my-panel').addEventListener('panel:beforeopen', e => {
				// panel:beforeopen bubbles, so read the panel from e.target (the dispatching
				// panel). e.currentTarget breaks under event delegation; e.target does not.
				const panel = e.target;
				const { signal } = e.detail;

				if (panel.dataset.loaded === 'true') return; // skip if already loaded

				e.detail.waitUntil(
					fetch('/api/content', { signal })
						.then(r => r.text())
						.then(html => {
							panel.querySelector('.panel-wrapper').innerHTML = html;
							panel.dataset.loaded = 'true';
						})
				);
			});

		.card.api
			h3 Event detail properties
			dl
				dt signal
				dd #[code AbortSignal]: pass to #[code fetch()] so in-flight requests cancel when the user closes the panel before it opens.

				dt waitUntil(promise)
				dd #[strong Recommended.] Delay opening until #[code promise] resolves. Safe to call more than once: the open waits for all of them.

				dt promise
				dd #[code Promise | null]: the underlying property #[code waitUntil()] sets. You can still assign it directly, but #[code waitUntil()] is preferred. Leave as #[code null] to open immediately.

				dt trigger
				dd #[code HTMLElement | null]: the element that initiated the open (e.g. the button).


	+section("Heavy computation")
		p Works for CPU-heavy operations too, not just network requests. Two flavours:

		h3 Simulated slow load (demo only)
		p This one does no real work. It only simulates latency with a timer, so the spinner is easy to see. The signal cancels the timer if you close the panel first.

		.card
			.demo
				button(aria-controls="heavy-sim" aria-expanded="false") Simulate slow load
				#heavy-sim(data-panel data-panel-loading-delay="200")
					.panel-wrapper
						// content injected by JS

			+codeblock('JS').
				panel.onBeforeOpen((el, signal) => new Promise((resolve, reject) => {
					// Demo only: no real work happens here, the timer just simulates latency.
					const t = setTimeout(() => {
						el.querySelector('.panel-wrapper').innerHTML = '<h3>Done</h3><p>Simulated 2s load.</p>';
						resolve();
					}, 2000);
					signal.addEventListener('abort', () => {
						clearTimeout(t);
						reject(new DOMException('Aborted', 'AbortError'));
					});
				}), { once: true });

		h3 Genuine CPU-heavy work
		p Real heavy work has to leave the main thread. Doing it synchronously inside the promise would still freeze the UI (and the spinner); a Web Worker is what keeps the page responsive. The signal terminates the worker on close.

		.card
			.demo
				button(aria-controls="heavy-worker" aria-expanded="false") Compute fibonacci(42)
				#heavy-worker(data-panel data-panel-loading-delay="200")
					.panel-wrapper
						// content injected by JS

			+codeblock('JS').
				panel.onBeforeOpen((el, signal) => new Promise((resolve, reject) => {
					const worker = new Worker('/assets/scripts/fib-worker.js');
					worker.postMessage(42);
					worker.onmessage = (e) => {
						el.querySelector('.panel-wrapper').innerHTML =
							`<h3>Calculation complete</h3><p>fibonacci(42) = ${e.data}</p>`;
						worker.terminate();
						resolve();
					};
					signal.addEventListener('abort', () => {
						worker.terminate();
						reject(new DOMException('Aborted', 'AbortError'));
					});
				}), { once: false });

		p The worker file (#[code fib-worker.js]) does the calculation off the main thread:

		+codeblock('JS').
			// fib-worker.js
			onmessage = (e) => {
				const fib = (n) => (n <= 1 ? n : fib(n - 1) + fib(n - 2));
				postMessage(fib(e.data));
			};


	+section("Loading states")
		.title-text
			h3 Loading spinner
			p During async operations, Panel shows a spinner. It only appears if loading takes longer than #[code loadingDelay] ms. Fast loads open directly without a spinner:

		+codeblock('JS').
			const panel = new Panel('#my-panel', {
				loadingDelay: 320  // Wait 320ms before showing spinner
			});

		.title-text
			p Or via data attribute:

		+codeblock('HTML')
			div(data-panel data-panel-loading-delay="320") ...

		.title-text
			h3 Loading height
			p Reserve vertical space for the spinner while content loads:

		+codeblock('JS').
			const panel = new Panel('#my-panel', {
				loadingHeight: 200  // Example increase from default 150 during load
			});

		+codeblock('HTML')
			div(data-panel data-panel-loading-height="200") ...


	+section("Abort handling")
		p When the user closes the panel during loading, the operation is automatically cancelled via the AbortSignal:

		+codeblock('JS').
			panel.onBeforeOpen((el, signal) => {
				// Pass signal to fetch (automatically cancels on close)
				return fetch('/api/data', { signal })
					.then(/* ... */);
			});

		p If you need to detect the abort (e.g. to clean up state), check the signal directly:

		+codeblock('JS').
			panel.onBeforeOpen((el, signal) => {
				signal.addEventListener('abort', () => {
					console.log('Load cancelled');
				});

				return fetch('/api/data', { signal });
			});


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			Panel.init('.docs-content [data-panel]');
		script(src=`${basePath}assets/scripts/example-panel-async.js` vite-ignore)
	else
		script(type="module").
			import { Panel } from 'panelset';
			Panel.init('.docs-content [data-panel]');
		script(type="module" src="/src/assets/scripts/example-panel-async.js")
