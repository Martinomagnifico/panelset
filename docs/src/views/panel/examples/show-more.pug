extends /views/templates/layouts/_base

append variables
	- pagetitle = "Show more"

block content
	.lane
		.container
			.page-header
				h1 Show more
				p.lead A vertical panel that expands to reveal hidden content.

	.lane
		.container
			p The simplest use of #[code Panel]: a block of text with a "Show more" button that reveals additional content below. The panel starts closed (#[code class="is-closed"]) and expands vertically when triggered.

			.card
				.demo
					article.show-more-article
						p This is some introductory text.
						button(aria-controls="docs-show-more" aria-expanded="false") Show more
						div#docs-show-more(data-panel data-panel-axis="vertical" class="is-closed")
							.panel-wrapper
								p Additional content that was hidden. It can be as long as needed — the panel animates to its natural height. If we make this text long, it might wrap to multiple lines.

			+codeblock('HTML').
				<article>
				  <p>This is some introductory text.</p>
				  <button aria-controls="my-panel" aria-expanded="false">Show more</button>

				  <div id="my-panel" data-panel data-panel-axis="vertical" class="is-closed">
				    <div class="panel-wrapper">
				      <p>Hidden content.</p>
				    </div>
				  </div>
				</article>

			+codeblock('JS').
				import { Panel } from 'panelset';
				Panel.init();

	.lane
		.container
			+anchor Changing the trigger
			p Because the trigger connects to the panel by #[code id], the two elements can appear in any order in the DOM. Here the expandable area sits #[em above] the trigger, and the button label changes between "Show more" and "Show less" using an #[code aria-expanded]-driven CSS rule — no JavaScript required.

			.card
				.demo
					article.show-more-article
						button(aria-controls="docs-show-more-trigger" aria-expanded="false")
							span.when-closed Show more
							span.when-open Show less
						div#docs-show-more-trigger(data-panel data-panel-axis="vertical" class="is-closed")
							.panel-wrapper
								p Additional content that was hidden. It can be as long as needed — the panel animates to its natural height. If we make this text long, it might wrap to multiple lines.

	


			+codeblock('HTML').
				<article>
				  <button aria-controls="my-panel" aria-expanded="false">
				    <span class="when-closed">Show more</span>
				    <span class="when-open">Show less</span>
				  </button>
				  <div id="my-panel" data-panel data-panel-axis="vertical" class="is-closed">
				    <div class="panel-wrapper">
				      <p>Hidden content here.</p>
				    </div>
				  </div>
				</article>

			+codeblock('CSS').
				button[aria-expanded="false"] .when-open,
				button[aria-expanded="true"] .when-closed { display: none; }

			+codeblock('JS').
				import { Panel } from 'panelset';
				Panel.init();

append scripts
	if isProd
		script(src="/lib/panelset.js" vite-ignore)
		script.
			Panel.init('.docs-content [data-panel]');
	else
		script(type="module").
			import { Panel } from 'panelset';
			Panel.init('.docs-content [data-panel]', { debug: true });
