extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Accessibility"

block content
	.lane
		.container
			.page-header
				h1 PanelSet accessibility
				p.lead What PanelSet handles for you, and what you still need to do.

	+section("What PanelSet does automatically")
		p PanelSet keeps #[code aria-selected] in sync on every #[code [aria-controls]] trigger, setting it the moment a switch is committed, well before the animation ends. It also applies #[code inert] to a closed container and to panels that are not visible yet during a transition, so nothing offscreen stays reachable.

		.card
			table.table
				thead
					tr
						th When
						th PanelSet automatically
				tbody
					tr
						td On initialisation
						td Sets #[code aria-selected] on all #[code [aria-controls]] triggers to match the active panel
					tr
						td On init / refresh
						td Links each panel to the tab that controls it via #[code aria-labelledby] (generating a tab #[code id] if needed), unless the panel already has a name
					tr
						td Tab is switched
						td Updates #[code aria-selected] immediately when the new tab is committed (before the animation ends)
					tr
						td Closable panelset is closed
						td Adds #[code inert] to the container, removing it and its contents from the tab order entirely

	+section("What you still need to provide")
		ul
			li Keyboard navigation (arrow keys, Home, End) if you are using a real #[code role="tablist"] pattern. You can use #[a(href=url('/panelcontrol/index.html')) PanelControl] to automate this for you.

			li An accessible name for any panel with #[strong no] controlling tab (give them #[code aria-label]). Panels that #[em do] have a tab get #[code aria-labelledby] for free (see #[a(href=url('/panelset/configuration.html?panel=option-managelabels#available-options')) manageLabels], the auto-adding of the attribute can be switched off).

			li The initial #[code aria-selected] state in your HTML. PanelSet overrides it on init, but it keeps the no-JS fallback correct.


	+section("Required markup")
		.card.api
			h3 Panel elements
			p Every panel needs #[code role="tabpanel"] and a unique #[code id].

			+codeblock('HTML')
				div(data-panelset)
					div(role="tabpanel" id="panel-1" aria-labelledby="tab-1") <!-- Content -->
					div(role="tabpanel" id="panel-2" aria-labelledby="tab-2") <!-- Content -->

		.card.api
			h3 Tab buttons
			p For a real tab interface, wrap the buttons in a #[code role="tablist"], and give each one #[code role="tab"] and #[code aria-controls].

			+codeblock('HTML')
				div(role="tablist" aria-label="Settings sections")
					button(role="tab" id="tab-1" aria-controls="panel-1" aria-selected="true") Overview
					button(role="tab" id="tab-2" aria-controls="panel-2" aria-selected="false") Security

	+section("Focus management")
		p Switch panels with the keyboard to see #[code autoFocus] at work. Tab to a button, press Enter, and watch where focus lands.

		.card
			+anchor('h3', 'a11y-heading')(title="autoFocus: 'heading'")
			p Focus moves to the first heading in the incoming panel. PanelSet adds #[code tabindex="-1"] to that heading for you if it has not got one (a heading cannot take focus otherwise).

			.demo
				.demo-controls
					button(aria-controls="a11y-h-panel-1") Panel 1
					button(aria-controls="a11y-h-panel-2") Panel 2
					button(aria-controls="a11y-h-panel-3") Panel 3
				div#a11y-heading-demo(data-panelset)
					.panel-wrapper
						div.active(role="tabpanel" id="a11y-h-panel-1" aria-labelledby="a11y-h-tab-1")
							h3(tabindex="-1") Key Features
							p Switch to this panel with keyboard to see focus land on this heading. Here is #[a(href="#a11y-heading") A focusable link in this panel].

						div(role="tabpanel" id="a11y-h-panel-2" hidden aria-labelledby="a11y-h-tab-2")
							h3(tabindex="-1") Pricing Plans
							p Switch to this panel with keyboard to see focus land on this heading.
							button(type="button") A button in this panel
						div(role="tabpanel" id="a11y-h-panel-3" hidden aria-labelledby="a11y-h-tab-3")
							h3(tabindex="-1") Support Options
							p Switch to this panel with keyboard to see focus land on this heading.
							input(type="text" placeholder="An input in this panel")

		.card
			+anchor('h3', 'a11y-first')(title="autoFocus: 'first'")
			p Focus moves to the first focusable element. Ideal for wizard steps, where you want the user in the form straight away.

			.demo
				.demo-controls
					button(aria-controls="a11y-f-panel-1") Step 1
					button(aria-controls="a11y-f-panel-2") Step 2
					button(aria-controls="a11y-f-panel-3") Step 3
				div#a11y-first-demo(data-panelset)
					.panel-wrapper

						div.active(role="tabpanel" id="a11y-f-panel-1" aria-label="Step 1: Your name")
							h3 Step 1. Your name
							p Focus will land on the input below when you arrive here via keyboard.
							label
								| Name:
								input(type="text" placeholder="Enter your name")

						div(role="tabpanel" id="a11y-f-panel-2" hidden aria-label="Step 2: Your email")
							h3 Step 2. Your email
							p Focus will land on the input below when you arrive here via keyboard.
							label
								| Email:
								input(type="email" placeholder="Enter your email")

						div(role="tabpanel" id="a11y-f-panel-3" hidden aria-label="Step 3: Confirm")
							h3 Step 3. Confirm
							p Focus will land on the submit button when you arrive here via keyboard.
							p Review your details and submit when ready.

				.demo-controls(style="justify-content: space-between")
					button#a11y-wizard-back.btn.chevron.back(disabled)
						+chevron(24, 'left')
						| Back
					button#a11y-wizard-next.btn.chevron
						| Next
						+chevron()

		+anchor('h3', 'a11y-input')(title="autoFocus: 'input'")
		p Focus moves to the first #[code input], #[code select], or #[code textarea] in the incoming panel.

		.callout
			+warning()
			p #[strong Note]: this one moves focus for everyone, not just keyboard users.

		.card
			.demo
				.demo-controls
					button(aria-controls="a11y-i-panel-1") Welcome
					button(aria-controls="a11y-i-panel-2") Sign in

				div#a11y-input-demo(data-panelset)
					.panel-wrapper
						div.active(role="tabpanel" id="a11y-i-panel-1" aria-label="Welcome")
							h3 Welcome
							p We have another panel for you.

						div(role="tabpanel" id="a11y-i-panel-2" hidden aria-label="Sign in")
							h3 Sign in
							p Please fill in your email to sign in.
							label
								| Email:
								input(type="email" placeholder="you@example.com")

	+section("autoFocus options")
		p Panel and PanelSet take the same #[code autoFocus] values.

		.card.api
			table.table
				thead
					tr
						th Value
						th What it focuses
						th Best for
				tbody
					tr
						td #[code 'heading']
						td First #[code h1-h6] in panel (gets #[code tabindex="-1"] automatically)
						td Standard tabs with headings
					tr
						td #[code 'first']
						td First focusable element (button, link, input)
						td Wizard steps, forms
					tr
						td #[code true]
						td The panel element itself
						td Panels with #[code aria-label]
					tr
						td #[code 'input']
						td First form field (input, select, textarea)
						td Forms, bypasses keyboard-only check
					tr
						td #[code false]
						td Nothing (no focus movement)
						td Page load, mouse-only interfaces

		.card.api
			h3 Keyboard vs. mouse detection

			p Pass the event to #[code show()] and PanelSet only moves focus on keyboard activation (Enter or Space). Mouse clicks skip the focus move, which keeps the page from jumping unexpectedly.

			+codeblock('JS').
				button.addEventListener('click', (event) => {
					panelSet.show('panel-2', {
						event,              // pass the event
						autoFocus: 'heading'
					});
					// keyboard: focuses heading
					// mouse click: no focus movement
				});

			.callout
				+warning()
				p #[strong Best practice:] always pass #[code event] to #[code show()]. Without it, #[code autoFocus] fires on every activation, mouse clicks included, which can scroll the page out from under a mobile user. You do not want that.

	+section("Labeling panels")
		p Every panel needs an accessible name, so a screen reader can say what it is showing. PanelSet does this for tabbed panels automatically (#[code manageLabels]); the patterns below are what it produces, plus what to write yourself for panels that have no tab.

		.card.api
			h3 aria-labelledby (recommended for tabs)
			p Links the panel to its tab button, so the button’s text becomes the panel’s accessible name. PanelSet applies this for you (it comes up with a tab id if needed); write it by hand only to override, or when #[code manageLabels] is off.

			+codeblock('HTML')
				button(role="tab" id="tab-overview" aria-controls="panel-overview") Overview
				+n
				div(role="tabpanel" id="panel-overview" aria-labelledby="tab-overview")
					// Content

		.card.api
			h3 aria-label (for panels without tabs)
			p For wizard steps, sub-panels, or any panel with no tab of its own.

			+codeblock('HTML')
				div(role="tabpanel" id="step-2" aria-label="Step 2: Contact Information")
					// Content


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}assets/scripts/example-accessibility.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			new PanelSet('#a11y-heading-demo', { autoFocus: 'heading' });
			new PanelSet('#a11y-first-demo', { autoFocus: 'first' });
			new PanelSet('#a11y-input-demo', { autoFocus: 'input' });
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module" src="/src/assets/scripts/example-accessibility.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			new PanelSet('#a11y-heading-demo', { autoFocus: 'heading' });
			new PanelSet('#a11y-first-demo', { autoFocus: 'first' });
			new PanelSet('#a11y-input-demo', { autoFocus: 'input' });
