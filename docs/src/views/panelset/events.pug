extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Events"

block content
	.lane
		.container
			.page-header
				h1 PanelSet events
				p.lead PanelSet dispatches some custom events.

			p PanelSet fires its custom events from the #[code [data-panelset]] container element. Listen on the container (most examples below do), or on #[code document], since the events bubble.

	+section("Available events")
		.column.gap-1(data-panel-group data-panel-close-siblings)
			+apiEvent("ps:ready")
				p Fires once the PanelSet instance is fully initialised and ready to use.

				h3 Detail:

				dl
					dt.code container: HTMLElement
					dd The #[code [data-panelset]] container element.
					dt.code instance: PanelSet
					dd The PanelSet instance.
				+codeblock('JavaScript').
					document.addEventListener('ps:ready', e => {
						console.log('Initialised:', e.detail.container.id);
						console.log('Panel count:', e.detail.instance.panels.length);
					});

			+apiEvent("ps:beforeactivate")

				p Fires at the very start of an activation, before anything changes. This one is cancelable: call #[code e.preventDefault()] to veto the switch. It fires whether a user clicked a tab, your script called #[code next()], #[code prev()], or #[code show()], or a #[code ?panel=] link opened a panel on load. They all arrive here first, so it is the place to control navigation (for example, a wizard that refuses to advance until the current step is valid).

				
				h3 Detail:
				dl
					dt.code panelId: string
					dd ID of the panel about to be activated.
					dt.code targetPanel: HTMLElement
					dd The panel element about to be activated.
					dt.code outgoingPanel: HTMLElement | null
					dd The currently active panel, or #[code null] if none.
					dt.code trigger: HTMLElement | null
					dd The element that triggered the activation, or #[code null] if programmatic.
				+codeblock('JavaScript').
					container.addEventListener('ps:beforeactivate', e => {
						// Veto the switch unless the current step is valid.
						if (!isCurrentStepValid()) {
							e.preventDefault();   // nothing changes
						}
					});

			+apiEvent("ps:beforeopen")

				p Fires just before an activation begins. This is the hook for loading content: hand a promise to #[code e.detail.promise] and the transition waits until it settles.

				h3 Detail:
				dl
					dt.code panelId: string
					dd ID of the panel being activated.
					dt.code targetPanel: HTMLElement
					dd The panel element being activated.
					dt.code outgoingPanel: HTMLElement | null
					dd The panel being deactivated, or #[code null] if none.
					dt.code signal: AbortSignal
					dd Aborted if the user triggers a different panel before this one loads.
					dt.code promise: Promise | null
					dd Set this to a promise to delay activation.
				+codeblock('JavaScript').
					container.addEventListener('ps:beforeopen', e => {
						const { targetPanel, signal } = e.detail;
						if (targetPanel.dataset.loaded === 'true') return;
						e.detail.promise = fetch(`/api/panel/${targetPanel.id}`, { signal })
							.then(r => r.text())
							.then(html => {
								targetPanel.innerHTML = html;
								targetPanel.dataset.loaded = 'true';
							});
					});
				p Or skip the event and use the convenience method:
				+codeblock('JavaScript').
					panelSet.onBeforeOpen((targetPanel, signal) => {
						return fetch(`/api/panel/${targetPanel.id}`, { signal })
							.then(r => r.text())
							.then(html => targetPanel.innerHTML = html);
					}, { once: true });

			+apiEvent("ps:activationstart")
				p Fires once the activation is committed and the transitions are about to start (after any async loading). The veto window has closed by now, so this is where you react to a switch that is definitely happening.

				h3 Detail:

				dl
					dt.code panelId: string
					dd ID of the panel being activated.
					dt.code trigger: HTMLElement | null
					dd The element that triggered the activation, or #[code null] if programmatic.
					dt.code outgoingPanel: HTMLElement | null
					dd The panel being deactivated, or #[code null] on the first activation.
					dt.code index: number
					dd Zero-based position of the activated panel in DOM order.
					dt.code total: number
					dd Number of panels in the set.
					dt.code atStart: boolean
					dd #[code true] when the activated panel is the first one.
					dt.code atEnd: boolean
					dd #[code true] when the activated panel is the last one.
				+codeblock('JavaScript').
					container.addEventListener('ps:activationstart', e => {
						console.log('Activating:', e.detail.panelId);
					});

			+apiEvent("ps:activationcomplete")

				p Fires when the height animation and the panel transition have both finished. The switch is done and the set is idle again.

				h3 Detail:
				dl
					dt.code panelId: string
					dd ID of the panel that is now active.
					dt.code trigger: HTMLElement | null
					dd The element that triggered the activation, or #[code null] if programmatic.
					dt.code outgoingPanel: HTMLElement | null
					dd The panel that was deactivated, or #[code null] on the first activation.
					dt.code index: number
					dd Zero-based position of the activated panel in DOM order.
					dt.code total: number
					dd Number of panels in the set.
					dt.code atStart: boolean
					dd #[code true] when the activated panel is the first one.
					dt.code atEnd: boolean
					dd #[code true] when the activated panel is the last one.
				+codeblock('JavaScript').
					container.addEventListener('ps:activationcomplete', e => {
						console.log('Now active:', e.detail.panelId);
					});

			+apiEvent("ps:activationaborted")
				p Fires when an activation-in-progress is interrupted by a newer one. This is the impatient-clicking case: the first switch never completes, and this tells you which panel got dropped.

				h3 Detail:
				dl
					dt.code panelId: string
					dd ID of the panel whose activation was aborted.
					dt.code trigger: HTMLElement | null
					dd The element that triggered the aborted activation.
				+codeblock('JavaScript').
					container.addEventListener('ps:activationaborted', e => {
						console.log('Aborted:', e.detail.panelId);
					});

	+section("Examples")
		.card
			p Switch to the Video tab and it plays; switch away and it pauses and rewinds to the start. The activation events are logged to the console so you can watch the order they fire in.
			.demo
				.demo-controls
					button(aria-controls="ev-vid-panel-1") Tab 1
					button(aria-controls="ev-vid-panel-2") Video
				div#ev-vid-demo(data-panelset)
					.panel-wrapper
						div.active(role="tabpanel" id="ev-vid-panel-1") Switch to the Video tab.
						div(role="tabpanel" id="ev-vid-panel-2" hidden)
							video#ev-vid(width="100%")
								source(src="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.webm" type="video/webm")
								source(src="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4" type="video/mp4")
			+codeblock('JavaScript').
				document.addEventListener('click', event => {
					const button = event.target.closest('button[aria-controls]');
					if (!button) return;
					const panelId = button.getAttribute('aria-controls');
					const container = document.getElementById(panelId)?.closest('[data-panelset]');
					container?.panelSet?.show(panelId, { event });
				});

				const demo  = document.getElementById('ev-vid-demo');
				const video = demo.querySelector('video');

				demo.addEventListener('ps:activationstart', e => {
					if (e.detail.panelId !== 'ev-vid-panel-2') video.pause();
				});
				demo.addEventListener('ps:activationcomplete', e => {
					if (e.detail.panelId === 'ev-vid-panel-2') {
						video.play();
					} else {
						video.currentTime = 0;
					}
				});


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}assets/scripts/example-panelset-events.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			Panel.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module" src="/src/assets/scripts/example-panelset-events.js")
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init();
