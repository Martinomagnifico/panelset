extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Getting started"

block content
	.lane
		.container
			.page-header
				h1 PanelSet
				p.lead A container that switches between panels, with smooth transitions and fades.

	+section("What PanelSet does")
		p #[code PanelSet] manages a group of panels where only one is visible at a time. When you activate a new panel, the outgoing one fades out, the container animates its height to match the incoming one, and the new panel fades in.

		p Typical uses: tabs, wizards, steppers, multi-step forms.

		.callout
			+warning()
			p #[strong Not the same as Panel.] #[code Panel] opens and closes a single element. #[code PanelSet] switches between several. See the #[a(href=url('/intro.html')) Intro] for the distinction.

	+section("Setup")
		+installWizard('PanelSet', 'PanelSet')

	+section("Markup")
		p Add #[code data-panelset] to the container. Each panel needs a unique #[code id] and #[code role="tabpanel"]. Mark the initially active panel with #[code class="active"] and all others with #[code hidden]. Wrap panel content in #[code .panel-wrapper] (auto-generated if missing).


		.card
			.demo
				+exampletabset('gs')
				+examplepanelset('gs')

			+codeblock('HTML')
				div(data-panelset)
					.panel-wrapper
						div(role="tabpanel" id="panel-1" aria-label="Features" class="active")
							h3 Features
							p Content...
						+n
						div(role="tabpanel" id="panel-2" aria-label="Pricing" hidden)
							h3 Pricing
							p Content...

	+section("Starting state")
		p Choose which panel is visible on load by giving it #[code class="active"] and marking every other panel #[code hidden]. Swap those class and attributes to start on a different panel. PanelSet reads this on init and syncs the triggers’ #[code aria-selected] automatically, so the markup is the only thing you set.

		.card
			.demo
				+exampletabset('starting-state')
				#starting-state(data-panelset)
					.panel-wrapper
						div(role="tabpanel", id="starting-state-panel-1", hidden, aria-label="Key features")
							+example-1

						.active(role="tabpanel", id="starting-state-panel-2", aria-label="Pricing plans")
							+example-2

						div(role="tabpanel", id="starting-state-panel-3", hidden, aria-label="Support options")
							+example-3


			+codeblock('HTML')
				// Start on the second panel (Pricing)
				div(data-panelset)
					.panel-wrapper
						div(role="tabpanel" id="panel-1" aria-label="Features" hidden)
							h3 Features
						+n
						div(role="tabpanel" id="panel-2" aria-label="Pricing" class="active")
							h3 Pricing

		p For a #[strong closable] PanelSet (#[code closable: true]), the whole container is closed by default. To start it open, add #[code is-open] to the container. PanelSet will read it on init, removes #[code inert], and the chosen #[code .active] panel shows.

		+codeblock('HTML')
			// Closable, and open on load
			div(data-panelset data-closable class="is-open")
				.panel-wrapper
					div(role="tabpanel" id="panel-1" aria-label="Features" class="active") …
					div(role="tabpanel" id="panel-2" aria-label="Pricing" hidden) …

	+section("Initializing")
		+codeblock('JS').
			// All [data-panelset] elements, default options
			PanelSet.init();

			// With options
			PanelSet.init({ debug: true });

			// Custom selector
			PanelSet.init('#my-tabs');

			// Both
			PanelSet.init('#my-tabs', { autoFocus: 'heading' });

			// Direct instance
			const ps = new PanelSet('#my-tabs', { closable: true });

	+section("Activating panels")
		p Use the #[code show()] method. Always pass the original event so PanelSet can detect keyboard vs. mouse for focus management.

		+codeblock('JS').
			// From a click handler
			button.addEventListener('click', event => {
				panelSet.show('panel-2', { event });
			});

		p For accessible tab interfaces, use #[code aria-controls] on the trigger buttons.

		+codeblock('JS').
			document.addEventListener('click', event => {
				const btn = event.target.closest('button[aria-controls]');
				if (!btn) return;

				const panelId = btn.getAttribute('aria-controls');
				const container = document.getElementById(panelId)?.closest('[data-panelset]');
				container?.panelSet?.show(panelId, { event });
			});

		p #[strong Bonus:] PanelSet automatically manages #[code aria-selected] and #[code tabindex] for elements with #[code role="tab"].

	+section("Public API", "API")
		+codeblock('JS').
			const ps = new PanelSet('#my-tabs');

			ps.show('panel-2', { event });   // activate a panel
			ps.open({ event });              // open (if closable: true)
			ps.close();                      // close (if closable: true)
			ps.toggle({ event });            // toggle open/closed (if closable: true)
			ps.getActive();                  // 'panel-2' (active or pending panel ID)

			ps.element      // the container HTMLElement
			ps.config       // the merged config object
			ps.panels       // array of panel HTMLElements
			ps.activePanel  // the currently visible panel element


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
