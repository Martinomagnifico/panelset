extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | API"

block content
	.lane
		.container
			.page-header
				h1 PanelSet API
				p.lead Constructor, instance methods, properties, and static methods.

	+section("Constructor")
		.card.api
			h3.code new PanelSet(elementOrSelector: HTMLElement | string, options?: PanelSetConfig)
			hr
			p Creates a new PanelSet instance.
			h4 Parameters:
			dl
				dt.code elementOrSelector
				dd CSS selector string or HTMLElement reference to the #[code [data-panelset]] container.
				dt.code options (optional)
				dd Configuration object. See #[a(href="/panelset/configuration.html") PanelSet, Configuration] for all options.
			+codeblock('JavaScript').
				const ps = new PanelSet('#my-tabs');
				const ps = new PanelSet('#my-tabs', { transitions: true, autoFocus: 'heading' });
				const ps = new PanelSet(document.getElementById('my-tabs'));

	+section("Instance methods")
		.card.api
			h3.code panelSet.show(panelId: string, options?): Promise&lt;void&gt;
			hr
			p Activates a panel by ID. Does nothing if the panel is already active (unless #[code closeOnTab] is enabled).
			h4 Parameters:
			dl
				dt.code panelId
				dd ID of the panel to activate.
				dt.code options (optional)
				dd
					ul
						li #[code event?: Event]: Triggering event. Used for keyboard detection and trigger tracking.
						li #[code transition?: boolean]: Whether to animate. Default: #[code true].
						li #[code autoFocus?: AutoFocusMode]: Override the global #[code autoFocus] for this activation.
			h4 Returns:
			p Promise that resolves when the activation transition completes.

			+codeblock('JavaScript').
				panelSet.show('panel-2');
				panelSet.show('panel-2', { transition: false });
				button.addEventListener('click', event => {
					panelSet.show('panel-2', { event, autoFocus: 'heading' });
				});

		.card.api
			h3.code panelSet.open(options?): void
			hr
			p Opens a closable PanelSet (#[code closable: true] required). Does nothing if it is already open.
			h4 Parameters:
			dl
				dt.code options (optional)
				dd #[code event], #[code transition], #[code autoFocus]: same as #[code show()].

		.card.api
			h3.code panelSet.close(options?): void
			hr
			p Closes a closable PanelSet. Does nothing if it is already closed.
			h4 Parameters:
			dl
				dt.code options (optional)
				dd #[code transition?: boolean]

		.card.api
			h3.code panelSet.toggle(options?): void
			hr
			p Opens if closed, closes if open. Same options as #[code open()].

		.card.api
			h3.code panelSet.next(options?): void
			hr
			p Activates the next panel in DOM order, stepping from the currently active (or pending) panel. By default it stops at the last panel; enable the #[code loop] config option (or #[code data-ps-loop]) to wrap to the first.
			h4 Parameters:
			dl
				dt.code options (optional)
				dd Same #[code ShowOptions] as #[code show()]: #[code event], #[code transition], #[code autoFocus]. Pass #[code event] so #[code autoFocus] only moves focus on keyboard activation.

			+codeblock('JavaScript').
				nextButton.addEventListener('click', event => panelSet.next({ event }));

		.card.api
			h3.code panelSet.prev(options?): void
			hr
			p Activates the previous panel in DOM order. By default it stops at the first panel; enable the #[code loop] config option (or #[code data-ps-loop]) to wrap to the last.
			h4 Parameters:
			dl
				dt.code options (optional)
				dd Same #[code ShowOptions] as #[code show()].

			+codeblock('JavaScript').
				prevButton.addEventListener('click', event => panelSet.prev({ event }));

		.card.api
			h3.code panelSet.getActive(): string | null
			hr
			p Returns the ID of the currently active (or pending) panel, or #[code null].

			+codeblock('JavaScript').
				const current = panelSet.getActive();
				if (current === 'step-2') {
					panelSet.show('step-3', { event });
				}

		.card.api
			h3.code panelSet.refresh(): void
			hr
			p Re-scans the DOM for this set’s panels and reconciles internal state: the active panel, trigger state, and the Prev/Next end-of-range disabling. Call after adding, removing, or reordering #[code [role="tabpanel"]] elements at runtime (for example a lazy or windowed wizard). The active panel is preserved when still present; otherwise it falls back to the #[code .active] panel, then the first. Newly added panels are initialised to the hidden state.
			p #[strong Note:] call when idle, not mid-transition. #[code addPanel()] and #[code removePanel()] call this for you.

		.card.api
			h3.code panelSet.addPanel(panel: HTMLElement, position?): HTMLElement
			hr
			p Inserts a panel at runtime and refreshes. The node is appended to the wrapper unless a position is given. Ensures the element carries #[code role="tabpanel"]. Returns the inserted panel.
			h4 Parameters:
			dl
				dt.code panel
				dd The element to insert.
				dt.code position (optional)
				dd One of #[code { before: panelId }], #[code { after: panelId }], or #[code { index: number }].

			+codeblock('JavaScript').
				const node = document.createElement('div');
				node.id = 'step-3';
				node.innerHTML = '&lt;h3&gt;Step 3&lt;/h3&gt;';
				panelSet.addPanel(node, { after: 'step-2' });
				panelSet.show('step-3');

		.card.api
			h3.code panelSet.removePanel(panelId: string): void
			hr
			p Removes a panel by ID and refreshes. If the removed panel was active, #[code refresh()] promotes a fallback. Does nothing if the ID is not found.

		.card.api
			h3.code panelSet.onBeforeOpen(handler, options?): void
			hr
			p Registers a handler for async content loading before panel activation.
			h4 Parameters:
			dl
				dt.code handler
				dd #[code (targetPanel: HTMLElement, signal: AbortSignal) => Promise&lt;void&gt; | void]: Return a promise to delay activation.
				dt.code options (optional)
				dd #[code { once?: boolean }]: If #[code true], the handler is skipped after the first successful load.

			+codeblock('JavaScript').
				panelSet.onBeforeOpen((targetPanel, signal) => {
					return fetch(`/api/${targetPanel.id}`, { signal })
						.then(r => r.text())
						.then(html => targetPanel.innerHTML = html);
				}, { once: true });

			p You can also define the handler as a named function. This keeps the call site clean and lets you share the same function across multiple panelsets.

			+codeblock('JavaScript').
				async function loadPanel(targetPanel, signal) {
					const html = await fetch(`/api/${targetPanel.id}`, { signal }).then(r => r.text());
					targetPanel.innerHTML = html;
				}

				panelSet.onBeforeOpen(loadPanel, { once: true });

		.card.api
			h3.code panelSet.destroy(): void
			hr
			p Tears down the instance: aborts any pending animations, disconnects the height-tracking #[code ResizeObserver], and removes the #[code element.panelSet] reference. The DOM (panels, classes) is left as-is. Re-initialise with #[code new PanelSet()] or #[code PanelSet.init()] afterwards if needed.

	+section("Instance properties")
		.card.api
			h3.code panelSet.element: HTMLElement
			hr
			p #[strong Read-only.] The #[code [data-panelset]] container element.

		.card.api
			h3.code panelSet.panels: HTMLElement[]
			hr
			p #[strong Read-only.] Array of all #[code [role="tabpanel"]] elements in this PanelSet.

		.card.api
			h3.code panelSet.activePanel: HTMLElement
			hr
			p #[strong Read-only.] The currently visible panel element.

		.card.api
			h3.code panelSet.pendingPanel: HTMLElement
			hr
			p #[strong Read-only.] The panel being activated. Equal to #[code activePanel] when idle, but during a transition it is the incoming panel. #[code getActive()] returns its ID, and #[code next()] / #[code prev()] step relative to it so rapid clicks queue correctly.

		.card.api
			h3.code panelSet.panelWrapper: HTMLElement
			hr
			p #[strong Read-only.] The direct-child #[code .panel-wrapper] element that holds the panels (created automatically if absent). Runtime inserts via #[code addPanel()] go here.

		.card.api
			h3.code panelSet.config: PanelSetConfig
			hr
			p #[strong Read-only.] The merged configuration object (1. defaults 2. data attributes 3. constructor options).

	+section("Static methods")
		.card.api
			h3.code PanelSet.init(selectorOrOptions?, options?): PanelSet[]
			hr
			p Auto-initialises all panelsets matching the selector. Stores the instance on each container as #[code container.panelSet].
			h4 Parameters:
			dl
				dt.code selectorOrOptions (optional)
				dd CSS selector string, or a config object (uses #[code '[data-panelset]'] selector).
				dt.code options (optional)
				dd Config object: only used when the first argument is a selector string.
			h4 Returns:
			p Array of created PanelSet instances.

			+codeblock('JavaScript').
				PanelSet.init();
				PanelSet.init({ debug: true });
				PanelSet.init('[data-panelset]', { autoFocus: 'heading' });

				// Access instance later via the element
				document.getElementById('my-tabs').panelSet.show('panel-2');

		.card.api
			h3.code PanelSet.defaults: PanelSetConfig
			hr
			p #[strong Static property.] Default configuration applied to all new instances. Modify to change defaults globally.

			+codeblock('JavaScript').
				PanelSet.defaults.autoFocus = 'heading';
				PanelSet.defaults.debug = true;

	+section("TypeScript types")
		+codeblock('JavaScript').
			import {
				PanelSet,
				type PanelSetConfig,
				type ShowOptions,
				type HandlerOptions,
				type AsyncContentHandler,
				type ReadyEventDetail,
				type BeforeActivateEventDetail,
				type BeforeOpenEventDetail,
				type ActivationEventDetail,
				type ActivationAbortedEventDetail,
			} from 'panelset';

			const config: PanelSetConfig = {
				transitions: { height: true, panels: false },
				closable: true,
				autoFocus: 'heading',
				persist: true,
			};

			const ps = new PanelSet('#my-tabs', config);

			ps.element.addEventListener('ps:activationstart', e => {
				const event = e as CustomEvent<ActivationEventDetail>;
				console.log(event.detail.panelId);
			});


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
