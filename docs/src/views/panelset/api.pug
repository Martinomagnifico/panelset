extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | API"

block content
	.lane
		.container
			.page-header
				h1 PanelSet API
				p.lead Everything you can call on a PanelSet.

	+section("Constructor")
		.card.api
			h3.code new PanelSet(elementOrSelector: HTMLElement | string, options?: PanelSetConfig)
			hr
			p Builds a PanelSet on a single container, from a selector or an element. This is the manual route, for when you want a reference to one specific instance. To wire up several at once, #[code PanelSet.init()] (further down) is less typing.
			h4 Parameters:
			dl
				dt.code elementOrSelector
				dd CSS selector string or HTMLElement reference to the #[code [data-panelset]] container.
				dt.code options (optional)
				dd Configuration object. See #[a(href=url('/panelset/configuration.html')) PanelSet, Configuration] for all options.
			+codeblock('JavaScript').
				const ps = new PanelSet('#my-tabs');
				const ps = new PanelSet('#my-tabs', { transitions: true, autoFocus: 'heading' });
				const ps = new PanelSet(document.getElementById('my-tabs'));

	+section("Instance methods")
		.card.api
			h3.code panelSet.show(panelId: string, options?): Promise&lt;void&gt;
			hr
			p Activate a panel by its ID. If it is already the active one, nothing happens. The exception is #[code closeOnTab]: with that on, asking for the active panel again closes the whole set (well, if closable).

			h4 Parameters:
			dl
				dt.code panelId
				dd ID of the panel to activate.
				dt.code options (optional)
				dd
					ul
						li #[code event?: Event]: Triggering event. Used for keyboard detection and trigger tracking.
						li #[code transition?: boolean]: Whether to animate. Default: #[code true].
						li #[code autoFocus?: AutoFocusMode]: Override the global #[code autoFocus] for this activation.
			h4 Returns:
			p A promise that resolves once the activation transition has finished.

			+codeblock('JavaScript').
				panelSet.show('panel-2');
				panelSet.show('panel-2', { transition: false });
				button.addEventListener('click', event => {
					panelSet.show('panel-2', { event, autoFocus: 'heading' });
				});

		.card.api
			h3.code panelSet.open(options?): void
			hr
			p Open a closable set (it needs #[code closable: true]). Does nothing if it is already open.
			
			h4 Parameters:
			dl
				dt.code options (optional)
				dd #[code event], #[code transition], #[code autoFocus]: same as #[code show()].

		.card.api
			h3.code panelSet.close(options?): void
			hr
			p Close a closable set. Does nothing if it is already closed.
			h4 Parameters:
			dl
				dt.code options (optional)
				dd #[code transition?: boolean]

		.card.api
			h3.code panelSet.toggle(options?): void
			hr
			p Open if closed, close if open. Kind of logical. Takes the same options as #[code open()]. 

		.card.api
			h3.code panelSet.next(options?): void
			hr
			p Activate the next panel in DOM order, counting from the active (or pending) panel. By default it stops at the last one. Turn on #[code loop] (or #[code data-ps-loop]) to wrap round to the first instead.

			h4 Parameters:
			dl
				dt.code options (optional)
				dd Same #[code ShowOptions] as #[code show()]: #[code event], #[code transition], #[code autoFocus]. Pass #[code event] so #[code autoFocus] only moves focus on keyboard activation.

			+codeblock('JavaScript').
				nextButton.addEventListener('click', event => panelSet.next({ event }));

		.card.api
			h3.code panelSet.prev(options?): void
			hr
			p Activate the previous panel in DOM order. By default it stops at the first one. Turn on #[code loop] (or #[code data-ps-loop]) to wrap round to the last instead.

			h4 Parameters:
			dl
				dt.code options (optional)
				dd Same #[code ShowOptions] as #[code show()].

			+codeblock('JavaScript').
				prevButton.addEventListener('click', event => panelSet.prev({ event }));

		.card.api
			h3.code panelSet.getActive(): string | null
			hr
			p The ID of the active (or pending) panel, or #[code null] if there is not one yet. During a transition you get the incoming panel, the one being activated, not the one on its way out.

			+codeblock('JavaScript').
				const current = panelSet.getActive();
				if (current === 'step-2') {
					panelSet.show('step-3', { event });
				}

		.card.api
			h3.code panelSet.refresh(): void
			hr
			p Re-scan the DOM for this set’s panels and reconcile the internal state: which panel is active, the trigger state, and the Prev/Next end-of-range disabling. Call it after you add, remove, or reorder #[code [role="tabpanel"]] elements at runtime (a lazy or windowed wizard, say). The active panel is kept if it is still there. If it has gone, the fallback is the #[code .active] panel, then the first. Any new panels start hidden.
			
			p #[strong Note:] call it when the set is idle, not mid-transition. #[code addPanel()] and #[code removePanel()] already do it for you.

		.card.api
			h3.code panelSet.addPanel(panel: HTMLElement, position?): HTMLElement
			hr
			p Insert a panel at runtime, then refresh. Without a position it is appended to the wrapper. The element picks up #[code role="tabpanel"] if it does not already have one. Returns the panel you inserted.

			h4 Parameters:

			dl
				dt.code panel
				dd The element to insert.
				dt.code position (optional)
				dd One of #[code { before: panelId }], #[code { after: panelId }], or #[code { index: number }].

			+codeblock('JavaScript').
				const node = document.createElement('div');
				node.id = 'step-3';
				node.innerHTML = '&lt;h3&gt;Step 3&lt;/h3&gt;';
				panelSet.addPanel(node, { after: 'step-2' });
				panelSet.show('step-3');

		.card.api
			h3.code panelSet.removePanel(panelId: string): void
			hr
			p Remove a panel by ID, then refresh. If it happened to be the active one, #[code refresh()] promotes a fallback. Nothing happens if the ID is not found.

		.card.api
			h3.code panelSet.onBeforeOpen(handler, options?): void
			hr
			p Register a handler that runs just before a panel activates, which is where content loading goes. Return a promise from it and activation waits for that promise to settle.

			h4 Parameters:
			dl
				dt.code handler
				dd #[code (targetPanel: HTMLElement, signal: AbortSignal) => Promise&lt;void&gt; | void]: Return a promise to delay activation.
				dt.code options (optional)
				dd #[code { once?: boolean }]: If #[code true], the handler is skipped after the first successful load.

			+codeblock('JavaScript').
				panelSet.onBeforeOpen((targetPanel, signal) => {
					return fetch(`/api/${targetPanel.id}`, { signal })
						.then(r => r.text())
						.then(html => targetPanel.innerHTML = html);
				}, { once: true });

			p You can pass a named function instead of an inline one. It keeps the call site tidy, and it lets you reuse the same loader across several panelsets.

			+codeblock('JavaScript').
				async function loadPanel(targetPanel, signal) {
					const html = await fetch(`/api/${targetPanel.id}`, { signal }).then(r => r.text());
					targetPanel.innerHTML = html;
				}

				panelSet.onBeforeOpen(loadPanel, { once: true });

		.card.api
			h3.code panelSet.destroy(): void
			hr
			p Destroy, delete, you get the point. It aborts any pending animation, disconnects the height-tracking #[code ResizeObserver], and drops the #[code element.panelSet] reference. The DOM is left exactly as it found it: panels, classes, all of it. Re-initialise with #[code new PanelSet()] or #[code PanelSet.init()] if you want it back.

	+section("Instance properties")
		.card.api
			h3.code panelSet.element: HTMLElement
			hr
			p #[strong Read-only.] The #[code [data-panelset]] container element itself.

		.card.api
			h3.code panelSet.panels: HTMLElement[]
			hr
			p #[strong Read-only.] Every #[code [role="tabpanel"]] element in this set, as an array.

		.card.api
			h3.code panelSet.activePanel: HTMLElement
			hr
			p #[strong Read-only.] The currently visible panel element.

		.card.api
			h3.code panelSet.pendingPanel: HTMLElement
			hr
			p #[strong Read-only.] The panel being activated. It matches #[code activePanel] when the set is idle; during a transition it is the incoming one. #[code getActive()] returns its ID, and #[code next()] / #[code prev()] step relative to it, so rapid clicks queue up in the right order.

		.card.api
			h3.code panelSet.panelWrapper: HTMLElement
			hr
			p #[strong Read-only.] The direct-child #[code .panel-wrapper] that holds the panels (created for you if it is missing). Runtime inserts from #[code addPanel()] land here.

		.card.api
			h3.code panelSet.config: PanelSetConfig
			hr
			p #[strong Read-only.] The merged configuration. Precedence runs least specific to most: defaults first, then constructor options, then data attributes.

	+section("Static methods")
		.card.api
			h3.code PanelSet.init(selectorOrOptions?, options?): PanelSet[]
			hr
			p Find every panelset matching the selector and initialise the lot in one call. Each instance is parked on its container as #[code container.panelSet], so you can reach it again later.
			
			p The selector is optional: if you leave it out, every #[code [data-panelset]] on the page will be included. The options object is only needed if you use a selector string: if you pass an element or leave the first argument out, options go in there.

			h4 Parameters:
			dl
				dt.code selectorOrOptions (optional)
				dd CSS selector string, or a config object (uses #[code '[data-panelset]'] selector).
				dt.code options (optional)
				dd Config object: only used when the first argument is a selector string.
			h4 Returns:
			p An array of the PanelSet instances it created.

			+codeblock('JavaScript').
				PanelSet.init();
				PanelSet.init({ debug: true });
				PanelSet.init('[data-panelset]', { autoFocus: 'heading' });

				// Access instance later via the element
				document.getElementById('my-tabs').panelSet.show('panel-2');

		.card.api
			h3.code PanelSet.defaults: PanelSetConfig
			hr
			p #[strong Static property.] The default config handed to every new instance. Change it here to move the defaults for the whole page at once.

			+codeblock('JavaScript').
				PanelSet.defaults.autoFocus = 'heading';
				PanelSet.defaults.debug = true;

	+section("TypeScript types")
		+codeblock('JavaScript').
			import {
				PanelSet,
				type PanelSetConfig,
				type ShowOptions,
				type HandlerOptions,
				type AsyncContentHandler,
				type ReadyEventDetail,
				type BeforeActivateEventDetail,
				type BeforeOpenEventDetail,
				type ActivationEventDetail,
				type ActivationAbortedEventDetail,
			} from 'panelset';

			const config: PanelSetConfig = {
				transitions: { height: true, panels: false },
				closable: true,
				autoFocus: 'heading',
				persist: true,
			};

			const ps = new PanelSet('#my-tabs', config);

			ps.element.addEventListener('ps:activationstart', e => {
				const event = e as CustomEvent<ActivationEventDetail>;
				console.log(event.detail.panelId);
			});


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
