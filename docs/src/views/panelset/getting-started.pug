extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet — Getting started"

mixin installWizardPS
	- const cdn = 'https://cdn.jsdelivr.net/npm/panelset@latest/dist'
	- const dl = 'https://github.com/martinomagnifico/panelset/releases/latest/download/panelset.zip'

	.card.no-padding.install-wizard.border
		nav(role="tablist").tabs
			button(role="tab" aria-controls="iw-npm") npm
			button(role="tab" aria-controls="iw-download") Download
			button(role="tab" aria-controls="iw-cdn") CDN

		.card-content(data-panelset)
			.panel-wrapper

				div(role="tabpanel" id="iw-npm" class="active" data-iw-source="npm")
					.column.gap-1
						div
							h3 Get it
							.code-block
								.code-header
									| Terminal
									button.copy Copy
								pre: code npm install panelset
						div
							h3 Use it
							.install-controls
								.control-row
									.control-item
										label Format
										select(disabled)
											option(value="esm") ESM module
										span.fixed-badge fixed
									.control-item
										label Usage
										select.iw-usage
											option(value="api") JS API
											option(value="wc") Web Component
							.code-block
								.code-header
									span.iw-lang
									button.copy Copy
								pre: code.iw-code

				div(role="tabpanel" id="iw-download" hidden data-iw-source="download")
					.column.gap-1
						div
							h3 Get it
							p Download the ZIP from the #[a(href=dl) releases page], unzip, and place the files somewhere your HTML can reach.
						div
							h3 Use it
							.install-controls
								.control-row
									.control-item
										label Format
										select.iw-format
											option(value="esm") ESM module
											option(value="iife") Script tag
									.control-item
										label Usage
										select.iw-usage
											option(value="api") JS API
											option(value="wc") Web Component
							.code-block
								.code-header
									span.iw-lang
									button.copy Copy
								pre: code.iw-code

				div(role="tabpanel" id="iw-cdn" hidden data-iw-source="cdn")
					.column.gap-1
						div
							h3 Get it
							p No download needed — files are served directly from #[a(href="https://www.jsdelivr.com/") jsDelivr].
							.code-block
								.code-header Base URL
								pre: code= cdn + '/'
						div
							h3 Use it
							.install-controls
								.control-row
									.control-item
										label Format
										select(disabled)
											option(value="iife") Script tag
										span.fixed-badge fixed
									.control-item
										label Usage
										select.iw-usage
											option(value="api") JS API
											option(value="wc") Web Component
							.code-block
								.code-header
									span.iw-lang
									button.copy Copy
								pre: code.iw-code


block content
	.lane
		.container
			.page-header
				h1 PanelSet
				p.lead A container that switches between panels, with smooth transitions and fades.

	+section("What PanelSet does")
		p #[code PanelSet] manages a group of panels where only one is visible at a time. When you activate a new panel, the outgoing one fades out, the container animates its height to match the incoming one, and the new panel fades in.

		p Typical uses: tabs, wizards, steppers, multi-step forms.

		.callout
			+warning()
			p #[strong Not the same as Panel.] #[code Panel] opens and closes a single element. #[code PanelSet] switches between several. See the #[a(href="/intro.html") Intro] for the distinction.

	+section("Setup")
		+installWizardPS

	+section("Markup")
		p Add #[code data-panelset] to the container. Each panel needs a unique #[code id] and #[code role="tabpanel"]. Mark the initially active panel with #[code class="active"] and all others with #[code hidden]. Wrap panel content in #[code .panel-wrapper] (auto-generated if missing).


		.card
			.demo
				+exampletabset('gs')
				+examplepanelset('gs')

			+codeblock('HTML')
				div(data-panelset)
					.panel-wrapper
						div(role="tabpanel" id="panel-1" aria-label="Features" class="active")
							h3 Features
							p Content...
						+n
						div(role="tabpanel" id="panel-2" aria-label="Pricing" hidden)
							h3 Pricing
							p Content...

	+section("Starting state")
		p Choose which panel is visible on load by giving it #[code class="active"] and marking every other panel #[code hidden]. Swap those class and attributes to start on a different panel. PanelSet reads this on init and syncs the triggers’ #[code aria-selected] automatically, so the markup is the only thing you set.

		.card
			.demo
				+exampletabset('starting-state')
				#starting-state(data-panelset)
					.panel-wrapper
						div(role="tabpanel", id="starting-state-panel-1", hidden, aria-label="Key features")
							+example-1

						.active(role="tabpanel", id="starting-state-panel-2", aria-label="Pricing plans")
							+example-2

						div(role="tabpanel", id="starting-state-panel-3", hidden, aria-label="Support options")
							+example-3


			+codeblock('HTML')
				// Start on the second panel (Pricing)
				div(data-panelset)
					.panel-wrapper
						div(role="tabpanel" id="panel-1" aria-label="Features" hidden)
							h3 Features
						+n
						div(role="tabpanel" id="panel-2" aria-label="Pricing" class="active")
							h3 Pricing

		p For a #[strong closable] PanelSet (#[code closable: true]), the whole container is closed by default. To start it open, add #[code is-open] to the container. PanelSet will read it on init, removes #[code inert], and the chosen #[code .active] panel shows.

		+codeblock('HTML')
			// Closable, and open on load
			div(data-panelset data-closable class="is-open")
				.panel-wrapper
					div(role="tabpanel" id="panel-1" aria-label="Features" class="active") …
					div(role="tabpanel" id="panel-2" aria-label="Pricing" hidden) …

	+section("Initializing")
		+codeblock('JS').
			// All [data-panelset] elements, default options
			PanelSet.init();

			// With options
			PanelSet.init({ debug: true });

			// Custom selector
			PanelSet.init('#my-tabs');

			// Both
			PanelSet.init('#my-tabs', { autoFocus: 'heading' });

			// Direct instance
			const ps = new PanelSet('#my-tabs', { closable: true });

	+section("Activating panels")
		p Use the #[code show()] method. Always pass the original event so PanelSet can detect keyboard vs. mouse for focus management.

		+codeblock('JS').
			// From a click handler
			button.addEventListener('click', event => {
				panelSet.show('panel-2', { event });
			});

		p For accessible tab interfaces, use #[code aria-controls] on the trigger buttons.

		+codeblock('JS').
			document.addEventListener('click', event => {
				const btn = event.target.closest('button[aria-controls]');
				if (!btn) return;

				const panelId = btn.getAttribute('aria-controls');
				const container = document.getElementById(panelId)?.closest('[data-panelset]');
				container?.panelSet?.show(panelId, { event });
			});

		p #[strong Bonus:] PanelSet automatically manages #[code aria-selected] and #[code tabindex] for elements with #[code role="tab"].

	+section("Public API", "API")
		+codeblock('JS').
			const ps = new PanelSet('#my-tabs');

			ps.show('panel-2', { event });   // activate a panel
			ps.open({ event });              // open (if closable: true)
			ps.close();                      // close (if closable: true)
			ps.toggle({ event });            // toggle open/closed (if closable: true)
			ps.getActive();                  // 'panel-2' (current panel ID)

			ps.element      // the container HTMLElement
			ps.config       // the merged config object
			ps.panels       // array of panel HTMLElements
			ps.activePanel  // the currently visible panel element


append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });

	script.
		(function () {
			var cdn = 'https://cdn.jsdelivr.net/npm/panelset@latest/dist';

			var snippets = {
				npm: {
					lang: 'js',
					api: "import { PanelSet } from 'panelset';\nimport 'panelset/style.css';",
					wc:  "import { PanelSet } from 'panelset';\nimport 'panelset/style.css';\n\nPanelSet.register();"
				},
				download: {
					esm: {
						lang: 'js',
						api: "import { PanelSet } from './panelset.esm.js';\nimport './panelset.css';",
						wc:  "import { PanelSet } from './panelset.esm.js';\nimport './panelset.css';\n\nPanelSet.register();"
					},
					iife: {
						lang: 'html',
						api: '<link rel="stylesheet" href="panelset.css">\n<script src="panelset.js"><\/script>',
						wc:  '<link rel="stylesheet" href="panelset.css">\n<script src="panelset.js"><\/script>\n<script>PanelSet.register();<\/script>'
					}
				},
				cdn: {
					lang: 'html',
					api: '<link rel="stylesheet" href="' + cdn + '/panelset.css">\n<script src="' + cdn + '/panelset.js"><\/script>',
					wc:  '<link rel="stylesheet" href="' + cdn + '/panelset.css">\n<script src="' + cdn + '/panelset.js"><\/script>\n<script>PanelSet.register();<\/script>'
				}
			};

			function updatePanel(panel) {
				var source   = panel.dataset.iwSource;
				var formatEl = panel.querySelector('.iw-format');
				var usageEl  = panel.querySelector('.iw-usage');
				var codeEl   = panel.querySelector('.iw-code');
				var langEl   = panel.querySelector('.iw-lang');

				var format = formatEl ? formatEl.value : 'esm';
				var usage  = usageEl  ? usageEl.value  : 'api';

				var data;
				if (source === 'npm' || source === 'cdn') {
					data = { lang: snippets[source].lang, code: snippets[source][usage] };
				} else {
					var group = snippets[source][format];
					data = { lang: group.lang, code: group[usage] };
				}

				if (codeEl) codeEl.textContent = data.code;
				if (langEl) langEl.textContent = data.lang.toUpperCase();
				if (window.hljs && codeEl) {
					codeEl.removeAttribute('data-highlighted');
					codeEl.className = 'language-' + data.lang;
					hljs.highlightElement(codeEl);
				}
			}

			document.querySelectorAll('.install-wizard [role="tabpanel"]').forEach(function (panel) {
				updatePanel(panel);
				panel.querySelectorAll('select').forEach(function (sel) {
					sel.addEventListener('change', function () { updatePanel(panel); });
				});
			});

			document.querySelectorAll('.install-wizard .copy').forEach(function (btn) {
				btn.addEventListener('click', function () {
					var code = btn.closest('.code-block').querySelector('code');
					if (!code) return;
					navigator.clipboard.writeText(code.textContent).then(function () {
						var orig = btn.textContent;
						btn.textContent = 'Copied!';
						setTimeout(function () { btn.textContent = orig; }, 1500);
					});
				});
			});
		}());
