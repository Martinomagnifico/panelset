extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Configuration"

block content
	.lane
		.container
			.page-header
				h1 PanelSet configuration
				p.lead Options via constructor, data attributes, or both

	+section("Setting options")
		h3 JavaScript options

		+codeblock('JS').
			PanelSet.init({ closable: true, closeOnTab: true });

			const ps = new PanelSet('#my-tabs', {
				transitions: true,
				closable: false,
				closeOnTab: false,
				autoFocus: 'heading',
				returnFocus: true
			});

		h3 Data attributes

		+codeblock('HTML')
			div(data-panelset data-transitions="false" data-closable data-loading-height="320" data-debug)
				// panels

		p JavaScript options and data attributes are both covered above. When both are set, precedence runs from least to most specific: #[strong defaults &gt; JS options &gt; element attribute]. The most specific wins, so a per-element data attribute always overrides a global #[code init()] option. That lets one set opt out of a global flag (e.g. #[code data-panel-persist="false"] on a set initialised with #[code PanelSet.init({ persist: true })]).

		p Web component configuration uses plain attributes directly on #[code &lt;ps-panelset&gt;]. No #[code data-] prefix, no JS call. These are documented in the third card of each option below. A global JS config object has no equivalent in the web component path: #[code connectedCallback] fires per element in isolation, with no shared initialisation moment. For global defaults across many elements, the JS init path is the better tool. Both paths can coexist on the same page. See the #[a(href="/panelset/examples/webcomponent.html") Web Component integration page] for full usage examples.

	+section("Available options")
		p Plain attributes (e.g. #[code transitions], #[code closable], #[code panelset-align]) are used when authoring with #[code &lt;ps-panelset&gt;]. JavaScript options, data attributes, and plain attributes all map to the same underlying config.
		.column.gap-1(data-panel-group data-panel-close-siblings)
			+apiOption("align: 'start' | 'center' | 'end'")
				p Where panels sit within the container while it is opening or closing. Only visible during the open/close animation.
				h4 Default: #[code 'start']
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { align: 'start' }]
							li #[code { align: 'center' }]
							li #[code { align: 'end' }]
					.card
						h4 Data attribute
						ul
							li #[code data-panelset-align="start"]
							li #[code data-panelset-align="center"]
							li #[code data-panelset-align="end"]
					.card
						h4 Web Component attribute
						ul
							li #[code panelset-align="start"]
							li #[code panelset-align="center"]
							li #[code panelset-align="end"]

			+apiOption("autoFocus: false | true | 'heading' | 'first' | 'input'")
				p Move focus into the incoming panel after activation.
				ul
					li #[code false]: no focus movement
					li #[code true]: focus the panel element itself
					li #[code 'heading']: first h1–h6 in the panel
					li #[code 'first']: first focusable element (keyboard events only)
					li #[code 'input']: first form field (bypasses keyboard-only check)
				p Priority order: #[code show()] call &gt; trigger attribute &gt; element attribute &gt; JS config.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { autoFocus: false }]
							li #[code { autoFocus: true }]
							li #[code { autoFocus: 'heading' }]
							li #[code { autoFocus: 'first' }]
							li #[code { autoFocus: 'input' }]
					.card
						h4 Data attribute
						p On the PanelSet element (default for all activations):
						ul
							li #[code data-auto-focus="heading"]
							li #[code data-auto-focus="first"]
							li #[code data-auto-focus="input"]
						p On a trigger button (overrides the element default for that activation):
						ul
							li #[code &lt;button aria-controls="..." data-auto-focus="input"&gt;]
					.card
						h4 Web Component attribute
						p On the #[code &lt;ps-panelset&gt;] element:
						ul
							li #[code auto-focus="heading"]
						p Per-trigger override works the same way: #[code data-auto-focus] on the button.

			+apiOption("closable: boolean")
				p When enabled, the entire PanelSet can be opened and closed (height: 0). Use #[code open()], #[code close()], and #[code toggle()] to control it.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { closable: true }]
							li #[code { closable: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-closable]
					.card
						h4 Web Component attribute
						ul
							li #[code closable]

			+apiOption("closeOnTab: boolean")
				p When enabled (requires #[code closable: true]), clicking the currently active tab closes the PanelSet. Any tab button also opens it when closed. Clicking a different tab silently switches to that panel first, then opens.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { closable: true, closeOnTab: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-close-on-tab]
					.card
						h4 Web Component attribute
						ul
							li #[code close-on-tab]

			+apiOption("levels: boolean")
				p Give panels a depth order from their DOM position — a later panel is "higher". Moving forward slides one way, back the other, and #[code .levelup] / #[code .leveldown] classes are added so CSS can reverse the transform on backward navigation.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { levels: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-levels]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-levels]

			+apiOption("loop: boolean")
				p Make #[code next()] / #[code prev()] wrap around the ends instead of stopping: past the last panel goes to the first, past the first to the last. With loop on, PanelSet never disables its #[code data-ps-next] / #[code data-ps-prev] verb buttons, since every panel stays reachable. Suits carousels — see the #[a(href="/panelset/examples/wizard.html") Wizard] page for a live cycler.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loop: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-loop]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-loop]

			+apiOption("disabledMode: 'aria' | 'native'")
				p How PanelSet disables its own #[code data-ps-next] / #[code data-ps-prev] verb buttons at the ends of the range (when #[code loop] is off). #[code 'aria'] toggles #[code aria-disabled] and leaves the native #[code disabled] attribute to you — the button stays focusable, so a hint can be announced. #[code 'native'] toggles the native #[code disabled] attribute (PanelSet owns it) and moves focus off a button before disabling it. Tab-strip locking is unaffected (always aria).
				h4 Default: #[code 'aria']
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { disabledMode: 'native' }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-disabled-mode="native"]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-disabled-mode="native"]

			+apiOption("debug: boolean")
				p Log activation events to the console.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { debug: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-debug]
					.card
						h4 Web Component attribute
						ul
							li #[code debug]

			+apiOption("interruptible: boolean")
				p When set to #[code false], new activation attempts are ignored while a transition or content load is in progress. The current activation completes first.
				p For user experience, setting this to #[code false] is #[strong not] recommended, but it is imaginable that certain flows might want to enforce a strict sequence of activations.
				h4 Default: #[code true]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { interruptible: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-interruptible="false"]
					.card
						h4 Web Component attribute
						ul
							li #[code interruptible="false"]

			+apiOption("loadingDelay: number")
				p Milliseconds before the loading spinner appears. Prevents spinner flash on fast connections.
				h4 Default: #[code 320]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loadingDelay: 320 }]
					.card
						h4 Data attribute
						ul
							li #[code data-loading-delay="320"]
					.card
						h4 Web Component attribute
						ul
							li #[code loading-delay="320"]

			+apiOption("loadingHeight: number")
				p Placeholder height in pixels while async content loads and no previous panel is visible.
				h4 Default: #[code 200]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loadingHeight: 200 }]
					.card
						h4 Data attribute
						ul
							li #[code data-loading-height="320"]
					.card
						h4 Web Component attribute
						ul
							li #[code loading-height="320"]

			+apiOption("manageTriggers: boolean")
				p When set to #[code false], PanelSet stops updating #[code aria-selected] and the #[code is-activating] class on trigger elements, and ignores #[code data-auto-focus] attributes on triggers.
				p Intended for wrapper libraries that own their own trigger state and drive PanelSet entirely through #[code show()]. For standalone use, leave this at the default.
				h4 Default: #[code true]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { manageTriggers: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-manage-triggers="false"]
					.card
						h4 Web Component attribute
						ul
							li #[code manage-triggers="false"]

			+apiOption("persist: boolean")
				p When enabled, switching panels writes the active panel ID to #[code localStorage]. On the next page load the last active panel is restored automatically.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { persist: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-panel-persist]
					.card
						h4 Web Component attribute
						ul
							li #[code panel-persist]
				p The container must have an #[code id] for #[code persist] to work.

			+apiOption("deepLink: boolean")
				p When enabled, switching panels updates the #[code ?panel=] URL param via #[code history.replaceState]. This keeps the address bar in sync so the current tab can be copied and shared. No new history entry is created.
				p The #[code ?panel=] param is always read on load regardless of this option. #[code deepLink] only controls whether activation #[em writes] back to the URL.
				p To combine shareable URLs with localStorage restoration, enable both #[code persist] and #[code deepLink].
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { deepLink: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-panel-deeplink]
					.card
						h4 Web Component attribute
						ul
							li #[code panel-deeplink]
	
			+apiOption("returnFocus: boolean")
				p Return focus to the trigger that opened the PanelSet when it closes.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { returnFocus: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-return-focus]
					.card
						h4 Web Component attribute
						ul
							li #[code return-focus]

			+apiOption("transitions: boolean | { height: boolean, panels: boolean }")
				p Enable or disable transitions. Pass an object to control height and panel fade-in/out independently.
				h4 Default: #[code true]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { transitions: true }]: all transitions on
							li #[code { transitions: false }]: all transitions off
							li #[code { transitions: { height : false } }]: height only off
							li #[code { transitions: { panels : false } }]: panel fades only off
					.card
						h4 Data attribute
						ul
							li #[code data-transitions="false"]
							li #[code data-transitions='{"height" : false}']
					.card
						h4 Web Component attribute
						ul
							li #[code transitions="false"]
							li #[code transitions='{"height" : false}']

	+section("CSS variables")
		p Transitions are controlled by CSS custom properties set on the element or any ancestor. All timing values must include a unit (#[code 0s] not #[code 0]). 

		p These same variables apply when using #[code &lt;ps-panelset&gt;]. Set them on the element directly or via CSS targeting #[code ps-panelset].

		+codeblock('CSS').
			[data-panelset] {
				/* Panel transitions */
				--ps-panel-out-speed:          0.25s;
				--ps-panel-out-timing:         ease-in;
				--ps-panel-in-speed:           0.25s;
				--ps-panel-in-timing:          ease-in-out;
				--ps-panel-in-delay:           0.25s;

				/* Container height animation */
				--ps-transition-timing:      ease-in-out;   /* tab-switch height */
				--ps-height-duration-ratio:  1;             /* height duration = panel-out-speed × ratio */
				--ps-open-speed:             0.25s;
				--ps-open-timing:            ease-in-out;
				--ps-close-speed:            0.25s;
				--ps-close-timing:           ease-in-out;

				/* Loading spinner */
				--ps-spinner-size:           40px;
				--ps-spinner-thickness:      4px;
				--ps-spinner-track-color:    rgba(0, 0, 0, 0.1);
				--ps-spinner-color:          rgba(0, 100, 255, 0.8);
				--ps-spinner-speed:          0.8s;
			}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			Panel.init();
	else
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init();
