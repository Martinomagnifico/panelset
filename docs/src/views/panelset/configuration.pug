extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Configuration"

block content
	.lane
		.container
			.page-header
				h1 PanelSet configuration
				p.lead Options via constructor, data attributes, or both

	+section("Setting options")
		h3 JavaScript options

		+codeblock('JS').
			PanelSet.init({ closable: true, closeOnTab: true });

			const ps = new PanelSet('#my-tabs', {
				transitions: true,
				closable: false,
				closeOnTab: false,
				autoFocus: 'heading',
				returnFocus: true
			});

		h3 Data attributes

		+codeblock('HTML')
			div(data-panelset data-transitions="false" data-closable data-loading-height="320" data-debug)
				// panels

		p When the same option is set two ways, the more specific one wins: #[strong defaults -&gt; JS options -&gt; group attribute -&gt; element attribute]. So a data attribute on a single set always beats a global #[code init()] option.

		p This is exactly how you let one set opt out of a flag the rest of the page opted into (e.g. #[code data-panel-persist="false"] on a set that #[code PanelSet.init({ persist: true })] would otherwise persist).

		p On #[code &lt;ps-panelset&gt;] the same options become plain attributes. No #[code data-] prefix, no JS call (third card of each option below). There’s no web-component equivalent of a global config object: #[code connectedCallback] fires per element, on its own, with no shared init moment. So for page-wide defaults, reach for the JS init() path instead. The two coexist happily. Full examples on the #[a(href="/panelset/examples/webcomponent.html") Web Component integration page].

	+section("Available options")
		p Every option below shows three ways to set it: a JS key, a data attribute, and a plain attribute for #[code &lt;ps-panelset&gt;]. All three land on the same config. Pick whichever suits you.

		.column.gap-1(data-panel-group data-panel-close-siblings)
			+apiOption("align: 'start' | 'center' | 'end'")
				p Where the panels sit inside the container while it opens or closes. You only ever see this mid-animation, so treat it as a finishing touch, not a layout setting.

				h4 Default: #[code 'start']

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { align: 'start' }]
							li #[code { align: 'center' }]
							li #[code { align: 'end' }]
					.card
						h4 Data attribute
						ul
							li #[code data-panelset-align="start"]
							li #[code data-panelset-align="center"]
							li #[code data-panelset-align="end"]
					.card
						h4 Web Component attribute
						ul
							li #[code panelset-align="start"]
							li #[code panelset-align="center"]
							li #[code panelset-align="end"]

			+apiOption("autoFocus: false | true | 'heading' | 'first' | 'input'")
				p Move focus into the incoming panel once it’s active, so keyboard and screen-reader users land in the new content instead of back on the tab they just left.
				ul
					li #[code false]: no focus movement
					li #[code true]: focus the panel element itself
					li #[code 'heading']: first h1-h6 in the panel
					li #[code 'first']: first focusable element (keyboard events only)
					li #[code 'input']: first form field (bypasses keyboard-only check)

				p Most specific wins: #[code show()] call -&gt; trigger attribute -&gt; element attribute -&gt; JS config.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { autoFocus: false }]
							li #[code { autoFocus: true }]
							li #[code { autoFocus: 'heading' }]
							li #[code { autoFocus: 'first' }]
							li #[code { autoFocus: 'input' }]
					.card
						h4 Data attribute
						p On the PanelSet element (default for all activations):
						ul
							li #[code data-auto-focus="heading"]
							li #[code data-auto-focus="first"]
							li #[code data-auto-focus="input"]
						p On a trigger button (overrides the element default for that activation):
						ul
							li #[code &lt;button aria-controls="..." data-auto-focus="input"&gt;]
					.card
						h4 Web Component attribute
						p On the #[code &lt;ps-panelset&gt;] element:
						ul
							li #[code auto-focus="heading"]
						p Per-trigger override works the same way: #[code data-auto-focus] on the button.

			+apiOption("closable: boolean")
				p Lets the whole PanelSet collapse to nothing (height: 0) and open again, not just switch between panels. Use #[code open()], #[code close()], and #[code toggle()] to control it.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { closable: true }]
							li #[code { closable: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-closable]
					.card
						h4 Web Component attribute
						ul
							li #[code closable]

			+apiOption("closeOnTab: boolean")
				p Needs #[code closable: true]. Click the active tab and the whole set closes; click any tab while it’s closed and it opens. Click a #[em different] tab and it switches to that panel first, then opens. 

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { closable: true, closeOnTab: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-close-on-tab]
					.card
						h4 Web Component attribute
						ul
							li #[code close-on-tab]

			+apiOption("levels: boolean")
				p Give panels a sense of depth from their DOM order: a later panel is "higher". Forward slides one way and back the other, with #[code .levelup] / #[code .leveldown] classes added so your CSS can flip the transform for backward moves.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { levels: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-levels]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-levels]

			+apiOption("loop: boolean")
				p Let #[code next()] / #[code prev()] wrap instead of stopping at the ends: past the last panel you’re back at the first, and the other way round. With loop on there’s nowhere unreachable, so PanelSet never disables its #[code data-ps-next] / #[code data-ps-prev] buttons. Carousel territory (see the #[a(href="/panelset/examples/wizard.html") Wizard] page).

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loop: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-loop]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-loop]

			+apiOption("disabledMode: 'aria' | 'native'")
				p How PanelSet switches off its own #[code data-ps-next] / #[code data-ps-prev] buttons at the ends of the range (only relevant when loop is off). #[code 'aria'] sets #[code aria-disabled] and leaves the native #[code disabled] attribute to you. The button keeps focus, so a screen reader can still announce why it’s dead. #[code 'native'] sets the real disabled attribute (PanelSet owns it from then on) and moves focus away first. Tab-strip locking ignores all this and always uses aria.

				h4 Default: #[code 'aria']

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { disabledMode: 'native' }]
					.card
						h4 Data attribute
						ul
							li #[code data-ps-disabled-mode="native"]
					.card
						h4 Web Component attribute
						ul
							li #[code ps-disabled-mode="native"]

			+apiOption("debug: boolean")
				p Log every activation to the console. Handy when something’s switching that shouldn’t be, quiet the rest of the time.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { debug: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-debug]
					.card
						h4 Web Component attribute
						ul
							li #[code debug]

			+apiOption("manageLabels: boolean")
				p Link each panel back to the trigger that controls it with #[code aria-labelledby] (generating a trigger #[code id] when one is missing), so a screen reader announces the panel by its tab’s text. Runs at init and on #[code refresh()]; never overrides an existing #[code aria-label] / #[code aria-labelledby]; and only acts when exactly one trigger controls the panel. Set to #[code false] if you prefer to do the labelling yourself.

				h4 Default: #[code true]
				
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { manageLabels: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-manage-labels="false"]
					.card
						h4 Web Component attribute
						ul
							li #[code manage-labels="false"]

			+apiOption("interruptible: boolean")

				p Leave it on. With it off, any activation that arrives mid-transition or mid-load is dropped: likely the one that has to finish first. That’s rarely what a user wants, but some flows genuinely need to force one step at a time, and this is the switch for those.

				h4 Default: #[code true]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { interruptible: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-interruptible="false"]
					.card
						h4 Web Component attribute
						ul
							li #[code interruptible="false"]

			+apiOption("loadingDelay: number")
				p How long to wait before showing the spinner. On a fast connection the content usually wins the race, so you never see a spinner you didn’t need.

				h4 Default: #[code 320]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loadingDelay: 320 }]
					.card
						h4 Data attribute
						ul
							li #[code data-loading-delay="320"]
					.card
						h4 Web Component attribute
						ul
							li #[code loading-delay="320"]

			+apiOption("loadingHeight: number")

				p The height to hold, in pixels, while async content loads and there’s no previous panel (or larger previous panel) to borrow a size from. Somewhere for the spinner to live until the real content turns up.

				h4 Default: #[code 150]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { loadingHeight: 200 }]
					.card
						h4 Data attribute
						ul
							li #[code data-loading-height="200"]
					.card
						h4 Web Component attribute
						ul
							li #[code loading-height="200"]

			+apiOption("manageTriggers: boolean")

				p With it off, PanelSet stops touching your triggers: no #[code aria-selected] updates, no #[code is-activating] class, and #[code data-auto-focus] on triggers is ignored. That’s for wrapper libraries that manage their own trigger state and drive PanelSet purely through #[code show()]. On your own, leave it on.

				h4 Default: #[code true]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { manageTriggers: false }]
					.card
						h4 Data attribute
						ul
							li #[code data-manage-triggers="false"]
					.card
						h4 Web Component attribute
						ul
							li #[code manage-triggers="false"]

			+apiOption("persist: boolean")
				p Write the active panel’s ID to #[code localStorage] on every switch, and restore it on the next load. The set comes back the way the user left it.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { persist: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-panel-persist]
					.card
						h4 Web Component attribute
						ul
							li #[code panel-persist]
				p Needs an #[code id] on the container, or there’s nothing to key the storage on.

			+apiOption("deepLink: boolean")
				p Keep the #[code ?panel=] URL param in sync as panels switch (via #[code history.replaceState], so no new history entries pile up). The address bar then always points at the current tab, ready to copy and share. Reading the param on load happens regardless. #[code deepLink] only decides whether activation writes back to it. Want shareable URLs and localStorage restore? Turn on #[code persist] and #[code deepLink] together.

				h4 Default: #[code false]

				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { deepLink: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-panel-deeplink]
					.card
						h4 Web Component attribute
						ul
							li #[code panel-deeplink]
	
			+apiOption("returnFocus: boolean")
				p When the set closes, send focus back to whatever opened it, so the keyboard user picks up where they were instead of at the top of the document.
				h4 Default: #[code false]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { returnFocus: true }]
					.card
						h4 Data attribute
						ul
							li #[code data-return-focus]
					.card
						h4 Web Component attribute
						ul
							li #[code return-focus]

			+apiOption("transitions: boolean | { height: boolean, panels: boolean }")
				p Turn transitions on or off. Pass an object instead of a boolean to control the height animation and the panel fades separately.
				h4 Default: #[code true]
				.card-row
					.card
						h4 JavaScript
						ul
							li #[code { transitions: true }]: all transitions on
							li #[code { transitions: false }]: all transitions off
							li #[code { transitions: { height : false } }]: height only off
							li #[code { transitions: { panels : false } }]: panel fades only off
					.card
						h4 Data attribute
						ul
							li #[code data-transitions="false"]
							li #[code data-transitions='{"height" : false}']
					.card
						h4 Web Component attribute
						ul
							li #[code transitions="false"]
							li #[code transitions='{"height" : false}']

	+section("CSS variables")
		p Transitions are controlled by CSS custom properties set on the element or any ancestor. All timing values must include a unit (#[code 0s] not #[code 0]). 

		p These same variables apply when using #[code &lt;ps-panelset&gt;]. Set them on the element directly or via CSS targeting #[code ps-panelset].

		+codeblock('CSS').
			[data-panelset] {
				/* Panel transitions */
				--ps-panel-out-speed:          0.25s;
				--ps-panel-out-timing:         ease-in;
				--ps-panel-in-speed:           0.25s;
				--ps-panel-in-timing:          ease-in-out;
				--ps-panel-in-delay:           0.25s;

				/* Container height animation */
				--ps-transition-timing:      ease-in-out;   /* tab-switch height */
				--ps-height-duration-ratio:  1;             /* height duration = panel-out-speed × ratio */
				--ps-open-speed:             0.25s;
				--ps-open-timing:            ease-in-out;
				--ps-close-speed:            0.25s;
				--ps-close-timing:           ease-in-out;

				/* Loading spinner */
				--ps-spinner-size:           40px;
				--ps-spinner-thickness:      4px;
				--ps-spinner-track-color:    rgba(0, 0, 0, 0.1);
				--ps-spinner-color:          rgba(0, 100, 255, 0.8);
				--ps-spinner-speed:          0.8s;
			}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			Panel.init();
	else
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init();
