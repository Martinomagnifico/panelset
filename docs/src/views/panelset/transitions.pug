extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Transitions"

block content
	.lane
		.container
			.page-header
				h1 PanelSet transitions
				p.lead PanelSet uses only CSS transitions only.




	+section("Transitionable elements")

		svg(xmlns="http://www.w3.org/2000/svg", width="340", height="340", fill="none", viewBox="0 0 340 340")
			path(stroke="var(--special-normal)", stroke-linejoin="round", stroke-width="3", d="M110 171h140v98H110z", opacity=".2")
			path(fill="var(--special-normal)", fill-opacity=".2", stroke="var(--special-normal)", stroke-width="3", d="M90 151h140v140H90z")
			path(stroke="var(--special-normal)", stroke-linejoin="round", stroke-width="3", d="M100 161h140v170H100z", opacity=".2")
			path(stroke="var(--btn-plain-text)", stroke-dasharray="4 4", stroke-linejoin="round", d="M80 141h180v160H80z")
			rect(width="210", height="190", x="65", y="126", stroke="var(--btn-plain-text)", stroke-linejoin="round", stroke-width="4", rx="16")
			path(fill="var(--text-default)", d="M64.5 209.3a8 8 0 1 0 0 16 8 8 0 0 0 0-16zM32 25.4a1.5 1.5 0 1 0-3 0h3zm-1.5 191.8H29c0 .8.7 1.4 1.5 1.4v-1.4zm34 0v-1.6h-34v3h34v-1.4zm-34 0H32V25.4h-3v191.8h1.5zM160 209.3a8 8 0 1 0 0 16 8 8 0 0 0 0-16zM317.5 102a1.5 1.5 0 0 0-3 0h3zM316 217.3v1.4a1.5 1.5 0 0 0 1.5-1.4H316zm-156 0v1.4h156v-3H160v1.6zm156 0h1.5V102h-3v115.3h1.5zM113.5 133a8 8 0 1 0 0 16 8 8 0 0 0 0-16zm1.5-71a1.5 1.5 0 1 0-3 0h3zm-1.5 79h1.5V62h-3v79h1.5z")

			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="24", y="15.9") Container (data-panels)
			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="86", y="53.9") Wrapper (.panel-wrapper)
			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="167", y="91.9") Panel (role="tabpanel")


	
	+section("1. Container")

		p The container is the #[code [data-panelset]] (or #[code [data-panel]]) box. It animates its #[strong height] to fit the active panel while switching, and (when #[code closable]) opens and closes as a whole.

		.column.gap-1(data-panel-group data-panel-close-siblings data-panel-persist)

			+collapse('h3', "Transitioning height")
				
				p During a tab switch the container animates its height so panels of different sizes don’t jump. The duration is derived from the panel speed. This is the default behaviour and can’t really be changed. But you can speed it up or slow it down relative to the panel transition with #[code --ps-height-duration-ratio], and change the easing with #[code --ps-transition-timing].

				dl.bg-surface-tint
					dt #[code --ps-height-duration-ratio]
					dd Multiplier on the height transition duration. This is relative to the total transition time of the inner panels. When you want these inner panels to transition after each other, the in-transition of the second panel can be delayed instead of happening at the same time as the out-transition of the first panel. If so, the delay time is added to the in-transition time of that second panel, and that is the total time for the inner transition, and normally, the height transition uses that exact time, but you can speed it up or down. Default: #[code 1].

					dt #[code --ps-transition-timing]
					dd Easing for the height change during a switch. Default: #[code ease-in-out].

				+codeblock('CSS').
					[data-panelset] {
						--ps-height-duration-ratio: 1;
						--ps-transition-timing: ease-in-out;
					}

			+collapse('h3', "Transitioning opening &amp; closing (closable)")
			
				p With #[code closable: true] the container collapses and expands as a whole. These control that height animation.

				dl.bg-surface-tint
					dt #[code --ps-open-speed]
					dd Height transition duration when opening. Default: #[code 0.25s].

					dt #[code --ps-open-timing]
					dd Easing when opening. Default: #[code ease-in-out].

					dt #[code --ps-close-speed]
					dd Height transition duration when closing. Default: #[code 0.25s].

					dt #[code --ps-close-timing]
					dd Easing when closing. Default: #[code ease-in-out].

				h4 Demo
				p Click a tab to open the set; click the active tab to close it. This demo is #[code closable] with #[code closeOnTab].

				.demo
					+exampletabset('opendemo')
					+examplepanelset('opendemo')(data-closable data-close-on-tab)

				+codeblock('CSS').
					[data-panelset] {
						--ps-open-speed:   0.25s;
						--ps-open-timing:  ease-in-out;
						--ps-close-speed:  0.25s;
						--ps-close-timing: ease-in-out;
					}

			+collapse('h3', "Transitioning extra transitions (closable)")

				p Use #[code --ps-open-transition-extra] and #[code --ps-close-transition-extra] to animate additional CSS properties alongside the height (for example a drop shadow or opacity). The value is appended to the #[code transition] shorthand directly. 

				dl.bg-surface-tint
					dt #[code --ps-open-transition-extra]
					dd Extra #[code transition] shorthand values appended when opening. Unset by default.

					dt #[code --ps-close-transition-extra]
					dd Same, applied when closing.

				h4 Demo

				.demo
					+exampletabset('borderdemo')
					+examplepanelset('borderdemo')(data-closable data-close-on-tab)

				+codeblock('CSS').
					#borderdemo {
						--ps-open-transition-extra:  box-shadow var(--ps-open-speed) ease-in;
						--ps-close-transition-extra: box-shadow var(--ps-close-speed) ease-out;
						box-shadow: inset 0 0 0 6px yellow, 0 0 0 rgba(0,0,0,0.2);
					}
					#borderdemo.is-open,
					#borderdemo.is-opening {
						box-shadow: inset 0 0 0 6px green, 0 0 1rem rgba(0,0,0,0.2);
					}

	+section("2. Wrapper (for closable PanelSets)", "Wrapper")

		p The wrapper is the #[code .panel-wrapper] that holds your content. It fades in as the container opens (and out as it closes). This applies to a Panel and to a closable PanelSet.

		.column.gap-1(data-panel-persist)

			+collapse('h3', "Transition the transform")
		
				p Set #[code --ps-wrapper-transform-from] to move the wrapper as it appears. It animates from that transform to #[code none] on open and back on close, sharing the #[code --ps-open-*] / #[code --ps-close-*] timing. Default #[code none] is a pure fade.

				p Open and close transforms on the wrapper can also have independent delays, both #[code 0s] by default. Set #[code --ps-wrapper-open-delay] to hold the content back until the box has grown a little (a common refinement), and #[code --ps-wrapper-close-delay] if you want the content to linger before collapsing.

				dl.bg-surface-tint
					dt #[code --ps-wrapper-transform-from]
					dd Transform the wrapper reveals from, settling at #[code none]; reverses on close. Any transform. Default: #[code none].

					dt #[code --ps-wrapper-open-delay]
					dd Delay before the wrapper reveals when opening. Default: #[code 0s]. (Legacy alias: #[code --ps-wrapper-delay].)

					dt #[code --ps-wrapper-close-delay]
					dd Delay before the wrapper starts leaving when closing. Default: #[code 0s].

				h4 Demo
				.demo
					+exampletabset('wrapperdemo')
					+examplepanelset('wrapperdemo')(data-closable data-close-on-tab)


				+codeblock('CSS').
					#wrapperdemo {
						--ps-wrapper-transform-from: translateY(-1rem);
						--ps-wrapper-open-delay: 0.1s;
					}


	+section("3. Inner panels")

		p The panels are the #[code [role="tabpanel"]] elements. Switching fades the outgoing panel out and the incoming one in. Add a transform for slide / scale / flip, and enable #[code levels] for direction-aware motion.

		.column.gap-1(data-panel-group data-panel-close-siblings data-panel-persist)
			+collapse('h3', "Speed &amp; timing")
				p The incoming and outgoing panels each have their own speed and easing, plus a delay on the incoming side.

				dl.bg-surface-tint
					dt #[code --ps-panel-out-speed]
					dd Duration of the outgoing panel transition (opacity and transform). Default: #[code 0.25s].

					dt #[code --ps-panel-out-timing]
					dd Easing for the outgoing transition. Default: #[code ease-in].

					dt #[code --ps-panel-in-speed]
					dd Duration of the incoming panel transition (opacity and transform). Default: #[code 0.25s].

					dt #[code --ps-panel-in-timing]
					dd Easing for the incoming transition. Default: #[code ease-in-out].

					dt #[code --ps-panel-in-delay]
					dd Delay before the incoming panel starts. Default: #[code 0.25s].

				.demo
					+exampletabset('demo')
					+examplepanelset('demo')

				+codeblock('CSS').
					[data-panelset] {
						--ps-panel-out-speed:  0.25s;
						--ps-panel-out-timing: ease-in;
						--ps-panel-in-speed:   0.25s;
						--ps-panel-in-timing:  ease-in-out;
						--ps-panel-in-delay:   0.25s;
					}

				h4 Slower, sequential
				p Both speeds set to 1 second. Because #[code --ps-panel-in-delay] is also 1 second, the panels transition sequentially: the outgoing one fully fades out before the incoming one fades in. Total time: 2 seconds.


				.demo
					+exampletabset('slowdemo')
					+examplepanelset('slowdemo')

				+codeblock('CSS').
					#slowdemo {
						--ps-panel-out-speed: 1s;
						--ps-panel-in-speed:  1s;
						--ps-panel-in-delay:  1s;
					}

				h4 Crossfading
				p Setting #[code --ps-panel-in-delay: 0s] makes both panels transition simultaneously. Total time matches whichever side is longer.


				.demo
					+exampletabset('crossfade')
					+examplepanelset('crossfade')

				+codeblock('CSS').
					#crossfade {
						--ps-panel-out-speed: 2s;
						--ps-panel-in-speed:  2s;
						--ps-panel-in-delay:  0s;
					}

			+collapse('h3', "Transforms (slide, scale, flip)")

				p By default panels only fade. Give them movement by setting a transform: the incoming panel animates #[strong from] #[code --ps-panel-in-transform-from] to its resting #[code none], and the outgoing panel animates #[strong to] #[code --ps-panel-out-transform-to] from #[code none]. The values are full CSS transforms, so 2D or 3D both work, and the speed/timing variables above still control the timing.

				dl.bg-surface-tint
					dt #[code --ps-panel-in-transform-from]
					dd Transform the incoming panel animates #[em from] (it settles at #[code none]). Any transform: #[code translateX(100%)], #[code scale(0.9)], #[code rotateY(90deg)]. Default: #[code none].

					dt #[code --ps-panel-out-transform-to]
					dd Transform the outgoing panel animates #[em to] (starting from #[code none]). Default: #[code none].

				p The cleanest way to package an effect is a class of your own. Collect the variables under it and add the class to the panelset.


				.demo
					+exampletabset('slidedemo')
					+examplepanelset('slidedemo')(class="slide")

				+codeblock('CSS').
					.slide {
						--ps-panel-in-transform-from: translateX(100%);   /* enter from the right */
						--ps-panel-out-transform-to:  translateX(-100%);   /* exit to the left    */
					}

				p A few more, same two knobs:

				+codeblock('CSS').
					/* Scale + fade */
					.zoom {
						--ps-panel-in-transform-from: scale(0.92);
						--ps-panel-out-transform-to:  scale(1.08);
					}

					/* 3D card flip */
					.flip {
						--ps-panel-in-transform-from: perspective(800px) rotateY(90deg);
						--ps-panel-out-transform-to:  perspective(800px) rotateY(-90deg);
					}

			+collapse('h3', "Level-based direction")
				p With #[code levels] enabled, the slide direction follows the panels' order: moving to a later panel slides one way, moving back slides the other. The order is taken straight from the DOM (a later panel is "higher"), so you don’t set anything per panel. Just turn the feature on.

				p Enable it with #[code data-ps-levels] on the container or #[code levels: true] in the config. JS then adds #[code .levelup] or #[code .leveldown] to the panels as they switch. Backward navigation (#[code .leveldown]) automatically #[strong swaps] #[code --ps-panel-in-transform-from] and #[code --ps-panel-out-transform-to] so the motion reverses. No extra variables, and it works for any transform.


				.demo
					+exampletabset('leveldemo')
					+examplepanelset('leveldemo')(class="slide" data-ps-levels)

				+codeblock('HTML')
					div(data-panelset data-ps-levels class="slide") …

				+codeblock('JavaScript').
					new PanelSet('#my-tabs', { levels: true });

				p Need a different look per direction? Target the classes yourself. They override the automatic swap.

				+codeblock('CSS').
					/* Custom: incoming always scales up, regardless of direction */
					.leveldown .incoming { transform: scale(0.9); }



	+section("Disabling transitions", "Disabling")
		p Pass #[code transitions: false] to skip all animation, or use an object to disable height and panel transitions independently.

		+codeblock('JavaScript').
			new PanelSet('#my-tabs', { transitions: false });             // all off
			new PanelSet('#my-tabs', { transitions: { height: false } }); // height only off
			new PanelSet('#my-tabs', { transitions: { panels: false } }); // panels only off

		p PanelSet respects #[code prefers-reduced-motion] automatically. If/when the user has requested reduced motion, all transitions are suppressed via CSS.


append styles
	style.
		#slowdemo {
			--ps-panel-out-speed: 1s;
			--ps-panel-in-speed:  1s;
			--ps-panel-in-delay:  1s;
		}
		#crossfade {
			--ps-panel-out-speed: 2s;
			--ps-panel-in-speed:  2s;
			--ps-panel-in-delay:  0s;
		}
		.slide {
			--ps-panel-out-speed: .3s;
			--ps-panel-in-speed:  .3s;

			--ps-panel-in-timing: ease-in-out; /* same easing */
			--ps-panel-out-timing: ease-in-out;/* same easing */

			--ps-panel-in-delay:  0s;  /* move both panels together */
			--ps-panel-in-transform-from: translateX(50%);
			--ps-panel-out-transform-to:  translateX(-50%);
			--ps-height-duration-ratio: 0.75;
		}

		/* Container + wrapper closable demos */
		#borderdemo {
			--ps-open-transition-extra:  box-shadow var(--ps-open-speed) ease-in;
			--ps-close-transition-extra: box-shadow var(--ps-close-speed) ease-out;

			background: var(--demo-btn-bg);
			border-radius: 0.5rem;
			box-shadow: inset 0 0 0 6px yellow, 0 0 0 rgba(0,0,0,0.2);

		}
		#borderdemo [role="tabpanel"] {
			padding: 1rem;
		}
		#borderdemo.is-open,
		#borderdemo.is-opening {
			box-shadow: inset 0 0 0 6px green, 0 0 1rem rgba(0,0,0,0.2);
		}
		#wrapperdemo {
			--ps-wrapper-transform-from: translateY(-1rem);
			--ps-wrapper-open-delay: 0.1s;
		}

append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
			Panel.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet, Panel } from 'panelset';
			PanelSet.init({ debug: true });
			Panel.init({ debug: true });