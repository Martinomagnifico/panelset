extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet — Transitions"

block content
	.lane
		.container
			.page-header
				h1 PanelSet transitions
				p.lead PanelSet uses only CSS transitions only.

	+section("CSS variables")
		p Set these on the #[code [data-panelset]] element or any ancestor. All values must include a unit (#[code 0s] not #[code 0]).

		+codeblock('CSS').
			[data-panelset] {
				/* Panel opacity fades */
				--ps-fadeout-speed:          0.25s;
				--ps-fadeout-timing:         ease-in;
				--ps-fadein-speed:           0.25s;
				--ps-fadein-timing:          ease-in-out;
				--ps-fadein-delay:           0.25s;

				/* Container height animation */
				--ps-height-duration-ratio:  1;        /* height duration = fadeout × ratio */
				--ps-transition-timing:      ease-in-out;

				/* Open/close (closable PanelSet only) */
				--ps-open-speed:             0.25s;
				--ps-open-timing:            ease-in-out;
				--ps-close-speed:            0.25s;
				--ps-close-timing:           ease-in-out;
				--ps-open-transition-extra:  /* none */;
				--ps-close-transition-extra: /* none */;
				--ps-open-wrapper-delay:     /* calc(0.5 * var(--ps-open-speed)) */;
			}

		dl.horizontal
			dt #[code --ps-fadeout-speed]
			dd Duration of the outgoing panel fade. Default: #[code 0.25s].

			dt #[code --ps-fadeout-timing]
			dd Easing for the fade-out. Default: #[code ease-in].

			dt #[code --ps-fadein-speed]
			dd Duration of the incoming panel fade. Default: #[code 0.25s].

			dt #[code --ps-fadein-timing]
			dd Easing for the fade-in. Default: #[code ease-in-out].

			dt #[code --ps-fadein-delay]
			dd Delay before the incoming panel starts fading in. Default: #[code 0.25s].

			dt #[code --ps-height-duration-ratio]
			dd Multiplier on the height transition duration relative to #[code --ps-fadeout-speed]. Default: #[code 1].

			dt #[code --ps-transition-timing]
			dd Easing for the height change during tab switching. Default: #[code ease-in-out].

			dt #[code --ps-open-speed]
			dd Height transition duration when opening a closable PanelSet. Default: #[code 0.25s].

			dt #[code --ps-open-timing]
			dd Easing when opening. Default: #[code ease-in-out].

			dt #[code --ps-close-speed]
			dd Height transition duration when closing. Default: #[code 0.25s].

			dt #[code --ps-close-timing]
			dd Easing when closing. Default: #[code ease-in-out].

			dt #[code --ps-open-transition-extra]
			dd Additional CSS transition shorthand values appended to the height transition when opening a closable PanelSet. Unset by default.

			dt #[code --ps-close-transition-extra]
			dd Same as above, applied during closing.

			dt #[code --ps-open-wrapper-delay]
			dd Delay before the inner #[code .panel-wrapper] fades in when opening. Default: #[code calc(0.5 * var(--ps-open-speed))] — half the open duration, so content appears after the height has made progress. Set to #[code 0s] for an immediate fade-in.

	+section("Default speed")
		.card
			.demo
				+exampletabset('demo')
				+examplepanelset('demo')

	+section("Slower transitions")
		p Both fade-out and fade-in set to 1 second. Because #[code --ps-fadein-delay] is also 1 second, the panels transition sequentially. The outgoing panel fully fades out before the incoming one fades in. Total time: 2 seconds.

		.card
			.demo
				+exampletabset('slowdemo')
				+examplepanelset('slowdemo')

			+codeblock('CSS').
				#slowdemo {
					--ps-fadeout-speed: 1s;
					--ps-fadein-speed:  1s;
					--ps-fadein-delay:  1s;
				}

	+section("Crossfading")
		p Setting #[code --ps-fadein-delay: 0s] makes both panels fade simultaneously, creating a crossfade. Total time matches whichever fade is longer.

		.card
			.demo
				+exampletabset('crossfade')
				+examplepanelset('crossfade')

			+codeblock('CSS').
				#crossfade {
					--ps-fadeout-speed: 2s;
					--ps-fadein-speed:  2s;
					--ps-fadein-delay:  0s;
				}

	+section("Extra transitions (closable)")
		p When a PanelSet has #[code closable: true], use #[code --ps-open-transition-extra] and #[code --ps-close-transition-extra] to animate additional CSS properties alongside the height — for example a drop shadow or opacity. The value is appended to the #[code transition] shorthand directly.

		p Use #[code --ps-open-wrapper-delay] to control when the inner content fades in. The default waits half the open duration so content appears after the container has already made progress. Set it to #[code 0s] if you want an immediate fade-in.

		+codeblock('CSS').
			#my-panelset {
				box-shadow: 0 0 0 rgba(0, 0, 0, 0);

				--ps-open-transition-extra:  box-shadow var(--ps-open-speed) var(--ps-open-timing);
				--ps-close-transition-extra: box-shadow var(--ps-close-speed) var(--ps-close-timing);
				--ps-open-wrapper-delay: 0s; /* fade content in immediately */
			}

			#my-panelset.is-open,
			#my-panelset.is-opening {
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
			}

	+section("Disabling transitions")
		p Pass #[code transitions: false] to skip all animation, or use an object to disable height and panel fades independently.

		+codeblock('JavaScript').
			new PanelSet('#my-tabs', { transitions: false });             // all off
			new PanelSet('#my-tabs', { transitions: { height: false } }); // height only off
			new PanelSet('#my-tabs', { transitions: { panels: false } }); // fades only off

		p PanelSet respects #[code prefers-reduced-motion] automatically. If/when the user has requested reduced motion, all transitions are suppressed via CSS.


append styles
	style.
		#slowdemo {
			--ps-fadeout-speed: 1s;
			--ps-fadein-speed:  1s;
			--ps-fadein-delay:  1s;
		}
		#crossfade {
			--ps-fadeout-speed: 2s;
			--ps-fadein-speed:  2s;
			--ps-fadein-delay:  0s;
		}

append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
