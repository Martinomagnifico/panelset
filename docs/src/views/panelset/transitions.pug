extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet — Transitions"

block content
	.lane
		.container
			.page-header
				h1 PanelSet transitions
				p.lead PanelSet uses only CSS transitions only.

	+section("Transitionable elements")

		ol
			li: h3 The container 
			li: h3 The wrapper 
			li: h3 The panels


	




		svg(xmlns="http://www.w3.org/2000/svg", width="340", height="340", fill="none", viewBox="0 0 340 340")
			path(stroke="var(--special-normal)", stroke-linejoin="round", stroke-width="3", d="M110 171h140v98H110z", opacity=".2")
			path(fill="var(--special-normal)", fill-opacity=".2", stroke="var(--special-normal)", stroke-width="3", d="M90 151h140v140H90z")
			path(stroke="var(--special-normal)", stroke-linejoin="round", stroke-width="3", d="M100 161h140v170H100z", opacity=".2")
			path(stroke="var(--btn-plain-text)", stroke-dasharray="4 4", stroke-linejoin="round", d="M80 141h180v160H80z")
			rect(width="210", height="190", x="65", y="126", stroke="var(--btn-plain-text)", stroke-linejoin="round", stroke-width="4", rx="16")
			path(fill="var(--text-default)", d="M64.5 209.3a8 8 0 1 0 0 16 8 8 0 0 0 0-16zM32 25.4a1.5 1.5 0 1 0-3 0h3zm-1.5 191.8H29c0 .8.7 1.4 1.5 1.4v-1.4zm34 0v-1.6h-34v3h34v-1.4zm-34 0H32V25.4h-3v191.8h1.5zM160 209.3a8 8 0 1 0 0 16 8 8 0 0 0 0-16zM317.5 102a1.5 1.5 0 0 0-3 0h3zM316 217.3v1.4a1.5 1.5 0 0 0 1.5-1.4H316zm-156 0v1.4h156v-3H160v1.6zm156 0h1.5V102h-3v115.3h1.5zM113.5 133a8 8 0 1 0 0 16 8 8 0 0 0 0-16zm1.5-71a1.5 1.5 0 1 0-3 0h3zm-1.5 79h1.5V62h-3v79h1.5z")

			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="24", y="15.9") 1. Container (data-panels)
			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="86", y="53.9") 2. Wrapper (.panel-wrapper)
			text(fill="var(--text-default)", style="white-space:pre", font-family="Source Sans 3", font-size="1rem", letter-spacing="0em")
				tspan(x="167", y="91.9") 3. Panel (role="tabpanel")





	+section("CSS variables")
		p Set these on the #[code [data-panelset]] element or any ancestor. All values must include a unit (#[code 0s] not #[code 0]).

		+codeblock('CSS').
			[data-panelset] {
				/* Panel switching — fade timing */
				--ps-fadeout-speed:          0.25s;
				--ps-fadeout-timing:         ease-in;
				--ps-fadein-speed:           0.25s;
				--ps-fadein-timing:          ease-in-out;
				--ps-fadein-delay:           0.25s;

				/* Panel switching — transform (default none = pure fade) */
				--ps-panel-in-from:          none;  /* incoming starts here → none */
				--ps-panel-out-to:           none;  /* outgoing ends here   ← none */

				/* Container height animation */
				--ps-height-duration-ratio:  1;        /* height duration = fadeout × ratio */
				--ps-transition-timing:      ease-in-out;

				/* Open/close (closable PanelSet only) */
				--ps-open-speed:             0.25s;
				--ps-open-timing:            ease-in-out;
				--ps-close-speed:            0.25s;
				--ps-close-timing:           ease-in-out;
				--ps-open-transition-extra:  /* none */;
				--ps-close-transition-extra: /* none */;
				--ps-open-wrapper-delay:     /* calc(0.5 * var(--ps-open-speed)) */;
				--ps-open-wrapper-from:      none;  /* wrapper reveal transform */
			}

		dl.horizontal
			dt #[code --ps-fadeout-speed]
			dd Duration of the outgoing panel fade. Default: #[code 0.25s].

			dt #[code --ps-fadeout-timing]
			dd Easing for the fade-out. Default: #[code ease-in].

			dt #[code --ps-fadein-speed]
			dd Duration of the incoming panel fade. Default: #[code 0.25s].

			dt #[code --ps-fadein-timing]
			dd Easing for the fade-in. Default: #[code ease-in-out].

			dt #[code --ps-fadein-delay]
			dd Delay before the incoming panel starts fading in. Default: #[code 0.25s].

			dt #[code --ps-panel-in-from]
			dd Transform the incoming panel animates #[em from] (it settles at #[code none]). Any transform — #[code translateX(100%)], #[code scale(0.9)], #[code rotateY(90deg)]. Default: #[code none] (pure fade).

			dt #[code --ps-panel-out-to]
			dd Transform the outgoing panel animates #[em to] (starting from #[code none]). Default: #[code none].

			dt #[code --ps-open-wrapper-from]
			dd Transform the inner #[code .panel-wrapper] reveals from when opening (Panel or closable PanelSet), settling at #[code none]; reverses on close. Default: #[code none].

			dt #[code --ps-height-duration-ratio]
			dd Multiplier on the height transition duration relative to #[code --ps-fadeout-speed]. Default: #[code 1].

			dt #[code --ps-transition-timing]
			dd Easing for the height change during tab switching. Default: #[code ease-in-out].

			dt #[code --ps-open-speed]
			dd Height transition duration when opening a closable PanelSet. Default: #[code 0.25s].

			dt #[code --ps-open-timing]
			dd Easing when opening. Default: #[code ease-in-out].

			dt #[code --ps-close-speed]
			dd Height transition duration when closing. Default: #[code 0.25s].

			dt #[code --ps-close-timing]
			dd Easing when closing. Default: #[code ease-in-out].

			dt #[code --ps-open-transition-extra]
			dd Additional CSS transition shorthand values appended to the height transition when opening a closable PanelSet. Unset by default.

			dt #[code --ps-close-transition-extra]
			dd Same as above, applied during closing.

			dt #[code --ps-open-wrapper-delay]
			dd Delay before the inner #[code .panel-wrapper] fades in when opening. Default: #[code calc(0.5 * var(--ps-open-speed))] — half the open duration, so content appears after the height has made progress. Set to #[code 0s] for an immediate fade-in.

	+section("Default speed")
		.card
			.demo
				+exampletabset('demo')
				+examplepanelset('demo')

	+section("Slower transitions")
		p Both fade-out and fade-in set to 1 second. Because #[code --ps-fadein-delay] is also 1 second, the panels transition sequentially. The outgoing panel fully fades out before the incoming one fades in. Total time: 2 seconds.

		.card
			.demo
				+exampletabset('slowdemo')
				+examplepanelset('slowdemo')

			+codeblock('CSS').
				#slowdemo {
					--ps-fadeout-speed: 1s;
					--ps-fadein-speed:  1s;
					--ps-fadein-delay:  1s;
				}

	+section("Crossfading")
		p Setting #[code --ps-fadein-delay: 0s] makes both panels fade simultaneously, creating a crossfade. Total time matches whichever fade is longer.

		.card
			.demo
				+exampletabset('crossfade')
				+examplepanelset('crossfade')

			+codeblock('CSS').
				#crossfade {
					--ps-fadeout-speed: 2s;
					--ps-fadein-speed:  2s;
					--ps-fadein-delay:  0s;
				}

	+section("Panel transforms (slide, scale, flip)")
		p By default panels only fade. Give them movement by setting a transform: the incoming panel animates #[strong from] #[code --ps-panel-in-from] to its resting #[code none], and the outgoing panel animates #[strong to] #[code --ps-panel-out-to] from #[code none]. The values are full CSS transforms, so 2D or 3D both work, and the existing #[code --ps-fade*] variables still control the timing.

		p The cleanest way to package an effect is a class of your own — collect the variables under it and add the class to the panelset.

		.card
			.demo
				+exampletabset('slidedemo')
				+examplepanelset('slidedemo')(class="slide")

			+codeblock('CSS').
				.slide {
					--ps-panel-in-from: translateX(100%);   /* enter from the right */
					--ps-panel-out-to:  translateX(-100%);   /* exit to the left    */
				}

		p A few more, same two knobs:

		+codeblock('CSS').
			/* Scale + fade */
			.zoom {
				--ps-panel-in-from: scale(0.92);
				--ps-panel-out-to:  scale(1.08);
			}

			/* 3D card flip */
			.flip {
				--ps-panel-in-from: perspective(800px) rotateY(90deg);
				--ps-panel-out-to:  perspective(800px) rotateY(-90deg);
			}

	+section("Level-based direction")
		p With #[code levels] enabled, the slide direction follows the panels' order: moving to a later panel slides one way, moving back slides the other. The order is taken straight from the DOM (a later panel is "higher"), so you don't set anything per panel — just turn the feature on.

		p Enable it with #[code data-ps-levels] on the container or #[code levels: true] in the config. JS then adds #[code .levelup] or #[code .leveldown] to the panels as they switch. Backward navigation (#[code .leveldown]) automatically #[strong swaps] #[code --ps-panel-in-from] and #[code --ps-panel-out-to] so the motion reverses — no extra variables, and it works for any transform.

		.card
			.demo
				+exampletabset('leveldemo')
				+examplepanelset('leveldemo')(class="slide" data-ps-levels)

		+codeblock('HTML').
			<div data-panelset data-ps-levels class="slide"> … </div>

		+codeblock('JavaScript').
			new PanelSet('#my-tabs', { levels: true });

		p Need a different look per direction? Target the classes yourself — they override the automatic swap.

		+codeblock('CSS').
			/* Custom: incoming always scales up, regardless of direction */
			.leveldown .incoming { transform: scale(0.9); }

	+section("Wrapper reveal transform")
		p For a Panel (or a closable PanelSet), the inner #[code .panel-wrapper] fades in as the container opens. Set #[code --ps-open-wrapper-from] to also move it — it animates from that transform to #[code none] on open and back on close, sharing the #[code --ps-open-*] / #[code --ps-close-*] timing.

		+codeblock('CSS').
			#my-panel {
				--ps-open-wrapper-from: translateY(-0.5rem);  /* content drops in */
			}

	+section("Extra transitions (closable)")
		p When a PanelSet has #[code closable: true], use #[code --ps-open-transition-extra] and #[code --ps-close-transition-extra] to animate additional CSS properties alongside the height — for example a drop shadow or opacity. The value is appended to the #[code transition] shorthand directly.

		p Use #[code --ps-open-wrapper-delay] to control when the inner content fades in. The default waits half the open duration so content appears after the container has already made progress. Set it to #[code 0s] if you want an immediate fade-in.

		+codeblock('CSS').
			#my-panelset {
				box-shadow: 0 0 0 rgba(0, 0, 0, 0);

				--ps-open-transition-extra:  box-shadow var(--ps-open-speed) var(--ps-open-timing);
				--ps-close-transition-extra: box-shadow var(--ps-close-speed) var(--ps-close-timing);
				--ps-open-wrapper-delay: 0s; /* fade content in immediately */
			}

			#my-panelset.is-open,
			#my-panelset.is-opening {
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
			}

	+section("Disabling transitions")
		p Pass #[code transitions: false] to skip all animation, or use an object to disable height and panel fades independently.

		+codeblock('JavaScript').
			new PanelSet('#my-tabs', { transitions: false });             // all off
			new PanelSet('#my-tabs', { transitions: { height: false } }); // height only off
			new PanelSet('#my-tabs', { transitions: { panels: false } }); // fades only off

		p PanelSet respects #[code prefers-reduced-motion] automatically. If/when the user has requested reduced motion, all transitions are suppressed via CSS.


append styles
	style.
		#slowdemo {
			--ps-fadeout-speed: 1s;
			--ps-fadein-speed:  1s;
			--ps-fadein-delay:  1s;
		}
		#crossfade {
			--ps-fadeout-speed: 2s;
			--ps-fadein-speed:  2s;
			--ps-fadein-delay:  0s;
		}
		.slide {
			--ps-fadeout-speed: .3s;
			--ps-fadein-speed:  .3s;

			--ps-fadein-timing: ease-in-out; /* same easing */
			--ps-fadeout-timing: ease-in-out;/* same easing */

			--ps-fadein-delay:  0s;  /* move both panels together */
			--ps-panel-in-from: translateX(50%);
			--ps-panel-out-to:  translateX(-50%);
			--ps-height-duration-ratio: 0.75;
		}

append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example.js` vite-ignore)
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module" src="/src/assets/scripts/example.js")
		script(type="module").
			import { PanelSet } from 'panelset';
			PanelSet.init({ debug: true });
