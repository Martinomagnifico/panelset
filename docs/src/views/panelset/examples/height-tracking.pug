extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Examples | Height tracking"


block content
	.lane
		.container
			.page-header
				h1=pagetitle
				p.lead Keeping track of the highest panel

	+section("Live demo")

		.card
			h4 Tracking off
			.demo.largeparent
				.tabinterface
					+exampletabset('notracking', true)
					+examplepanelset('notracking').tab-content

			h4 Tracking on
			.demo.largeparent
				.tabinterface
					+exampletabset('demo', true)
					div(data-panelset-trackheight)
						+examplepanelset('demo').tab-content


			p In this demo, we position the panelset and a row of buttons inside a centered interface. The first example doesn’t have tracking enabled, so you can see how the interface height changes as you switch panels, #[strong which might be annoying to use, because the tab buttons move away from the cursor]. The second example has tracking enabled, so the interface height stays consistent.
			.callout 
				+warning()
				p #[strong Note]: the max height (or the height/min-height of your container) is determined by the tallest panel, so if you have a lot of content in one panel, it will make the entire interface taller. Use this option when you want to avoid any height changes, but be mindful of resulting panels with empty space under it.




	+section("How to use it")
		p To enable height tracking, simply add the #[code data-panelset-trackheight] attribute to any parent container of the #[code data-panelset] element. This will make PanelSet calculate the tallest panel and add a CSS variable #[code --ps-max-height] on that parent container. You need to use that variable yourself in your styling, either as a height or min-height to see the effect:

		+codeblock('CSS').
			[data-panelset-trackheight] {
				height: var(--ps-max-height);
			}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module").
			import PanelSet from 'panelset';
			PanelSet.init({debug: true });


	script.
		const tabs = document.querySelectorAll('[role="tab"]');
		
		document.addEventListener('click', (e) => {
			const button = e.target.closest('button');
			if (!button) return;

			if (button.hasAttribute('aria-controls')) {
				const panelId = button.getAttribute('aria-controls');
				const panel = document.getElementById(panelId);
				const container = panel?.closest('[data-panelset]');
				
				if (container?.panelSet) {
					container.panelSet.show(panelId, true, { trigger: button });
				}
			}
		});

		// Update ARIA states. Scoped to the panelset that fired the event
		document.addEventListener('ps:activationstart', (e) => {
			const panelset = e.target;
			tabs.forEach(tab => {
				const panel = document.getElementById(tab.getAttribute('aria-controls'));
				if (panel?.closest('[data-panelset]') !== panelset) return;
				tab.setAttribute('aria-selected', tab.getAttribute('aria-controls') === e.detail.panelId);
			});
		});



append styles
	style.
		.largeparent {
			min-height: 400px;
			display: flex;
			flex-direction: column;
			padding: 1rem;
			align-items: center;
			justify-content: center;
		}

		.tabinterface {
			width: min(100%, 500px);
		}
		[data-panelset-trackheight] {
			height: var(--ps-max-height);
		}