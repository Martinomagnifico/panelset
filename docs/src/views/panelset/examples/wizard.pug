extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet | Examples | Wizard"

block content
	.lane
		.container
			.page-header
				h1 Wizard
				p.lead A multi-step flow driven by Next / Previous instead of tabs.

	+section("Live demo")
		p A PanelSet does not have to be driven by buttons that link directly to certain panels. Here #[code show()] is called from #[strong Next] and #[strong Previous] buttons that step through the panels in DOM order. With #[code data-ps-levels] enabled, moving forward slides one way and back the other, so the direction matches the action.

		.card

			p This example uses #[strong height tracking] so the frame stays as tall as the tallest step and the Previous / Next buttons keep their place. If you would rather let the box grow and shrink per step, leave it out. See #[a(href=url('/panelset/examples/height-tracking.html')) Height tracking].

			.demo
				.wizard-frame(data-panelset-trackheight)
					#wizard.tab-content(data-panelset data-ps-levels)
						.panel-wrapper
							.active#wizard-step-1(role="tabpanel" aria-label="Step 1")
								h3 Step 1. Account
								p Create your account to get started. This first step is deliberately short, so the height change to the next step is obvious.

							#wizard-step-2(role="tabpanel" hidden aria-label="Step 2")
								h3 Step 2. Profile
								p Tell us about yourself. We will keep your info in a database and sell it to the highest bidder. Moving forward slides the next step in from the right while the container animates its height to fit this longer content. There could have been some bullet points in here…

							#wizard-step-3(role="tabpanel" hidden aria-label="Step 3")
								h3 Step 3. Confirm
								p Review and confirm. Moving back slides the other way, and the height animates down again.

				.wizard-nav
					button.secondary(data-ps-prev="#wizard" data-ps-disabled-hint="wiz-prev-hint") Previous
					button(data-ps-next="#wizard" data-ps-disabled-hint="wiz-next-hint") Next
				span#wiz-prev-hint(hidden) You’re on the first step.
				span#wiz-next-hint(hidden) You’re on the last step.

			h4 Markup
			+codeblock('HTML')
				#wizard(data-panelset data-ps-levels)
					.panel-wrapper
						#wizard-step-1.active(role="tabpanel") ...
						#wizard-step-2(role="tabpanel" hidden) ...
						#wizard-step-3(role="tabpanel" hidden) ...
				+n
				.wizard-nav
					button(data-ps-prev="#wizard") Previous
					button(data-ps-next="#wizard") Next




			h3 Previous and next buttons
			p Add #[code data-ps-prev] / #[code data-ps-next] to the buttons and PanelSet connects them to #[code prev()] / #[code next()] (no stepping logic of your own). The nav sits outside the set here, so the attribute names the set it drives:

			+codeblock('HTML')
				.wizard-nav
					button(data-ps-prev="#wizard") Previous
					button(data-ps-next="#wizard") Next

			h3 Disabling the buttons at the ends
			p With #[code loop] off, PanelSet reflects end-of-range onto these buttons as #[code aria-disabled]: #[code data-ps-prev] at the first panel, #[code data-ps-next] at the last. It uses #[code aria-disabled] rather than the native #[code disabled], so the button stays focusable and no focus juggling is needed; just style the state:

			+codeblock('CSS').
				[data-ps-prev][aria-disabled="true"],
				[data-ps-next][aria-disabled="true"] { opacity: 0.4; cursor: not-allowed; }

			p Because #[code aria-disabled] keeps the button #[strong focusable], a keyboard or screen-reader user can land on it, so tell them #[em why]. Point #[code data-ps-disabled-hint] at a hidden element and PanelSet adds it to the button’s #[code aria-describedby] only while the button is disabled:

			+codeblock('HTML')
				.wizard-nav
					button(data-ps-prev="#wizard" data-ps-disabled-hint="wiz-prev-hint") Previous
					button(data-ps-next="#wizard" data-ps-disabled-hint="wiz-next-hint") Next
				span#wiz-prev-hint(hidden) You’re on the first step.
				span#wiz-next-hint(hidden) You’re on the last step.

			p For a "Finish" call-to-action on the last step instead of a disabled Next, listen for #[code ps:activationstart] (it carries #[code atStart] / #[code atEnd]) and swap the button yourself.

			h3 Or wrap instead: looping
			p Add #[code data-ps-loop] and Prev / Next #[strong wrap] instead of stopping: #[code next()] past the last panel goes to the first, #[code prev()] past the first to the last. The ends are always reachable, so PanelSet never disables the buttons. This suits a #[strong carousel] or cycler, not a step-by-step wizard (wrapping past the end would skip the validation). With #[code data-ps-levels] on too, the wrap still slides in the button’s direction: #[strong Next] keeps moving forward, even from the last slide back to the first.

			.demo
				#cycler.tab-content(data-panelset data-ps-levels data-ps-loop)
					.panel-wrapper
						.active#cycle-1(role="tabpanel" aria-label="Slide 1")
							h3 Slide 1
							p Keep clicking #[strong Next]: past the last slide it wraps straight back to the first.
						#cycle-2(role="tabpanel" hidden aria-label="Slide 2")
							h3 Slide 2
							p And #[strong Previous] wraps the other way, from the first slide to the last.
						#cycle-3(role="tabpanel" hidden aria-label="Slide 3")
							h3 Slide 3
							p Three slides, no ends: the buttons never disable.
				.wizard-nav
					button.secondary(data-ps-prev="#cycler") Previous
					button(data-ps-next="#cycler") Next

			h4 Markup
			+codeblock('HTML')
				#cycler(data-panelset data-ps-levels data-ps-loop)
					.panel-wrapper
						#cycle-1.active(role="tabpanel") ...
						#cycle-2(role="tabpanel" hidden) ...
						#cycle-3(role="tabpanel" hidden) ...
				+n
				.wizard-nav
					button(data-ps-prev="#cycler") Previous
					button(data-ps-next="#cycler") Next



	+section("Requiring valid input before advancing")
		p This wizard puts a tab strip #[em and] Previous / Next buttons over one PanelSet. A required checkbox on each step controls progress: you cannot move forward (by button #[em or] by clicking a later tab) until the current step is ticked. Because tab clicks, #[code next()] and #[code prev()] all funnel through #[code show()], one #[code ps:beforeactivate] listener guards every path. Stepping #[em back] is always allowed.

		.card
			.demo
				.demo-controls
					button(role="tab" aria-controls="vstep-1" aria-selected="true") Account
					button(role="tab" aria-controls="vstep-2") Profile
					button(role="tab" aria-controls="vstep-3") Confirm

				br

				#vwizard.tab-content(data-panelset data-ps-levels data-auto-focus="first")
					.panel-wrapper
						.active#vstep-1(role="tabpanel" aria-label="Account")
							h3 Step 1. Account
							label.wizard-check
								input(type="checkbox" required)
								span I agree to create an account
						#vstep-2(role="tabpanel" hidden aria-label="Profile")
							h3 Step 2. Profile
							label.wizard-check
								input(type="checkbox" required)
								span I confirm my profile details are correct
						#vstep-3(role="tabpanel" hidden aria-label="Confirm")
							h3 Step 3. Confirm
							label.wizard-check
								span Thank you for signing up! No more steps, so no checkbox here.
				.wizard-nav
					button.secondary(data-ps-prev="#vwizard" data-ps-disabled-hint="vwiz-prev-hint") Previous
					button(data-ps-next="#vwizard") Next
				span#vwiz-prev-hint(hidden) You’re on the first step.
				span#vwiz-next-hint(hidden) You’re on the last step.
				span#vwiz-next-incomplete-hint(hidden) Complete this step to continue.

			p #[strong Try it]: with a box unticked, #[strong Next] is disabled (focus it to hear why) and later tabs are locked. Tick the box and #[strong Next] enables; then you can move on.

			h4 Markup
			+codeblock('HTML')
				.demo-controls
					button(role="tab" aria-controls="vstep-1" aria-selected="true") Account
					button(role="tab" aria-controls="vstep-2") Profile
					button(role="tab" aria-controls="vstep-3") Confirm
				+n
				#vwizard(data-panelset data-ps-levels)
					.panel-wrapper
						#vstep-1.active(role="tabpanel")
							label
								input(type="checkbox" required)
								span  I agree to create an account
						#vstep-2(role="tabpanel" hidden) …
						#vstep-3(role="tabpanel" hidden) …
				+n
				.wizard-nav
					button(data-ps-prev="#vwizard" data-ps-disabled-hint="vwiz-prev-hint") Previous
					button(data-ps-next="#vwizard") Next
				span#vwiz-prev-hint(hidden) You’re on the first step.
				span#vwiz-next-hint(hidden) You’re on the last step.
				span#vwiz-next-incomplete-hint(hidden) Complete this step to continue.

			h4 JavaScript
			+codeblock('JS').
				const vwizard = document.querySelector('#vwizard');
				const ps      = vwizard.panelSet;
				const tabs    = [...document.querySelectorAll('[role="tab"]')];
				const nextBtn = document.querySelector('[data-ps-next="#vwizard"]');

				const panelOf = tab => document.getElementById(tab.getAttribute('aria-controls'));
				const valid   = panel => !panel.querySelector('[required]:invalid');

				tabs.forEach(tab => tab.addEventListener('click', event => {
					if (tab.getAttribute('aria-disabled') !== 'true')
						ps.show(tab.getAttribute('aria-controls'), { event });
				}));

				vwizard.addEventListener('ps:beforeactivate', event => {
					const { outgoingPanel, targetPanel } = event.detail;
					const forward = outgoingPanel &&
						(outgoingPanel.compareDocumentPosition(targetPanel) & Node.DOCUMENT_POSITION_FOLLOWING);
					if (forward && !valid(outgoingPanel)) {
						event.preventDefault();
						outgoingPanel.querySelector('[required]:invalid')?.focus();
					}
				});

				function refresh() {
					const firstInvalid = tabs.findIndex(t => !valid(panelOf(t)));
					tabs.forEach((t, i) =>
						t.setAttribute('aria-disabled', String(firstInvalid !== -1 && i > firstInvalid)));
					const i = tabs.findIndex(t => t.getAttribute('aria-controls') === ps.getActive());
					const atEnd = i === tabs.length - 1;
					const incomplete = i >= 0 && !valid(panelOf(tabs[i]));
					nextBtn.setAttribute('aria-disabled', String(atEnd || incomplete));
					const hint = atEnd ? 'vwiz-next-hint' : incomplete ? 'vwiz-next-incomplete-hint' : '';
					if (hint) nextBtn.setAttribute('aria-describedby', hint);
					else nextBtn.removeAttribute('aria-describedby');
				}
				vwizard.addEventListener('change', refresh);
				vwizard.addEventListener('ps:activationcomplete', refresh);
				refresh();

			.callout
				+warning()
				p #[strong Note]: the tab locking above is still done by hand. If you want to avoid that, just use #[a(href=url('/panelcontrol/examples/wizard.html')) PanelControl].




append styles
	style.
		#wizard,
		#vwizard,
		#cycler {
			--ps-panel-in-transform-from: translateX(40px);
			--ps-panel-out-transform-to:  translateX(-40px);
			--ps-panel-in-delay: 0s;
		}
		.wizard-frame {
			min-height: var(--ps-max-height);
		}
		.wizard-nav {
			display: flex;
			justify-content: space-between;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.wizard-check {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 0.75rem;
		}
		.tabs [role="tab"][aria-disabled="true"],
		.demo-controls [aria-disabled="true"],
		.wizard-nav [aria-disabled="true"] {
			opacity: 0.4;
			cursor: not-allowed;
		}


append scripts
	if isProd
		script(src=`${basePath}lib/panelset.js` vite-ignore)
		script.
			PanelSet.init();
	else
		script(type="module").
			import PanelSet from 'panelset';
			PanelSet.init({ debug: true });

	script.
		(() => {
			const vwizard = document.querySelector('#vwizard');
			if (!vwizard) return;
			const tabs    = [...document.querySelectorAll('[role="tab"][aria-controls^="vstep-"]')];
			const nextBtn = document.querySelector('[data-ps-next="#vwizard"]');
			const panelOf = tab => document.getElementById(tab.getAttribute('aria-controls'));
			const valid   = panel => !panel.querySelector('[required]:invalid');

			tabs.forEach(tab => tab.addEventListener('click', e => {
				if (tab.getAttribute('aria-disabled') !== 'true')
					vwizard.panelSet?.show(tab.getAttribute('aria-controls'), { event: e });
			}));

			vwizard.addEventListener('ps:beforeactivate', e => {
				const { outgoingPanel, targetPanel } = e.detail;
				const forward = outgoingPanel &&
					(outgoingPanel.compareDocumentPosition(targetPanel) & Node.DOCUMENT_POSITION_FOLLOWING);
				if (forward && !valid(outgoingPanel)) {
					e.preventDefault();
					outgoingPanel.querySelector('[required]:invalid')?.focus();
				}
			});

			const refresh = () => {
				const ps = vwizard.panelSet;
				if (!ps) return;
				const firstInvalid = tabs.findIndex(t => !valid(panelOf(t)));
				tabs.forEach((t, i) =>
					t.setAttribute('aria-disabled', String(firstInvalid !== -1 && i > firstInvalid)));
				const i = tabs.findIndex(t => t.getAttribute('aria-controls') === ps.getActive());
				const atEnd = i === tabs.length - 1;
				const incomplete = i >= 0 && !valid(panelOf(tabs[i]));
				nextBtn?.setAttribute('aria-disabled', String(atEnd || incomplete));
				const hint = atEnd ? 'vwiz-next-hint' : incomplete ? 'vwiz-next-incomplete-hint' : '';
				if (hint) nextBtn?.setAttribute('aria-describedby', hint);
				else nextBtn?.removeAttribute('aria-describedby');
			};
			vwizard.addEventListener('change', refresh);
			vwizard.addEventListener('ps:activationcomplete', refresh);
			if (vwizard.panelSet) refresh();
			else vwizard.addEventListener('ps:ready', refresh, { once: true });
		})();
