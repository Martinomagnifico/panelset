extends /views/templates/layouts/_base

append variables
	- pagetitle = "PanelSet: Web Component"


block content
	.lane
		.container
			.page-header
				h1 Web Component
				p.lead Use PanelSet as a native HTML element.

	+section("Getting started")
		p #[code &lt;ps-panelset&gt;] is a custom element that wraps PanelSet. Everything works the same: events, async content, closable mode, #[code persist], all of it. The only differences are how you register it and how you write attributes.

		.title-text
			h3 IIFE (no build step)
			p Include the bundled script. #[code register()] is called automatically with the default #[code ps] prefix. No extra setup needed.

		+codeblock('HTML')
			script(src="panelset.js")
			+n
			// <ps-panelset> is ready immediately after the script loads
			ps-panelset(id="my-tabs")
				.panel-wrapper
					#tab-1(role="tabpanel" class="active") ...
					#tab-2(role="tabpanel" hidden) ...






		.title-text
			h3 Module: import and done
			p Just import this path and both elements are registered. Nothing to call.

		+codeblock('JS').
			import 'panelset/register';
			// <ps-panel> and <ps-panelset> are now registered

		.title-text
			h3 Module: explicit call
			p Call #[code register()] yourself when you need control over timing or the prefix.

		+codeblock('JS').
			import { register } from 'panelset';
			register(); // registers <ps-panel> and <ps-panelset>

	+section("Basic tab example")
		p A tab interface using #[code &lt;ps-panelset&gt;] with plain attributes. The attribute names match the data attributes but without the #[code data-] prefix: #[code data-panelset-align] becomes #[code panelset-align].

		.card

			.demo
				+exampletabset('wc-ps', true)
				+examplepanelset('wc-ps', wc=true).tab-content


			+codeblock('HTML')
				+exampletabset('wc-ps', true)
				+n
				ps-panelset
					.panel-wrapper
						.active(role="tabpanel" id="wc-ps-panel-1" aria-label="Features") ...
						div(role="tabpanel" id="wc-ps-panel-2" hidden aria-label="Pricing") ...
						div(role="tabpanel" id="wc-ps-panel-3" hidden aria-label="Support") ...

	+section("Trigger wiring")
		p PanelSet requires a click handler to call #[code show()]. The only change from the standard pattern is using #[code closest('ps-panelset')] instead of #[code closest('[data-panelset]')] to find the container.

		+codeblock('JS').
			document.addEventListener('click', event => {
				const button = event.target.closest('button[aria-controls]');
				if (!button) return;

				const tablist = button.closest('[role="tablist"]');
				tablist?.querySelectorAll('[role="tab"]').forEach(tab => {
					tab.setAttribute('aria-selected', 'false');
				});
				button.setAttribute('aria-selected', 'true');

				const panelId = button.getAttribute('aria-controls');
				const panel = document.getElementById(panelId);
				const container = panel?.closest('ps-panelset'); // instead of '[data-panelset]'

				container?.panelSet?.show(panelId, { event });
			});

	+section("Custom prefix")
		p Pass a string to #[code register()] to use a custom element name prefix. The default is #[code ps].

		+codeblock('JS').
			import { register } from 'panelset';

			register();         // <ps-panel>, <ps-panelset>
			register('solar'); // <solar-panel>, <solar-panelset>

		p It is safe to call #[code register()] multiple times. It skips any name that is already defined.

append scripts
	if isProd
		script(src=`${basePath}assets/scripts/example-wc-tabs.js` vite-ignore)
		//- IIFE in _scripts.pug already calls register(); no extra init needed.
	else
		script(type="module").
			import { register } from 'panelset';
			register();
		script(type="module" src="/src/assets/scripts/example-wc-tabs.js")
