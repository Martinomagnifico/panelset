
mixin apiEvent(name)
	- const id = 'event-' + name.replace(/[^a-z0-9]/gi, '-').toLowerCase()
	.card.api.no-padding
		button.card-trigger(aria-controls=id aria-expanded="false")
			h4.code= name
			+chevron()
		div(id=id data-panel)
			.panel-wrapper
				.card-content
					block


mixin apiOption(name)
	- const optionName = name.split(':')[0].split('(')[0].trim()
	- const id = 'option-' + optionName.replace(/[^a-z0-9]/gi, '-').toLowerCase()
	.card.api.no-padding
		button.card-trigger(aria-controls=id aria-expanded="false")
			h4.code= name
			+chevron()
		div(id=id data-panel)
			.panel-wrapper
				.card-content
					block


mixin faq(title)
	.card.no-padding
		button.card-trigger(data-panel-trigger)
			h3!= title
			+chevron()
		div(data-panel)
			.panel-wrapper
				.card-content
					block


mixin collapse(headinglevel, title)
	.card.no-padding
		button.card-trigger(data-panel-trigger)
			#{headinglevel}!= title
			+chevron()
		div(data-panel data-panel-persist)
			.panel-wrapper
				.card-content
					block





mixin anchor(tag, id)
	- tag = tag || 'h2'
	- var title = ''
	- if (attributes.title) title = attributes.title
	- id = id || attributes.id || null
	- var attrs = Object.assign({}, attributes); delete attrs.id; delete attrs.title;
	- if (!id) { id = title.replace(/<[^>]*>/g, '').trim().toLowerCase().replace(/[^a-z0-9\s]/g, '').trim().replace(/\s+/g, '-'); }
	#{tag}.heading-anchor(id=id)&attributes(attrs)
		!= title
		a(href=`#${id}` aria-label="Copy link to section" data-tooltip="Copy link")
			svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
				path(d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71")
				path(d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71")


mixin html
	doctype html
	html(class=page.class, lang=page.language)
		if block
			block

mixin lane-hr(title)
	.lane.hr
		.container
			hr

	if title || block
		.lane
			.container
				if title
					+anchor(title=title)
				block


mixin section(title, shorttitle)
	- const shortestitle = shorttitle || title;
	- const id = shortestitle.replace(/<[^>]*>/g, '').trim().toLowerCase().replace(/[^a-z0-9\s]/g, '').trim().replace(/\s+/g, '-');
	section(id=id)
		.container
			if title
				h2.heading-anchor!= title
					a(href=`#${id}` aria-label="Copy link to section" data-tooltip="Copy link")
						svg(xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
							path(d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71")
							path(d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71")
			if block
				block


mixin lane(title)
	.lane.hr
		.container
			hr

	if title || block
		.lane
			.container
				if title
					+anchor(title=title)
				block


- const example1Title = "Key Features"
- const example2Title = "Pricing Plans"
- const example3Title = "Support Options"

mixin example-1-content
	ul
		li This is our most important feature ever!

mixin example-2-content
	ul
		li Starter Plan: Whenever you don’t want to pay a lot.
		li Professional Plan: Ideal for managers who like to spend money!
		
mixin example-3-content
	ul
		li If you send us an email, we will probably ignore it.
		li We don't even have a community forum.
		li Opening an issue on GitHub is your next best option. Or even better: PR’s! You do the work!



mixin example-1
	h3= example1Title
	+example-1-content

mixin example-2
	h3= example2Title
	+example-2-content

mixin example-3
	h3= example3Title
	+example-3-content

mixin example-4
	h3 Time for coffee!
	p You found the hidden panel. Now support me if you like this project: #[a(href="https://ko-fi.com/martinomagnifico") Buy me a coffee].

mixin examplepanelset(id, wc=false)
	- const tag = wc ? 'ps-panelset' : 'div'
	#{tag}(id=id, data-panelset=(!wc || undefined))&attributes(attributes)
		.panel-wrapper
			.active(role="tabpanel", id=`${id}-panel-1`, aria-label="Key features")
				+example-1

			div(role="tabpanel", id=`${id}-panel-2`, hidden, aria-label="Pricing plans")
				+example-2

			div(role="tabpanel", id=`${id}-panel-3`, hidden, aria-label="Support options")
				+example-3

			if ee
				div(role="tabpanel", id=`${id}-panel-4`, hidden, aria-label="Extra panel")
					+example-4



mixin exampletabset(id, tabs=false)

	if tabs
		nav.tabs(role="tablist" aria-label="Content sections")&attributes(attributes)
			button(role="tab" aria-controls=`${id}-panel-1` aria-selected="true") Features
			button(role="tab" aria-controls=`${id}-panel-2`) Pricing
			button(role="tab" aria-controls=`${id}-panel-3`) Support

	else
		.demo-controls
			button(aria-controls=`${id}-panel-1`) Features
			button(aria-controls=`${id}-panel-2`) Pricing
			button(aria-controls=`${id}-panel-3`) Support


mixin revealsrc(kind, thesource)
	- let isProd = process.env.NODE_ENV === 'production';
	if isProd
		if kind === 'script'
			script(src=`${thesource}`)
		else
			link(rel="stylesheet", href=`${thesource}`)
	else
		if kind === 'script'
			script(src=`/node_modules/reveal.js/${thesource}`)
		else
			link(rel="stylesheet", href=`/node_modules/reveal.js/${thesource}`)

-
	const reindentCode = (code) => {
		const lines = code.split('\n');
		let minIndent = Infinity;
		
		for (const line of lines) {
			if (line.trim().length > 0) {
				const match = line.match(/^(\s*)/);
				if (match && match[1].length < minIndent) {
					minIndent = match[1].length;
				}
			}
		}
		
		if (minIndent === Infinity) {
			minIndent = 0;
		}

		const deindentedLines = lines.map(line => {
			const s = line.substring(minIndent);
			return s.replace(/^( {2})+/, m => '\t'.repeat(m.length / 2));
		});
		return deindentedLines.join('\n').trim();
	};


mixin escape()
	- var oldBuf = pug_html;
	- pug_html = '';
	block
	- pug_html = oldBuf + pug.escape(pug_html);


mixin reindent_block_html()
	- var oldBuf = pug_html;
	- pug_html = '';
	block
	- var rawPugSource = pug_html;
	- pug_html = oldBuf;
	- var deindentedCode = reindentCode(rawPugSource)
	- pug_html += deindentedCode



mixin close(label)
	- label = label || 'Close'
	button.close(data-panel-close aria-label=label)
		svg.offset(viewport="0 0 24 24", version="1.1", xmlns="http://www.w3.org/2000/svg")
			g(transform="rotate(45 12 12)")
				line(x1="0", y1="12", x2="24", y2="12")
				line(x1="12", y1="0", x2="12", y2="24")

		span.sr-only=label



//- Blank line inside a parsed-Pug +codeblock. Pug drops empty source lines, so
//- emit a literal newline into the rendered HTML where a gap is wanted: +n
mixin n()
	= "\n"

mixin codeblock(type, label)
	- label = label || type
	.code-block
		.code-header
			| #{label}
			button.copy Copy
		pre
			code(class=`language-${type}`)
				if block
					+escape()
						+reindent_block_html()
							block


