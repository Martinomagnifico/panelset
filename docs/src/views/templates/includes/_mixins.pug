// Installing/using

mixin installWizard(name, imports)
	- const cdn = 'https://cdn.jsdelivr.net/npm/panelset@latest/dist'
	- const dl = 'https://github.com/martinomagnifico/panelset/releases/latest/download/panelset.zip'

	.card.no-padding.install-wizard(data-iw-imports=imports data-iw-cdn=cdn)
		div(role="tablist").tabs
			button(role="tab" aria-controls="iw-npm") npm
			button(role="tab" aria-controls="iw-download") Download
			button(role="tab" aria-controls="iw-cdn") CDN

		.card-content(data-panelset)
			.panel-wrapper

				div(role="tabpanel" id="iw-npm" class="active" data-iw-source="npm")
					.column.gap-2
						div.column.gap-1
							h3 Installing #{name}
							.code-block
								.code-header
									| Terminal
									button.copy Copy
								pre: code npm install panelset
						+arrow
						div.column.gap-1
							h3 Using #{name}
							.install-controls
								.control-row
									.control-item.mobileblock
										label(for="formatselectnpm") Format
										select#formatselectnpm.styled-select(disabled)
											button
												selectedcontent
												+chevron(18, 'down')
											option.choice(value="esm") ESM module
									.control-item.mobileblock
										label(for="usageselectnpm") Usage
										select#usageselectnpm.styled-select.iw-usage
											button
												selectedcontent
												+chevron(18, 'down')
											option.choice(value="api") JS API
											option.choice(value="wc") Web Component
							.code-block
								.code-header
									span.iw-lang
									button.copy Copy
								pre: code.iw-code

				div(role="tabpanel" id="iw-download" hidden data-iw-source="download")
					.column.gap-2
						.column.gap-1
							h3 Installing #{name}
							p Download the ZIP from the #[a(href=dl) releases page], unzip, and place the files somewhere your HTML can reach.
						+arrow
						.column.gap-1
							h3 Using #{name}
							.install-controls
								.control-row
									.control-item.mobileblock
										label(for="formatselectdownload") Format
										select#formatselectdownload.styled-select.iw-format
											button
												selectedcontent
												+chevron(18, 'down')
											option.choice(value="esm") ESM module
											option.choice(value="iife") Script tag
									.control-item.mobileblock
										label(for="usageselectdownload") Usage
										select#usageselectdownload.styled-select.iw-usage
											button
												selectedcontent
												+chevron(18, 'down')
											option.choice(value="api") JS API
											option.choice(value="wc") Web Component
							.code-block
								.code-header
									span.iw-lang
									button.copy Copy
								pre: code.iw-code

				div(role="tabpanel" id="iw-cdn" hidden data-iw-source="cdn")
					.column.gap-2
						.column.gap-1
							h3 Installing #{name}
							p No download needed. Files are served directly from #[a(href="https://www.jsdelivr.com/") jsDelivr].
							.code-block
								.code-header Base URL
								pre: code= cdn + '/'
						+arrow
						.column.gap-1
							h3 Using #{name}
							.install-controls
								.control-row
									.control-item.mobileblock
										label(for="formatselectcdn") Format
										select#formatselectcdn.styled-select(disabled)
											button
												selectedcontent
												+chevron(18, 'down')
											option.choice(value="iife") Script tag
									.control-item.mobileblock
