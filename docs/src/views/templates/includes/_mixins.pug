mixin chevron(size, dir)
	- size = size || 24
	- var pts = { right: '9 6 15 12 9 18', left: '15 6 9 12 15 18', down: '6 9 12 15 18 9', up: '6 15 12 9 18 15' }
	- var points = pts[dir] || pts.right
	svg.chevron(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width=size height=size fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true")
		polyline(points=points)

